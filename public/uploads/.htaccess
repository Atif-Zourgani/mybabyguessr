# Bloque toute exécution de scripts dans ce dossier
<FilesMatch ".+">
    SetHandler none
    SetHandler default-handler
    Options -ExecCGI
    RemoveHandler .php .php3 .php4 .php5 .php7 .php8 .phtml .phar
    RemoveType .php .php3 .php4 .php5 .php7 .php8 .phtml .phar
</FilesMatch>

<IfModule mod_php.c>
    php_flag engine off
</IfModule>

Options -Indexes
