        <p style="font-size:0.875rem;color:var(--color-muted)">Last updated: May 27, 2026</p>
        {% if locale != 'en' %}
        <p style="margin-top:0.75rem;font-size:0.8125rem;padding:0.625rem 1rem;border-radius:0.5rem;background:rgba(196,113,74,0.08);color:var(--color-muted)">
            Cette politique est également disponible
            <a href="{{ path('app_privacy', {'_locale': 'fr'}) }}" style="color:var(--color-brand);font-weight:700">en français</a>.
            In case of conflict, the French version prevails.
        </p>
        {% endif %}
        {% endif %}
    </div>

    {# ── Contenu ── #}
    <div class="card" style="padding:1.75rem 1.5rem">

        {% if locale == 'fr' %}

        {# ══════════════ VERSION FRANÇAISE ══════════════ #}

        <p style="font-size:0.9375rem;color:var(--color-muted);line-height:1.7">
            La présente politique de confidentialité décrit comment MyBabyGuessr collecte, utilise et protège vos données personnelles, conformément au <strong>Règlement Général sur la Protection des Données (RGPD — UE 2016/679)</strong> et à la loi Informatique et Libertés.
        </p>

        {# Section #}
        <h2 style="font-size:1rem;font-weight:800;color:var(--color-ink);margin:2rem 0 0.625rem;padding-bottom:0.5rem;border-bottom:1px solid var(--color-line)">1. Responsable du traitement</h2>
