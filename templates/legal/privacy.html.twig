{% extends 'base.html.twig' %}
{% set locale = app.request.locale %}
{% block title %}{% if locale == 'fr' %}Politique de confidentialité{% elseif locale == 'de' %}Datenschutzrichtlinie{% elseif locale == 'es' %}Política de privacidad{% elseif locale == 'pt' %}Política de privacidade{% elseif locale == 'it' %}Informativa sulla privacy{% else %}Privacy Policy{% endif %} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
<section class="max-w-3xl mx-auto px-4 py-10 sm:py-16">

    {# ── En-tête ── #}
    <div style="margin-bottom:2rem">
        {% if locale == 'fr' %}
        <h1 class="text-3xl sm:text-4xl font-bold mb-3" style="color:var(--color-ink)">Politique de confidentialité</h1>
        <p style="font-size:0.875rem;color:var(--color-muted)">Dernière mise à jour : 27 mai 2026</p>
        {% else %}
