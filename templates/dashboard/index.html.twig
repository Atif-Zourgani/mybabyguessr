{% extends 'base.html.twig' %}

{% block title %}{{ 'dashboard.title'|trans }}{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}
{% block og_title %}{{ 'dashboard.title'|trans }} — MyBabyGuessr{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">

    {# ── Bienvenue ────────────────────────────────────────── #}
    <div class="mb-10 sm:mb-14">
        <h1 class="text-3xl sm:text-4xl mb-1">
            {{ 'dashboard.welcome'|trans }},
            <span style="color: var(--color-brand)">{{ app.user.firstName }}</span> !
        </h1>
        <p class="text-lg" style="color: var(--color-muted)">{{ 'dashboard.subtitle'|trans }}</p>
    </div>

    {# ── Mes Baby Guessr ─────────────────────────────────── #}
    <section aria-labelledby="games-title">
        <div class="card-panel">

            {# En-tête #}
            <div class="flex items-center gap-3 px-5 sm:px-8 py-4"
                 style="border-bottom: 1px solid var(--color-line);">
                <div class="w-1 h-4 rounded-full shrink-0"
                     style="background-color: var(--color-brand);"></div>
                <h2 id="games-title"
                    class="text-xs font-bold uppercase tracking-widest flex-1"
                    style="color: var(--color-ink)">
                    {{ 'dashboard.games.title'|trans }}
                </h2>
                {% if games|length %}
                    <a href="{{ path('app_game_new', {'_locale': app.request.locale}) }}"
                       class="btn btn-primary shrink-0"
                       style="font-size: 0.875rem; padding: 0.5rem 1rem;">
                        <span aria-hidden="true">+</span>
                        <span class="hidden sm:inline">{{ 'dashboard.games.btn_create'|trans }}</span>
                        <span class="sr-only sm:hidden">{{ 'dashboard.games.btn_create'|trans }}</span>
                    </a>
                {% endif %}
            </div>

            {# ── État vide ─────────────────────────────────── #}
            {% if games|length == 0 %}
                <div class="px-6 sm:px-10 py-12 sm:py-16 text-center"
                     style="background-color: var(--color-cream);">

                    <div class="flex justify-center mb-6">
                        <div class="flex items-center justify-center w-14 h-14 rounded-2xl"
                             style="background-color: rgba(196,113,74,.12);">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M20 12V22H4V12" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M22 7H2V12H22V7Z" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M12 22V7" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M12 7H7.5C6.84 7 6.2 6.74 5.73 6.27C5.26 5.8 5 5.16 5 4.5C5 3.84 5.26 3.2 5.73 2.73C6.2 2.26 6.84 2 7.5 2C11 2 12 7 12 7Z" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M12 7H16.5C17.16 7 17.8 6.74 18.27 6.27C18.74 5.8 19 5.16 19 4.5C19 3.84 18.74 3.2 18.27 2.73C17.8 2.26 17.16 2 16.5 2C13 2 12 7 12 7Z" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                    </div>

                    <p class="text-sm sm:text-base leading-relaxed max-w-sm mx-auto mb-3"
                       style="color: var(--color-muted)">
                        {{ 'dashboard.games.empty_desc'|trans }}
                    </p>

                    <p class="text-xs max-w-xs mx-auto mb-8"
                       style="color: var(--color-muted); opacity: 0.7">
                        {{ 'dashboard.games.empty_hint'|trans }}
                    </p>

                    <a href="{{ path('app_game_new', {'_locale': app.request.locale}) }}"
                       class="btn btn-primary w-full sm:w-auto px-10">
                        {{ 'dashboard.games.btn_create_first'|trans }}
                    </a>
                </div>

            {# ── Liste des Baby Guessr ─────────────────────── #}
            {% else %}
                <div class="p-5 sm:p-8 grid grid-cols-1 sm:grid-cols-2 gap-4"
                     style="background-color: var(--color-cream);">

                    {% for game in games %}
                    <div class="card-panel">

                        {# En-tête de la carte #}
                        <div class="flex items-center gap-4 p-4"
                             style="border-bottom: 1px solid var(--color-line);">

                            {# Thumbnail / placeholder #}
                            <div class="shrink-0 rounded-xl flex items-center justify-center"
                                 style="width: 3.5rem; height: 3.5rem; flex-shrink: 0; overflow: hidden; background-color: rgba(196,113,74,0.10);">
                                {% if game.image %}
                                    <img src="{{ asset(game.image) }}"
                                         alt=""
                                         style="width: 100%; height: 100%; object-fit: cover; display: block;">
                                {% else %}
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                        <path d="M9 12h6M9 16h6M17 21H7a2 2 0 01-2-2V5a2 2 0 012-2h7l5 5v11a2 2 0 01-2 2z" stroke="var(--color-brand)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                {% endif %}
                            </div>

                            {# Titre + date #}
                            <div class="flex-1 min-w-0">
                                <div class="font-bold leading-tight truncate"
                                     style="color: var(--color-ink)">
                                    {{ game.displayTitle }}
                                </div>
                                <div class="text-xs mt-0.5"
                                     style="color: var(--color-muted)">
                                    {{ game.createdAt|date('d/m/Y') }}
                                </div>
                            </div>

                            {# Badge statut #}
                            {% set statusStyles = {
                                'open':     'background-color: rgba(196,113,74,0.12); color: var(--color-brand)',
                                'closed':   'background-color: #f3f4f6; color: #6b7280',
                                'revealed': 'background-color: rgba(39,103,73,0.10); color: #276749'
                            } %}
                            <span class="shrink-0 text-xs font-bold px-2.5 py-1 rounded-full"
                                  style="{{ statusStyles[game.status.value] }}">
                                {{ ('games.status.' ~ game.status.value)|trans }}
                            </span>

                        </div>

                        {# Catégories actives + bouton Voir #}
                        <div class="px-4 py-3 flex items-center gap-2 flex-wrap">
                            <div class="flex flex-wrap gap-1.5 flex-1">
                                {% if game.isGuessGender() %}<span class="pill">{{ 'games.pill.gender'|trans }}</span>{% endif %}
                                {% if game.isGuessName() %}  <span class="pill">{{ 'games.pill.name'|trans }}</span>{% endif %}
                                {% if game.isGuessDate() %}  <span class="pill">{{ 'games.pill.date'|trans }}</span>{% endif %}
                                {% if game.isGuessWeight() %}<span class="pill">{{ 'games.pill.weight'|trans }}</span>{% endif %}
                                {% if game.isGuessHeight() %}<span class="pill">{{ 'games.pill.height'|trans }}</span>{% endif %}
                            </div>
                            <a href="{{ path('app_game_show', {'_locale': app.request.locale, 'token': game.token}) }}"
                               class="btn btn-secondary shrink-0"
                               style="font-size: 0.8125rem; padding: 0.375rem 1rem;">
                                {{ 'games.btn_view'|trans }} &rarr;
                            </a>
                        </div>

                    </div>
                    {% endfor %}

                </div>
            {% endif %}

        </div>
    </section>

</div>
{% endblock %}
