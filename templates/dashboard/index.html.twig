{% extends 'base.html.twig' %}

{% block title %}{{ 'dashboard.title'|trans }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}
{% block og_title %}{{ 'dashboard.title'|trans }} — MyBabyGuessr{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">

    {# ── Bienvenue ────────────────────────────────────────── #}
    <div class="mb-10 sm:mb-14" style="position:relative">
        <img src="{{ asset('images/illustration/soleil.png') }}" alt="" aria-hidden="true"
             style="position:absolute;top:-8px;right:0;width:70px;opacity:0.75;pointer-events:none;z-index:0">
        <h1 class="text-3xl sm:text-4xl mb-1" style="position:relative;z-index:1">
            {{ 'dashboard.welcome'|trans }},
            <span style="color: var(--color-brand)">{{ app.user.firstName }}</span> !
        </h1>
        <p class="text-lg" style="color: var(--color-muted); position:relative;z-index:1">
            {% if games|length > 0 %}
                {{ 'dashboard.active_games'|trans({'%count%': games|length}) }}
            {% else %}
                {{ 'dashboard.subtitle'|trans }}
            {% endif %}
        </p>
    </div>

    {# ── Mes Baby Guessr ─────────────────────────────────── #}
    <section aria-labelledby="games-title">
        <div class="card-panel">

            {# En-tête section #}
            <div class="flex items-center gap-3 px-5 sm:px-8 py-4"
                 style="border-bottom: 1px solid var(--color-line);">
                <div class="w-1 h-4 rounded-full shrink-0"
                     style="background-color: var(--color-brand);"></div>
                <h2 id="games-title"
                    class="text-xs font-bold uppercase tracking-widest flex-1"
                    style="color: var(--color-ink)">
                    {{ 'dashboard.games.title'|trans }}
                </h2>
                {% if games|length %}
                    <a href="{{ path('app_game_new', {'_locale': app.request.locale}) }}"
                       class="btn btn-primary shrink-0"
                       style="font-size: 0.875rem; padding: 0.5rem 1rem;">
                        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        <span class="hidden sm:inline">{{ 'dashboard.games.btn_create'|trans }}</span>
                        <span class="sr-only sm:hidden">{{ 'dashboard.games.btn_create'|trans }}</span>
                    </a>
                {% endif %}
            </div>

            {# ── État vide ─────────────────────────────────── #}
            {% if games|length == 0 %}
                <div class="px-6 sm:px-10 py-12 sm:py-16 text-center"
                     style="background-color: var(--color-cream);">

                    <div class="flex justify-center mb-6">
                        <div class="flex items-center justify-center w-14 h-14 rounded-2xl"
                             style="background-color: rgba(196,113,74,.12);">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M20 12V22H4V12" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M22 7H2V12H22V7Z" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M12 22V7" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M12 7H7.5C6.84 7 6.2 6.74 5.73 6.27C5.26 5.8 5 5.16 5 4.5C5 3.84 5.26 3.2 5.73 2.73C6.2 2.26 6.84 2 7.5 2C11 2 12 7 12 7Z" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M12 7H16.5C17.16 7 17.8 6.74 18.27 6.27C18.74 5.8 19 5.16 19 4.5C19 3.84 18.74 3.2 18.27 2.73C17.8 2.26 17.16 2 16.5 2C13 2 12 7 12 7Z" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                    </div>

                    <p class="text-xl sm:text-2xl font-bold mb-8" style="color: var(--color-ink)">
                        {{ 'dashboard.games.empty_title'|trans }}
                    </p>

                    {# Mini-guide 3 étapes #}
                    <div class="max-w-xs mx-auto flex flex-col gap-5 mb-10 text-left">
                        {% for i in 1..3 %}
                        <div class="flex items-start gap-4">
                            <div class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-white text-xs font-bold"
                                 style="background-color: var(--color-brand);">
                                {{ i }}
                            </div>
                            <div>
                                <p class="text-sm font-bold" style="color: var(--color-ink)">
                                    {{ ('dashboard.games.step' ~ i ~ '_title')|trans }}
                                </p>
                                <p class="text-sm mt-0.5 leading-relaxed" style="color: var(--color-muted)">
                                    {{ ('dashboard.games.step' ~ i ~ '_desc')|trans }}
                                </p>
                            </div>
                        </div>
                        {% endfor %}
                    </div>

                    {# Reveal optionnel #}
                    <div class="max-w-xs mx-auto flex items-start gap-3 mb-10 text-left px-4 py-3 rounded-xl"
                         style="background-color: rgba(196,113,74,0.08);">
                        <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none"
                             stroke="var(--color-brand)" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <p class="text-xs leading-relaxed" style="color: var(--color-muted)">
                            {{ 'dashboard.games.empty_reveal'|trans }}
                        </p>
                    </div>

                    <div class="flex justify-center items-end gap-6">
                        <a href="{{ path('app_game_new', {'_locale': app.request.locale}) }}"
                           class="btn btn-primary px-10">
                            {{ 'dashboard.games.btn_create_first'|trans }}
                        </a>
                        <img src="{{ asset('images/illustration/girafe.png') }}" alt="" aria-hidden="true"
                             style="width:72px;opacity:0.90;pointer-events:none;flex-shrink:0">
                    </div>
                </div>

            {# ── Liste des Baby Guessr ─────────────────────── #}
            {% else %}
                <div class="p-4 sm:p-8 grid grid-cols-1 sm:grid-cols-2 gap-4"
                     style="background-color: var(--color-cream);">

                    {% set papillons = ['papillon1.png', 'papillon2.png', 'papillon3.png'] %}
                    {% for game in games %}
                    {% set papillon = papillons[loop.index0 % 3] %}
                    <div class="card-panel transition duration-200 hover:shadow-xl" style="position:relative;overflow:hidden">

                        {# En-tête cliquable → page show #}
                        <a href="{{ path('app_game_show', {'_locale': app.request.locale, 'token': game.token}) }}"
                           class="flex items-center gap-4 p-4 transition-colors duration-150 hover:bg-[#F8F3EE]"
                           style="border-bottom: 1px solid var(--color-line); text-decoration: none;"
                           aria-label="{{ game.displayTitle }}">

                            {# Thumbnail #}
                            <div class="shrink-0 rounded-xl flex items-center justify-center"
                                 style="width: 4.5rem; height: 4.5rem; overflow: hidden; background-color: rgba(196,113,74,0.10);">
                                {% if game.image %}
                                    <img src="{{ asset(game.image) }}"
                                         alt=""
                                         width="72" height="72"
                                         loading="lazy"
                                         style="width: 100%; height: 100%; object-fit: cover; display: block;">
                                {% else %}
                                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                        <path d="M20 12V22H4V12" stroke="var(--color-brand)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M22 7H2V12H22V7Z" stroke="var(--color-brand)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M12 22V7" stroke="var(--color-brand)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M12 7H7.5C6.84 7 6.2 6.74 5.73 6.27C5.26 5.8 5 5.16 5 4.5C5 3.84 5.26 3.2 5.73 2.73C6.2 2.26 6.84 2 7.5 2C11 2 12 7 12 7Z" stroke="var(--color-brand)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M12 7H16.5C17.16 7 17.8 6.74 18.27 6.27C18.74 5.8 19 5.16 19 4.5C19 3.84 18.74 3.2 18.27 2.73C17.8 2.26 17.16 2 16.5 2C13 2 12 7 12 7Z" stroke="var(--color-brand)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                {% endif %}
                            </div>

                            {# Titre + date #}
                            <div class="flex-1 min-w-0">
                                <div class="font-bold leading-tight truncate" style="color: var(--color-ink)">
                                    {{ game.displayTitle }}
                                </div>
                                <div class="text-xs mt-0.5" style="color: var(--color-muted)">
                                    {{ game.createdAt|date(app.request.locale != 'en' ? 'd/m/Y' : 'm/d/Y') }}
                                </div>
                            </div>

                            {# Badge statut #}
                            {% set statusStyles = {
                                'open':     'background-color: rgba(196,113,74,0.12); color: var(--color-brand)',
                                'closed':   'background-color: #f3f4f6; color: #6b7280',
                                'revealed': 'background-color: rgba(39,103,73,0.10); color: #276749'
                            } %}
                            <span class="shrink-0 text-xs font-bold px-2.5 py-1 rounded-full"
                                  style="{{ statusStyles[game.status.value] }}">
                                {{ ('games.status.' ~ game.status.value)|trans }}
                            </span>

                        </a>

                        {# Footer — fond cream #}
                        <div style="background-color: var(--color-cream); position:relative; overflow:hidden">
                            <img src="{{ asset('images/illustration/' ~ papillon) }}" alt="" aria-hidden="true"
                                 style="position:absolute;bottom:2px;right:6px;width:30px;opacity:0.55;pointer-events:none;z-index:0">

                            {# Actions pleine largeur #}
                            <div class="grid grid-cols-2">
                                <a href="{{ path('app_game_show', {'_locale': app.request.locale, 'token': game.token}) }}"
                                   class="flex items-center justify-center gap-1.5 py-3 text-sm font-semibold transition-colors duration-150 hover:bg-[#ede6de]"
                                   style="color: var(--color-ink); text-decoration: none; border-right: 1px solid var(--color-line)">
                                    {{ 'games.btn_view'|trans }} →
                                </a>
                                <a href="{{ path('app_game_share', {'_locale': app.request.locale, 'token': game.token}) }}"
                                   class="flex items-center justify-center gap-1.5 py-3 text-sm font-semibold transition-colors duration-150 hover:bg-[#ede6de]"
                                   style="color: var(--color-brand); text-decoration: none;">
                                    <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2"
                                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <circle cx="18" cy="5" r="3"/>
                                        <circle cx="6" cy="12" r="3"/>
                                        <circle cx="18" cy="19" r="3"/>
                                        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                                        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                                    </svg>
                                    {{ 'games.btn_share'|trans }}
                                </a>
                            </div>

                        </div>

                    </div>
                    {% endfor %}

                </div>
            {% endif %}

        </div>
    </section>

    <div class="flex justify-end mt-6 pr-2" style="pointer-events:none" aria-hidden="true">
        <img src="{{ asset('images/illustration/singe.png') }}" alt=""
             style="width:80px;opacity:0.72">
    </div>

</div>
{% endblock %}
