{% extends 'base.html.twig' %}

{% block title %}{{ 'dashboard.title'|trans }}{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}
{% block og_title %}{{ 'dashboard.title'|trans }} — MyBabyGuessr{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">

    {# ── Bienvenue ────────────────────────────────────────── #}
    <div class="mb-12">
        <h1 class="text-3xl mb-1">
            {{ 'dashboard.welcome'|trans }},
            <span class="text-brand">{{ app.user.firstName }}</span> !
        </h1>
        <p class="text-muted">{{ 'dashboard.subtitle'|trans }}</p>
    </div>

    {# ── Mes parties ──────────────────────────────────────── #}
    <section aria-labelledby="games-title">

        <div class="flex items-center justify-between mb-6">
            <h2 id="games-title" class="text-2xl">
                {{ 'dashboard.games.title'|trans }}
            </h2>
            <a href="{{ path('app_game_new', {'_locale': app.request.locale}) }}"
               class="btn btn-secondary !py-2 !px-5 !text-sm">
                + {{ 'dashboard.games.btn_create'|trans }}
            </a>
        </div>

        {# État vide — aucune partie créée #}
        <div class="card text-center" style="padding: 4rem 2rem;">

            <div class="w-20 h-20 rounded-full border-2 border-dashed flex items-center justify-center mx-auto mb-6"
                 style="border-color: var(--color-brand); background-color: var(--color-cream);">
                <span class="text-3xl font-black" style="color: var(--color-brand)">?</span>
            </div>

            <h3 class="text-xl mb-3">
                {{ 'dashboard.games.empty_title'|trans }}
            </h3>

            <p class="text-muted max-w-sm mx-auto mb-8 leading-relaxed">
                {{ 'dashboard.games.empty_desc'|trans }}
            </p>

            <a href="{{ path('app_game_new', {'_locale': app.request.locale}) }}"
               class="btn btn-primary px-8">
                {{ 'dashboard.games.btn_create_first'|trans }}
            </a>

        </div>

    </section>

</div>
{% endblock %}
