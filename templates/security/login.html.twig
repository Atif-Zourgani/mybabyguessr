{% extends 'base.html.twig' %}

{% block title %}{{ 'login.title'|trans }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block stylesheets %}
<style>
.deco-login { position:absolute; pointer-events:none; z-index:2; }
.deco-login-papillon { top:20px; left:20px; width:34px; opacity:0.75; }
.deco-login-feuille  { top:14px; right:20px; width:30px; opacity:0.68; transform:rotate(20deg); }
.deco-login-elephant { bottom:-20px; left:14px; width:68px; opacity:0.88; }
@media (min-width:640px) {
    .deco-login-papillon { top:24px; left:calc(50% - 252px); width:42px; }
    .deco-login-feuille  { top:20px; left:calc(50% + 204px); width:36px; transform:rotate(20deg); }
    .deco-login-elephant { bottom:-20px; left:calc(50% - 310px); width:100px; }
}
</style>
{% endblock %}

{% block body %}
<section class="flex items-center justify-center min-h-[calc(100vh-10rem)] px-4 py-6 sm:py-12"
         style="position:relative;overflow:hidden">

    <img src="{{ asset('images/illustration/papillon1.png') }}"    alt="" aria-hidden="true" class="deco-login deco-login-papillon">
    <img src="{{ asset('images/illustration/feuille_orange.png') }}" alt="" aria-hidden="true" class="deco-login deco-login-feuille">
    <img src="{{ asset('images/illustration/elephant.png') }}"     alt="" aria-hidden="true" class="deco-login deco-login-elephant">

    <div class="card w-full max-w-md" style="position:relative;z-index:1">

        {# Logo #}
        <div class="flex justify-center mb-6">
            <img src="{{ asset('images/logo-mybabyguessr.png') }}"
                 alt="MyBabyGuessr"
                 width="1024" height="1024"
                 fetchpriority="high"
                 class="h-16 sm:h-28 w-auto">
        </div>

        {# Titre #}
        <h1 class="text-2xl text-center mb-8">
            {{ 'login.title'|trans }}
        </h1>

        {# Erreur d'authentification #}
        {% if error %}
            <div class="flash-error mb-6" role="alert">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {# Déjà connecté #}
        {% if app.user %}
            <div class="flash-success mb-6">
                {{ 'login.logged_in_as'|trans({'%email%': app.user.userIdentifier}) }}
                — <a href="{{ path('app_logout', {'_locale': app.request.locale}) }}">{{ 'login.logout'|trans }}</a>
            </div>
        {% endif %}

        <form method="post">

            {# Email #}
            <div class="mb-5">
                <label for="inputEmail" class="form-label">{{ 'login.email'|trans }}</label>
                <input type="email"
                       id="inputEmail"
                       name="email"
                       value="{{ last_username }}"
                       class="form-input"
                       autocomplete="email"
                       required
                       autofocus
                       aria-required="true">
            </div>

            {# Mot de passe #}
            <div class="mb-2">
                <label for="inputPassword" class="form-label">{{ 'login.password'|trans }}</label>
                <input type="password"
                       id="inputPassword"
                       name="password"
                       class="form-input"
                       autocomplete="current-password"
                       required
                       aria-required="true">
            </div>

            {# Mot de passe oublié #}
            <div class="text-right mb-5">
                <a href="{{ path('app_forgot_password_request', {'_locale': app.request.locale}) }}"
                   class="text-sm">
                    {{ 'login.forgot_password'|trans }}
                </a>
            </div>

            <input type="hidden" name="_csrf_token"
                   data-controller="csrf-protection"
                   value="{{ csrf_token('authenticate') }}">

            {# Se souvenir de moi #}
            <div class="flex items-center gap-2 mb-6">
                <input type="checkbox"
                       id="rememberMe"
                       name="_remember_me"
                       class="w-4 h-4 cursor-pointer rounded"
                       style="accent-color: var(--color-brand)">
                <label for="rememberMe" class="text-sm text-muted cursor-pointer">
                    {{ 'login.remember_me'|trans }}
                </label>
            </div>

            <button type="submit" class="btn btn-primary w-full">
                {{ 'login.submit'|trans }}
            </button>
        </form>

        {# Lien inscription #}
        <p class="text-center text-sm text-muted mt-6">
            {{ 'login.no_account'|trans }}
            <a href="{{ path('app_register', {'_locale': app.request.locale}) }}">
                {{ 'register.title'|trans }}
            </a>
        </p>

    </div>
</section>
{% endblock %}
