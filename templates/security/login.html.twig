{% extends 'base.html.twig' %}

{% block title %}{{ 'login.title'|trans }}{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
<section class="flex items-center justify-center min-h-[calc(100vh-10rem)] px-4 py-12">
    <div class="card w-full max-w-md">

        {# Logo #}
        <div class="flex justify-center mb-6">
            <img src="{{ asset('images/logo-mybabyguessr.png') }}"
                 alt="MyBabyGuessr"
                 class="h-28 w-auto">
        </div>

        {# Titre #}
        <h1 class="text-2xl text-center mb-8" style="color: var(--color-ink)">
            {{ 'login.title'|trans }}
        </h1>

        {# Erreur d'authentification #}
        {% if error %}
            <div class="flash-error mb-6" role="alert">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {# Déjà connecté #}
        {% if app.user %}
            <div class="flash-success mb-6">
                {{ 'login.logged_in_as'|trans({'%email%': app.user.userIdentifier}) }}
                — <a href="{{ path('app_logout', {'_locale': app.request.locale}) }}">{{ 'login.logout'|trans }}</a>
            </div>
        {% endif %}

        <form method="post" novalidate>

            {# Email #}
            <div class="mb-5">
                <label for="inputEmail" class="form-label">{{ 'login.email'|trans }}</label>
                <input type="email"
                       id="inputEmail"
                       name="email"
                       value="{{ last_username }}"
                       class="form-input"
                       autocomplete="email"
                       required
                       autofocus
                       aria-required="true">
            </div>

            {# Mot de passe #}
            <div class="mb-2">
                <label for="inputPassword" class="form-label">{{ 'login.password'|trans }}</label>
                <input type="password"
                       id="inputPassword"
                       name="password"
                       class="form-input"
                       autocomplete="current-password"
                       required
                       aria-required="true">
            </div>

            {# Mot de passe oublié #}
            <div class="text-right mb-5">
                <a href="{{ path('app_forgot_password_request', {'_locale': app.request.locale}) }}"
                   class="text-sm">
                    {{ 'login.forgot_password'|trans }}
                </a>
            </div>

            <input type="hidden" name="_csrf_token"
                   data-controller="csrf-protection"
                   value="{{ csrf_token('authenticate') }}">

            {# Se souvenir de moi #}
            <div class="flex items-center gap-2 mb-6">
                <input type="checkbox"
                       id="rememberMe"
                       name="_remember_me"
                       class="w-4 h-4 cursor-pointer rounded"
                       style="accent-color: var(--color-brand)">
                <label for="rememberMe" class="text-sm text-muted cursor-pointer">
                    {{ 'login.remember_me'|trans }}
                </label>
            </div>

            <button type="submit" class="btn btn-primary w-full">
                {{ 'login.submit'|trans }}
            </button>
        </form>

        {# Lien inscription #}
        <p class="text-center text-sm text-muted mt-6">
            {{ app.request.locale == 'fr' ? 'Pas encore de compte ?' : 'No account yet?' }}
            <a href="{{ path('app_register', {'_locale': app.request.locale}) }}">
                {{ 'register.title'|trans }}
            </a>
        </p>

    </div>
</section>
{% endblock %}
