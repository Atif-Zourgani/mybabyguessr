<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#F8F3EE">

    {# ── Favicon ──────────────────────────────────────────── #}
    <link rel="icon"             href="{{ asset('images/favicon.png') }}" type="image/png">
    <link rel="apple-touch-icon" href="{{ asset('images/logo-mybabyguessr.png') }}">

    {# ── SEO ──────────────────────────────────────────────── #}
    <title>{% block title %}MyBabyGuessr{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{{ 'home.seo.description'|trans }}{% endblock %}">
    <meta name="robots" content="{% block robots %}index, follow{% endblock %}">

    {# ── Canonical & hreflang ─────────────────────────────── #}
    <link rel="canonical" href="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
    {% if app.request.attributes.has('_route') %}
        {% set _route  = app.request.attributes.get('_route') %}
        {% set _params = app.request.attributes.get('_route_params') %}
        <link rel="alternate" hreflang="fr"        href="{{ url(_route, _params|merge({'_locale': 'fr'})) }}">
        <link rel="alternate" hreflang="en"        href="{{ url(_route, _params|merge({'_locale': 'en'})) }}">
        <link rel="alternate" hreflang="es"        href="{{ url(_route, _params|merge({'_locale': 'es'})) }}">
        <link rel="alternate" hreflang="pt"        href="{{ url(_route, _params|merge({'_locale': 'pt'})) }}">
        <link rel="alternate" hreflang="de"        href="{{ url(_route, _params|merge({'_locale': 'de'})) }}">
        <link rel="alternate" hreflang="it"        href="{{ url(_route, _params|merge({'_locale': 'it'})) }}">
        <link rel="alternate" hreflang="x-default" href="{{ url(_route, _params|merge({'_locale': 'fr'})) }}">
    {% endif %}

    {# ── Open Graph ───────────────────────────────────────── #}
    {% set _og_locale     = app.request.locale == 'fr' ? 'fr_FR' : (app.request.locale == 'es' ? 'es_ES' : (app.request.locale == 'pt' ? 'pt_PT' : (app.request.locale == 'de' ? 'de_DE' : (app.request.locale == 'it' ? 'it_IT' : 'en_GB')))) %}
    {% set _og_all_locales = {'fr': 'fr_FR', 'en': 'en_GB', 'es': 'es_ES', 'pt': 'pt_PT', 'de': 'de_DE', 'it': 'it_IT'} %}
    <meta property="og:type"             content="website">
    <meta property="og:url"              content="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
    <meta property="og:title"            content="{% block og_title %}MyBabyGuessr{% endblock %}">
    <meta property="og:description"      content="{% block og_description %}{{ 'home.seo.description'|trans }}{% endblock %}">
    {% block og_image %}
    <meta property="og:image"        content="{{ absolute_url(asset('images/og-image.png')) }}">
    <meta property="og:image:width"  content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt"    content="MyBabyGuessr">
    {% endblock %}
    <meta property="og:locale"           content="{{ _og_locale }}">
    {% for _loc, _og_alt in _og_all_locales %}{% if _loc != app.request.locale %}
    <meta property="og:locale:alternate" content="{{ _og_alt }}">
    {% endif %}{% endfor %}
    <meta property="og:site_name"        content="MyBabyGuessr">

    {# ── Twitter Card ─────────────────────────────────────── #}
    <meta name="twitter:card"        content="{% block twitter_card %}summary{% endblock %}">
    <meta name="twitter:title"       content="{{ block('og_title') }}">
    <meta name="twitter:description" content="{{ block('og_description') }}">
    <meta name="twitter:image"       content="{% block twitter_image %}{{ absolute_url(asset('images/logo-mybabyguessr.png')) }}{% endblock %}">
    <meta name="twitter:site"         content="@MyBabyGuessr">
    <meta name="twitter:domain"       content="mybabyguessr.com">

    {# ── JSON-LD : Organisation (toutes pages) ────────────── #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "MyBabyGuessr",
      "url": "{{ app.request.schemeAndHttpHost }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ absolute_url(asset('images/logo-mybabyguessr.png')) }}",
        "width": 1536,
        "height": 1024
      }
    }
    </script>
    {% block structured_data %}{% endblock %}

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css">

    {# ── Assets ───────────────────────────────────────────── #}
    <style>[x-cloak]{display:none!important}</style>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body class="min-h-screen flex flex-col">

    {# ── Skip link accessibilité ──────────────────────────── #}
    <a class="skip-link" href="#main-content"
       onclick="event.preventDefault();var t=document.getElementById('main-content');if(t){t.focus();t.scrollIntoView()}">
        {{ 'base.skip_to_content'|trans }}
    </a>

    {% include 'partials/_header.html.twig' %}
    {% include 'partials/_flash.html.twig' %}

    {# ── Contenu principal ────────────────────────────────── #}
    <main id="main-content" tabindex="-1" class="flex-1">
        {% block body %}{% endblock %}
    </main>

    {% include 'partials/_footer.html.twig' %}

    {# ── Bannière cookies + GA4 ──────────────────────────── #}
    {% include 'partials/_cookies.html.twig' %}

</body>
</html>
