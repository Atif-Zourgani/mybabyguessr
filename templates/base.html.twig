<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#F8F3EE">

    {# ── Favicon ──────────────────────────────────────────── #}
    <link rel="icon"             href="{{ asset('images/logo-mybabyguessr.png') }}" type="image/png">
    <link rel="apple-touch-icon" href="{{ asset('images/logo-mybabyguessr.png') }}">

    {# ── SEO ──────────────────────────────────────────────── #}
    <title>{% block title %}MyBabyGuessr{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{% if app.request.locale == 'fr' %}Créez votre jeu de pronostics bébé en 2 minutes. Famille et amis devinent le prénom, la date de naissance, le poids et le sexe — sans créer de compte. Partagez juste un lien.{% elseif app.request.locale == 'es' %}Crea tu juego de pronósticos bebé en minutos. Familia y amigos adivinan el nombre, la fecha de nacimiento, el peso y el sexo — sin crear cuenta. Solo comparte un enlace.{% elseif app.request.locale == 'pt' %}Crie o seu jogo de apostas sobre o bebé em minutos. Família e amigos adivinham o nome, a data de nascimento, o peso e o sexo — sem criar conta. Partilhe apenas um link.{% elseif app.request.locale == 'de' %}Erstelle dein Baby-Tippspiel in Minuten. Familie und Freunde tippen auf Name, Geburtsdatum, Gewicht und Geschlecht – ohne Konto. Nur ein Link zum Teilen.{% elseif app.request.locale == 'it' %}Crea il tuo gioco di pronostici sul bebè in pochi minuti. Famiglia e amici indovinano nome, data di nascita, peso e sesso — senza account. Solo un link da condividere.{% else %}Create a free baby guessing game in minutes. Family and friends guess name, due date, weight and gender — no account needed. Just share a link.{% endif %}{% endblock %}">
    <meta name="robots" content="{% block robots %}index, follow{% endblock %}">

    {# ── Canonical & hreflang ─────────────────────────────── #}
    <link rel="canonical" href="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
    {% if app.request.attributes.has('_route') %}
        {% set _route  = app.request.attributes.get('_route') %}
        {% set _params = app.request.attributes.get('_route_params') %}
        <link rel="alternate" hreflang="fr"        href="{{ url(_route, _params|merge({'_locale': 'fr'})) }}">
        <link rel="alternate" hreflang="en"        href="{{ url(_route, _params|merge({'_locale': 'en'})) }}">
        <link rel="alternate" hreflang="es"        href="{{ url(_route, _params|merge({'_locale': 'es'})) }}">
        <link rel="alternate" hreflang="pt"        href="{{ url(_route, _params|merge({'_locale': 'pt'})) }}">
        <link rel="alternate" hreflang="de"        href="{{ url(_route, _params|merge({'_locale': 'de'})) }}">
        <link rel="alternate" hreflang="it"        href="{{ url(_route, _params|merge({'_locale': 'it'})) }}">
        <link rel="alternate" hreflang="x-default" href="{{ url(_route, _params|merge({'_locale': 'fr'})) }}">
    {% endif %}

    {# ── Open Graph ───────────────────────────────────────── #}
    {% set _og_locale     = app.request.locale == 'fr' ? 'fr_FR' : (app.request.locale == 'es' ? 'es_ES' : (app.request.locale == 'pt' ? 'pt_BR' : (app.request.locale == 'de' ? 'de_DE' : (app.request.locale == 'it' ? 'it_IT' : 'en_GB')))) %}
    {% set _og_locale_alt = app.request.locale == 'fr' ? 'en_GB' : 'fr_FR' %}
    <meta property="og:type"             content="website">
    <meta property="og:url"              content="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
    <meta property="og:title"            content="{% block og_title %}MyBabyGuessr{% endblock %}">
    <meta property="og:description"      content="{% block og_description %}{% if app.request.locale == 'fr' %}Créez votre jeu de pronostics bébé en 2 minutes. Famille et amis devinent le prénom, la date de naissance, le poids et le sexe — sans créer de compte. Partagez juste un lien.{% elseif app.request.locale == 'es' %}Crea tu juego de pronósticos bebé en minutos. Familia y amigos adivinan el nombre, la fecha de nacimiento, el peso y el sexo — sin crear cuenta. Solo comparte un enlace.{% elseif app.request.locale == 'pt' %}Crie o seu jogo de apostas sobre o bebé em minutos. Família e amigos adivinham o nome, a data de nascimento, o peso e o sexo — sem criar conta. Partilhe apenas um link.{% elseif app.request.locale == 'de' %}Erstelle dein Baby-Tippspiel in Minuten. Familie und Freunde tippen auf Name, Geburtsdatum, Gewicht und Geschlecht – ohne Konto. Nur ein Link zum Teilen.{% elseif app.request.locale == 'it' %}Crea il tuo gioco di pronostici sul bebè in pochi minuti. Famiglia e amici indovinano nome, data di nascita, peso e sesso — senza account. Solo un link da condividere.{% else %}Create a free baby guessing game in minutes. Family and friends guess name, due date, weight and gender — no account needed. Just share a link.{% endif %}{% endblock %}">
    {% block og_image %}
    <meta property="og:image"        content="{{ absolute_url(asset('images/logo-mybabyguessr.png')) }}">
    <meta property="og:image:width"  content="1024">
    <meta property="og:image:height" content="1024">
    <meta property="og:image:alt"    content="MyBabyGuessr">
    {% endblock %}
    <meta property="og:locale"           content="{{ _og_locale }}">
    <meta property="og:locale:alternate" content="{{ _og_locale_alt }}">
    <meta property="og:site_name"        content="MyBabyGuessr">

    {# ── Twitter Card ─────────────────────────────────────── #}
    <meta name="twitter:card"        content="{% block twitter_card %}summary{% endblock %}">
    <meta name="twitter:title"       content="{{ block('og_title') }}">
    <meta name="twitter:description" content="{{ block('og_description') }}">
    <meta name="twitter:image"       content="{% block twitter_image %}{{ absolute_url(asset('images/logo-mybabyguessr.png')) }}{% endblock %}">

    {# ── JSON-LD : Organisation (toutes pages) ────────────── #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "MyBabyGuessr",
      "url": "{{ app.request.schemeAndHttpHost }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ absolute_url(asset('images/logo-mybabyguessr.png')) }}",
        "width": 1024,
        "height": 1024
      }
    }
    </script>
    {% block structured_data %}{% endblock %}

    {# ── Police Nunito (à auto-héberger avant mise en prod) ── #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css">

    {# ── Assets ───────────────────────────────────────────── #}
    <style>[x-cloak]{display:none!important}</style>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body class="min-h-screen flex flex-col">

    {# ── Skip link accessibilité ──────────────────────────── #}
    <a class="skip-link" href="#main-content">
        {{ app.request.locale == 'fr' ? 'Aller au contenu principal' : (app.request.locale == 'es' ? 'Ir al contenido principal' : (app.request.locale == 'pt' ? 'Ir para o conteúdo principal' : (app.request.locale == 'de' ? 'Zum Hauptinhalt springen' : (app.request.locale == 'it' ? 'Vai al contenuto principale' : 'Skip to main content')))) }}
    </a>

    {% include 'partials/_header.html.twig' %}
    {% include 'partials/_flash.html.twig' %}

    {# ── Contenu principal ────────────────────────────────── #}
    <main id="main-content" tabindex="-1" class="flex-1">
        {% block body %}{% endblock %}
    </main>

    {% include 'partials/_footer.html.twig' %}

</body>
</html>
