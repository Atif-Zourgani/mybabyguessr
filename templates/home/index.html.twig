{% extends 'base.html.twig' %}

{% block title %}{{ 'home.hero.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'home.hero.description'|trans }}{% endblock %}
{% block og_title %}{{ 'home.hero.title'|trans }} — MyBabyGuessr{% endblock %}
{% block og_description %}{{ 'home.hero.description'|trans }}{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "MyBabyGuessr",
  "url": "{{ app.request.schemeAndHttpHost }}",
  "description": "{{ 'home.hero.description'|trans|e('js') }}",
  "inLanguage": "{{ app.request.locale == 'fr' ? 'fr-FR' : 'en-GB' }}"
}
</script>
{% endblock %}

{% block body %}

{# ── Hero ─────────────────────────────────────────────────────── #}
<section aria-labelledby="hero-title" class="bg-cream pt-10 pb-14 sm:pt-16 sm:pb-24 lg:pt-20 lg:pb-32 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto text-center">

        <p class="text-brand font-bold text-sm uppercase tracking-widest mb-5">
            {{ 'home.hero.subtitle'|trans }}
        </p>

        <h1 id="hero-title" class="text-4xl sm:text-5xl lg:text-6xl font-bold text-ink leading-tight mb-6">
            {{ 'home.hero.title'|trans }}
        </h1>

        <p class="text-lg text-muted leading-relaxed mb-10 max-w-2xl mx-auto">
            {{ 'home.hero.description'|trans }}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a href="{{ path('app_register', {'_locale': app.request.locale}) }}"
               class="btn btn-primary w-full sm:w-auto text-lg px-8">
                {{ 'home.hero.cta_register'|trans }}
            </a>
            <a href="{{ path('app_login', {'_locale': app.request.locale}) }}"
               class="btn btn-secondary w-full sm:w-auto text-lg px-8">
                {{ 'home.hero.cta_login'|trans }}
            </a>
        </div>

    </div>
</section>

{# ── Comment ça marche ────────────────────────────────────────── #}
<section aria-labelledby="how-title" class="bg-white py-12 sm:py-20 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">

        <h2 id="how-title" class="text-2xl sm:text-3xl sm:text-4xl text-center mb-10 sm:mb-16">
            {{ 'home.how.title'|trans }}
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

            {% for i in 1..3 %}
            <div class="flex flex-col items-center text-center gap-5">

                <div class="w-14 h-14 rounded-full bg-brand flex items-center justify-center text-white font-bold text-xl shrink-0"
                     aria-hidden="true">
                    {{ i }}
                </div>

                <h3 class="text-xl font-bold text-ink">
                    {{ ('home.how.step' ~ i ~ '_title')|trans }}
                </h3>

                <p class="text-muted leading-relaxed">
                    {{ ('home.how.step' ~ i ~ '_desc')|trans }}
                </p>

            </div>
            {% endfor %}

        </div>
    </div>
</section>

{# ── Features ─────────────────────────────────────────────────── #}
<section aria-labelledby="features-title" class="bg-cream py-12 sm:py-20 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">

        <div class="text-center mb-10 sm:mb-16">
            <h2 id="features-title" class="text-2xl sm:text-3xl sm:text-4xl mb-4">
                {{ 'home.features.title'|trans }}
            </h2>
            <p class="text-muted text-lg">{{ 'home.features.subtitle'|trans }}</p>
        </div>

        <div class="flex flex-wrap justify-center gap-6">

            {# 1 — Pronostics personnalisés #}
            <div class="card flex-none w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
                     style="background-color: rgba(196,113,74,.12);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                         xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
                         stroke="var(--color-brand)" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 11l3 3L22 4"/>
                        <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-ink mb-2">{{ 'home.features.feature1_title'|trans }}</h3>
                <p class="text-muted text-sm leading-relaxed">{{ 'home.features.feature1_desc'|trans }}</p>
            </div>

            {# 2 — Partage en un lien #}
            <div class="card flex-none w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
                     style="background-color: rgba(196,113,74,.12);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                         xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
                         stroke="var(--color-brand)" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="18" cy="5" r="3"/>
                        <circle cx="6" cy="12" r="3"/>
                        <circle cx="18" cy="19" r="3"/>
                        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-ink mb-2">{{ 'home.features.feature2_title'|trans }}</h3>
                <p class="text-muted text-sm leading-relaxed">{{ 'home.features.feature2_desc'|trans }}</p>
            </div>

            {# 3 — Tableau des scores #}
            <div class="card flex-none w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
                     style="background-color: rgba(196,113,74,.12);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                         xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
                         stroke="var(--color-brand)" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10"/>
                        <line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6" y1="20" x2="6" y2="14"/>
                        <line x1="2" y1="20" x2="22" y2="20"/>
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-ink mb-2">{{ 'home.features.feature3_title'|trans }}</h3>
                <p class="text-muted text-sm leading-relaxed">{{ 'home.features.feature3_desc'|trans }}</p>
            </div>

            {# 4 — Bilingue #}
            <div class="card flex-none w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
                     style="background-color: rgba(196,113,74,.12);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                         xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
                         stroke="var(--color-brand)" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="2" y1="12" x2="22" y2="12"/>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-ink mb-2">{{ 'home.features.feature4_title'|trans }}</h3>
                <p class="text-muted text-sm leading-relaxed">{{ 'home.features.feature4_desc'|trans }}</p>
            </div>

            {# 5 — 100% gratuit #}
            <div class="card flex-none w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
                     style="background-color: rgba(196,113,74,.12);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                         xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
                         stroke="var(--color-brand)" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        <polyline points="9 12 11 14 15 10"/>
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-ink mb-2">{{ 'home.features.feature5_title'|trans }}</h3>
                <p class="text-muted text-sm leading-relaxed">{{ 'home.features.feature5_desc'|trans }}</p>
            </div>

        </div>

    </div>
</section>

{# ── CTA final ────────────────────────────────────────────────── #}
<section class="bg-white py-12 sm:py-20 px-4 sm:px-6">
    <div class="max-w-xl mx-auto text-center">

        <h2 class="text-3xl sm:text-4xl mb-6">
            {{ 'home.cta.title'|trans }}
        </h2>

        <p class="text-muted leading-relaxed mb-10">
            {{ 'home.hero.description'|trans }}
        </p>

        <a href="{{ path('app_register', {'_locale': app.request.locale}) }}"
           class="btn btn-primary text-lg px-8">
            {{ 'home.cta.button'|trans }}
        </a>

    </div>
</section>

{% endblock %}
