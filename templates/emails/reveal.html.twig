<!DOCTYPE html>
<html lang="{{ locale }}" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>{{ locale == 'fr' ? 'La révélation est arrivée !' : (locale == 'es' ? '¡La revelación está aquí!' : (locale == 'pt' ? 'A revelação chegou!' : (locale == 'de' ? 'Die Enthüllung ist da!' : 'The reveal is here!'))) }}</title>
    <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;700&display=swap');
        body { margin:0; padding:0; background-color:#F8F3EE; }
        * { box-sizing:border-box; }
        a { color:#C4714A; }
        @media only screen and (max-width:620px) {
            .email-container { width:100% !important; }
            .email-body { padding:32px 24px !important; }
            .email-header { padding:24px !important; }
            .email-footer { padding:20px 24px !important; }
            .btn-cta { display:block !important; }
        }
    </style>
</head>
<body style="margin:0;padding:0;background-color:#F8F3EE;font-family:'Nunito','Helvetica Neue',Arial,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#F8F3EE;">
    <tr>
        <td align="center" style="padding:40px 20px;">

            <table class="email-container" width="600" cellpadding="0" cellspacing="0" role="presentation"
                   style="max-width:600px;width:100%;background-color:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(44,31,21,0.08);">

                {# ── Header / Logo ── #}
                <tr>
                    <td class="email-header" align="center"
                        style="background-color:#F8F3EE;padding:32px 40px;border-bottom:1px solid #D9CFC9;">
                        <img src="{{ absolute_url(asset('images/logo-mybabyguessr.png')) }}"
                             alt="MyBabyGuessr"
                             width="160"
                             style="display:block;margin:0 auto;width:160px;max-width:100%;height:auto;">
                    </td>
                </tr>

                {# ── Bande colorée ── #}
                <tr>
                    <td height="6" style="background-color:#C4714A;font-size:0;line-height:0;">&nbsp;</td>
                </tr>

                {# ── Corps ── #}
                <tr>
                    <td class="email-body" style="padding:48px 40px 32px;">

                        {# Icône étoile #}
                        <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                            <tr>
                                <td align="center" style="padding:0 0 24px;">
                                    <div style="display:inline-flex;align-items:center;justify-content:center;width:64px;height:64px;border-radius:50%;background-color:rgba(196,113,74,0.12);">
                                        <span style="font-size:28px;">&#9733;</span>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        {# Salutation #}
                        <h1 style="margin:0 0 16px;font-size:24px;font-weight:700;color:#2C1F15;line-height:1.3;text-align:center;">
                            {% if locale == 'fr' %}
                                Bonjour {{ playerName }}&nbsp;!
                            {% elseif locale == 'es' %}
                                ¡Hola {{ playerName }}!
                            {% elseif locale == 'pt' %}
                                Olá {{ playerName }}!
                            {% elseif locale == 'de' %}
                                Hallo {{ playerName }}!
                            {% else %}
                                Hello {{ playerName }}!
                            {% endif %}
                        </h1>

                        {# Message #}
                        <p style="margin:0 0 24px;font-size:16px;color:#7A6A5F;line-height:1.6;text-align:center;">
                            {% if locale == 'fr' %}
                                Les vraies réponses du <strong style="color:#2C1F15;">{{ game.displayTitle }}</strong> sont révélées !
                                Découvrez les résultats et voyez qui a deviné juste.
                            {% elseif locale == 'es' %}
                                ¡Las respuestas reales del <strong style="color:#2C1F15;">{{ game.displayTitle }}</strong> están reveladas!
                                Descubre los resultados y ve quién ha acertado.
                            {% elseif locale == 'pt' %}
                                As respostas reais do <strong style="color:#2C1F15;">{{ game.displayTitle }}</strong> foram reveladas!
                                Descubra os resultados e veja quem adivinhou certo.
                            {% elseif locale == 'de' %}
                                Die echten Antworten für <strong style="color:#2C1F15;">{{ game.displayTitle }}</strong> sind da!
                                Entdecke die Ergebnisse und sieh, wer richtig geraten hat.
                            {% else %}
                                The real answers for <strong style="color:#2C1F15;">{{ game.displayTitle }}</strong> are here!
                                Discover the results and see who guessed right.
                            {% endif %}
                        </p>

                        {# Bouton CTA #}
                        <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                            <tr>
                                <td align="center" style="padding:8px 0 32px;">
                                    <a href="{{ revealUrl }}"
                                       class="btn-cta"
                                       style="display:inline-block;background-color:#C4714A;color:#ffffff;font-family:'Nunito','Helvetica Neue',Arial,sans-serif;font-size:16px;font-weight:700;text-decoration:none;padding:14px 36px;border-radius:10px;mso-padding-alt:0;text-align:center;">
                                        <!--[if mso]><i style="letter-spacing:36px;mso-font-width:-100%;mso-text-raise:30pt">&nbsp;</i><![endif]-->
                                        {{ locale == 'fr' ? 'Voir la révélation' : (locale == 'es' ? 'Ver la revelación' : (locale == 'pt' ? 'Ver a revelação' : (locale == 'de' ? 'Enthüllung ansehen' : 'See the reveal'))) }}
                                        <!--[if mso]><i style="letter-spacing:36px;mso-font-width:-100%">&nbsp;</i><![endif]-->
                                    </a>
                                </td>
                            </tr>
                        </table>

                        {# Lien de secours #}
                        <p style="margin:0 0 8px;font-size:13px;color:#7A6A5F;line-height:1.5;">
                            {{ locale == 'fr' ? 'Si le bouton ne fonctionne pas, copiez ce lien dans votre navigateur :' : (locale == 'es' ? 'Si el botón no funciona, copia este enlace en tu navegador:' : (locale == 'pt' ? 'Se o botão não funcionar, copie este link para o seu navegador:' : (locale == 'de' ? 'Falls der Button nicht funktioniert, kopiere diesen Link in deinen Browser:' : 'If the button doesn\'t work, copy this link into your browser:'))) }}
                        </p>
                        <p style="margin:0 0 32px;font-size:12px;word-break:break-all;">
                            <a href="{{ revealUrl }}" style="color:#C4714A;">{{ revealUrl }}</a>
                        </p>

                        {# Séparateur #}
                        <hr style="border:none;border-top:1px solid #D9CFC9;margin:0 0 24px;">

                        {# Disclaimer #}
                        <p style="margin:0;font-size:13px;color:#7A6A5F;line-height:1.5;">
                            {% if locale == 'fr' %}
                                Vous recevez cet email car vous avez participé au Baby Guessr <strong style="color:#2C1F15;">{{ game.displayTitle }}</strong>.
                            {% elseif locale == 'es' %}
                                Recibiste este email porque participaste en el Baby Guessr <strong style="color:#2C1F15;">{{ game.displayTitle }}</strong>.
                            {% elseif locale == 'pt' %}
                                Recebeu este email porque participou no Baby Guessr <strong style="color:#2C1F15;">{{ game.displayTitle }}</strong>.
                            {% elseif locale == 'de' %}
                                Du erhältst diese E-Mail, weil du am Baby Guessr <strong style="color:#2C1F15;">{{ game.displayTitle }}</strong> teilgenommen hast.
                            {% else %}
                                You received this email because you participated in the Baby Guessr <strong style="color:#2C1F15;">{{ game.displayTitle }}</strong>.
                            {% endif %}
                        </p>

                    </td>
                </tr>

                {# ── Footer ── #}
                <tr>
                    <td class="email-footer" align="center"
                        style="background-color:#F8F3EE;padding:24px 40px;border-top:1px solid #D9CFC9;">
                        <p style="margin:0 0 6px;font-size:13px;color:#7A6A5F;">
                            © {{ "now"|date("Y") }} MyBabyGuessr — Devine. Partage. Révèle.
                        </p>
                        <p style="margin:0;font-size:12px;color:#7A6A5F;">
                            <a href="https://mybabyguessr.com" style="color:#C4714A;text-decoration:none;">mybabyguessr.com</a>
                        </p>
                    </td>
                </tr>

            </table>

        </td>
    </tr>
</table>

</body>
</html>
