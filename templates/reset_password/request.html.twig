{% extends 'base.html.twig' %}

{% block title %}{{ 'reset.request.title'|trans }}{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
<section class="flex items-center justify-center min-h-[calc(100vh-10rem)] px-4 py-6 sm:py-12">
    <div class="card w-full max-w-md">

        <div class="flex justify-center mb-6">
            <img src="{{ asset('images/logo-mybabyguessr.png') }}"
                 alt="MyBabyGuessr"
                 width="1024" height="1024"
                 fetchpriority="high"
                 class="h-20 w-auto">
        </div>

        <h1 class="text-2xl mb-2">{{ 'reset.request.title'|trans }}</h1>
        <p class="text-sm text-muted mb-8">{{ 'reset.request.hint'|trans }}</p>

        {{ form_start(requestForm) }}
            {{ form_row(requestForm.email, {label: 'login.email'|trans}) }}
            <button type="submit" class="btn btn-primary w-full mt-2">
                {{ 'reset.request.submit'|trans }}
            </button>
        {{ form_end(requestForm) }}

        <p class="text-center text-sm text-muted mt-6">
            <a href="{{ path('app_login', {'_locale': app.request.locale}) }}">
                &larr; {{ 'login.title'|trans }}
            </a>
        </p>

    </div>
</section>
{% endblock %}
