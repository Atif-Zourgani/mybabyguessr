{% extends 'base.html.twig' %}

{% block title %}{{ 'reset.new_password.title'|trans }}{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
<section class="flex items-center justify-center min-h-[calc(100vh-10rem)] px-4 py-12">
    <div class="card w-full max-w-md">

        <div class="flex justify-center mb-6">
            <img src="{{ asset('images/logo-mybabyguessr.png') }}"
                 alt="MyBabyGuessr"
                 width="1024" height="1024"
                 fetchpriority="high"
                 class="h-20 w-auto">
        </div>

        <h1 class="text-2xl mb-8">{{ 'reset.new_password.title'|trans }}</h1>

        {{ form_start(resetForm) }}
            {{ form_row(resetForm.plainPassword) }}
            <button type="submit" class="btn btn-primary w-full mt-2">
                {{ 'reset.new_password.submit'|trans }}
            </button>
        {{ form_end(resetForm) }}

    </div>
</section>
{% endblock %}
