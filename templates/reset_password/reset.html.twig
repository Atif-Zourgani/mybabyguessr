{% extends 'base.html.twig' %}

{% block title %}{{ 'reset.new_password.title'|trans }} — MyBabyGuessr{% endblock %}

{% block body %}
    <h1>{{ 'reset.new_password.title'|trans }}</h1>

    {{ form_start(resetForm) }}
        {{ form_row(resetForm.plainPassword, { label: 'reset.new_password.label'|trans }) }}
        <button type="submit">{{ 'reset.new_password.submit'|trans }}</button>
    {{ form_end(resetForm) }}
{% endblock %}
