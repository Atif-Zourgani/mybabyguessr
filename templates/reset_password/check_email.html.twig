{% extends 'base.html.twig' %}

{% block title %}{{ 'reset.check_email.title'|trans }}{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
<section class="flex items-center justify-center min-h-[calc(100vh-10rem)] px-4 py-12">
    <div class="card w-full max-w-md text-center">

        <div class="flex justify-center mb-6">
            <img src="{{ asset('images/logo-mybabyguessr.png') }}"
                 alt="MyBabyGuessr"
                 width="1024" height="1024"
                 fetchpriority="high"
                 class="h-20 w-auto">
        </div>

        <div class="flex justify-center mb-6">
            <div class="flex items-center justify-center w-14 h-14 rounded-2xl"
                 style="background-color: rgba(196,113,74,.12);">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                     xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
                     stroke="var(--color-brand)" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
            </div>
        </div>

        <h1 class="text-2xl mb-4">{{ 'reset.check_email.title'|trans }}</h1>
        <p class="text-muted mb-6">
            {{ 'reset.check_email.message'|trans({
                '%delay%': resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle')
            }) }}
        </p>
        <p class="text-sm text-muted">
            {{ 'reset.check_email.no_email'|trans }}
            <a href="{{ path('app_forgot_password_request', {'_locale': app.request.locale}) }}">
                {{ 'reset.check_email.try_again'|trans }}
            </a>
        </p>

    </div>
</section>
{% endblock %}
