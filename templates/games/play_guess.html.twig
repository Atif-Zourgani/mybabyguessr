{% extends 'base.html.twig' %}

{% block title %}{{ game.displayTitle }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 sm:px-6 py-12 text-center">
    <p class="text-2xl font-bold mb-2" style="color: var(--color-ink)">
        {{ player.name }}
    </p>
    <p style="color: var(--color-muted)">
        {{ game.displayTitle }} — formulaire de jeu à venir
    </p>
</div>
{% endblock %}
