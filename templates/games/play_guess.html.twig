{% extends 'base.html.twig' %}
{% block title %}{{ 'play.guess.title'|trans }} — {{ game.displayTitle }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}
{% block meta_description %}{{ 'play.identify.welcome_desc'|trans({'%name%': game.user.firstName}) }}{% endblock %}

{% set steps = [] %}
{% if game.guessGender %}{% set steps = steps|merge(['gender']) %}{% endif %}
{% if game.guessName   %}{% set steps = steps|merge(['name'])   %}{% endif %}
{% if game.guessDate   %}{% set steps = steps|merge(['date'])   %}{% endif %}
{% if game.guessWeight %}{% set steps = steps|merge(['weight']) %}{% endif %}
{% if game.guessHeight %}{% set steps = steps|merge(['height']) %}{% endif %}

{% set _g = formData.gender ?? '' %}
{% set genderValue = _g in ['boy', 'girl'] ? _g : '' %}

{% block stylesheets %}
<style>
.ply-deco { position:absolute; pointer-events:none; z-index:2; }
.ply-tr   { top:12px;    right:8px;  width:38px; opacity:0.78; }
.ply-br   { bottom:10px; right:8px;  width:74px; opacity:0.88; }
.ply-bl   { bottom:10px; left:8px;   width:70px; opacity:0.84; }
.ply-lg   { width:57px; }
@media (min-width:640px) {
    .ply-tr { top:20px;    left:calc(50% + 230px); width:48px; }
    .ply-br { bottom:16px; left:calc(50% + 226px); width:92px; }
    .ply-bl { bottom:16px; right:calc(50% + 226px); width:86px; }
    .ply-lg { width:72px; }
}
</style>
{% endblock %}

{% block body %}
{% set isHintsMode = game.guessName and game.nameMode and game.nameMode.value == 'hints' %}
{% set hs = hintsState %}
<div class="px-4 py-10 sm:py-16" style="position:relative"
     x-data="{
       showIntro: true,
       steps: {{ steps|json_encode }},
       current: 0,
       gender: '{{ genderValue }}',
       stepError: false,
       errors: {{ errors|json_encode }},
       isHintsMode: {{ isHintsMode ? 'true' : 'false' }},
       hintsStep: {{ hs.step }},
       hintsProposals: {{ hs.proposals|json_encode }},
       hintsClues: {{ hs.clues|json_encode }},
       hintsCurrentInput: '',
       hintsLoading: false,
       hintsCompleted: {{ hs.completed ? 'true' : 'false' }},
       hintUrls: [
         null,
         '{{ path('app_game_hint', {'_locale': app.request.locale, 'slug': game.slug, 'token': game.token, 'attempt': 1}) }}',
         '{{ path('app_game_hint', {'_locale': app.request.locale, 'slug': game.slug, 'token': game.token, 'attempt': 2}) }}',
         '{{ path('app_game_hint', {'_locale': app.request.locale, 'slug': game.slug, 'token': game.token, 'attempt': 3}) }}'
       ],
       get totalSteps() { return this.steps.length; },
       get currentStep() { return this.steps[this.current]; },
       get isLast() { return this.current === this.totalSteps - 1; },
       init() {
         const errKeys = Object.keys(this.errors);
         if (errKeys.length > 0) {
           this.showIntro = false;
           const idx = this.steps.findIndex(s => errKeys.includes(s));
           if (idx !== -1) { this.current = idx; this.stepError = true; }
         }
       },
       validate() {
         const s = this.currentStep;
         if (s === 'gender') return this.gender !== '';
         if (s === 'name') {
           if (this.isHintsMode) return this.hintsCompleted;
           return (document.getElementById('guess_name')?.value ?? '').trim().length > 0;
         }
         if (s === 'date')   return (document.getElementById('guess_date')?.value ?? '').length > 0;
         if (s === 'weight') { const w = parseFloat((document.getElementById('guess_weight')?.value ?? '').replace(',','.')); return !isNaN(w) && w >= 0.5 && w <= 7; }
         if (s === 'height') { const h = parseFloat((document.getElementById('guess_height')?.value ?? '').replace(',','.')); return !isNaN(h) && h >= 20 && h <= 70; }
         return true;
       },
       next() { if (!this.validate()) { this.stepError = true; return; } this.stepError = false; if (this.current < this.totalSteps - 1) this.current++; },
       prev() { this.stepError = false; if (this.current > 0) this.current--; },
       async submitHint() {
         const name = this.hintsCurrentInput.trim();
         if (!name || this.hintsLoading) return;
         this.hintsLoading = true;
         try {
           const fd = new FormData();
           fd.append('name', name);
           const res = await fetch(this.hintUrls[this.hintsStep], { method: 'POST', body: fd });
           if (!res.ok) throw new Error('HTTP ' + res.status);
           const data = await res.json();
           this.hintsProposals.push(name);
           this.hintsCurrentInput = '';
           if (this.hintsStep >= 3) {
             this.hintsCompleted = true;
           } else {
             this.hintsClues.push(data.clue);
             this.hintsStep++;
           }
         } catch(e) { console.error('hint error', e); }
         finally { this.hintsLoading = false; }
       }
     }">

    {# ── Illustrations par étape ──────────────────────────────── #}

    {# Intro : girafe + papillon #}
    <img src="{{ asset('images/illustration/girafe.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-br"
         x-show="showIntro"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">
    <img src="{{ asset('images/illustration/papillon1.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-tr ply-lg"
         x-show="showIntro"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

    {# Sexe : lion #}
    <img src="{{ asset('images/illustration/lion.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-br"
         x-show="!showIntro && currentStep === 'gender'"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

    {# Prénom libre : papillon #}
    <img src="{{ asset('images/illustration/papillon2.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-tr ply-lg"
         x-show="!showIntro && currentStep === 'name' && !isHintsMode"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

    {# Hints essai 1 : éléphant #}
    <img src="{{ asset('images/illustration/elephant.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-br"
         x-show="!showIntro && currentStep === 'name' && isHintsMode && !hintsCompleted && hintsStep === 1"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

    {# Hints essai 2 : singe #}
    <img src="{{ asset('images/illustration/singe.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-br"
         x-show="!showIntro && currentStep === 'name' && isHintsMode && !hintsCompleted && hintsStep === 2"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

    {# Hints essai 3 : papillon #}
    <img src="{{ asset('images/illustration/papillon3.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-tr ply-lg"
         x-show="!showIntro && currentStep === 'name' && isHintsMode && !hintsCompleted && hintsStep === 3"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

    {# Hints complété : soleil #}
    <img src="{{ asset('images/illustration/soleil.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-tr"
         x-show="!showIntro && currentStep === 'name' && isHintsMode && hintsCompleted"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

    {# Date : feuille #}
    <img src="{{ asset('images/illustration/feuille_orange.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-tr"
         style="transform:rotate(25deg)"
         x-show="!showIntro && currentStep === 'date'"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

    {# Poids : soleil #}
    <img src="{{ asset('images/illustration/soleil.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-tr"
         x-show="!showIntro && currentStep === 'weight'"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

    {# Taille : étoile #}
    <img src="{{ asset('images/illustration/etoile.png') }}" alt="" aria-hidden="true"
         class="ply-deco ply-tr ply-lg"
         x-show="!showIntro && currentStep === 'height'"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

<div class="max-w-md mx-auto" style="position:relative;z-index:1">

    {# ══════════════════════════════════════════════════════════ #}
    {# ── Écran d'intro ──────────────────────────────────────── #}
    {# ══════════════════════════════════════════════════════════ #}
    <div x-show="showIntro"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">

        {# Image ou logo #}
        <div class="flex justify-center mb-6">
            {% if game.image %}
            <img src="{{ asset(game.image) }}" alt="{{ game.displayTitle }}"
                 width="96" height="96" fetchpriority="high"
                 class="w-24 h-24 rounded-2xl object-cover">
            {% else %}
            <img src="{{ asset('images/logo-mybabyguessr.png') }}" alt="MyBabyGuessr"
                 width="1024" height="1024" fetchpriority="high"
                 class="h-16 w-auto">
            {% endif %}
        </div>

        {# Heading + desc #}
        <div class="text-center mb-7">
            <h1 class="text-3xl font-bold mb-3" style="color:var(--color-ink)">
                {{ 'play.intro.heading'|trans }}
            </h1>
            <p class="text-sm leading-relaxed" style="color:var(--color-muted)">
                {{ 'play.intro.desc'|trans({'%name%': game.user.firstName}) }}
            </p>
        </div>

        {# Séparateur #}
        <div class="mb-5" style="border-top:1px solid var(--color-line)"></div>

        {# Catégories #}
        <p class="text-xs font-bold uppercase tracking-wider text-center mb-3"
           style="color:var(--color-muted)">
            {{ 'play.intro.categories_label'|trans }}
        </p>
        <div class="flex flex-wrap justify-center gap-2 mb-6">
            {% if game.guessGender %}
            <span class="px-3 py-1.5 rounded-full text-sm font-semibold"
                  style="background-color:rgba(196,113,74,0.12);color:var(--color-brand)">
                {{ 'games.pill.gender'|trans }}
            </span>
            {% endif %}
            {% if game.guessName %}
            <span class="px-3 py-1.5 rounded-full text-sm font-semibold"
                  style="background-color:rgba(196,113,74,0.12);color:var(--color-brand)">
                {{ 'games.pill.name'|trans }}
            </span>
            {% endif %}
            {% if game.guessDate %}
            <span class="px-3 py-1.5 rounded-full text-sm font-semibold"
                  style="background-color:rgba(196,113,74,0.12);color:var(--color-brand)">
                {{ 'games.pill.date'|trans }}
            </span>
            {% endif %}
            {% if game.guessWeight %}
            <span class="px-3 py-1.5 rounded-full text-sm font-semibold"
                  style="background-color:rgba(196,113,74,0.12);color:var(--color-brand)">
                {{ 'games.pill.weight'|trans }}
            </span>
            {% endif %}
            {% if game.guessHeight %}
            <span class="px-3 py-1.5 rounded-full text-sm font-semibold"
                  style="background-color:rgba(196,113,74,0.12);color:var(--color-brand)">
                {{ 'games.pill.height'|trans }}
            </span>
            {% endif %}
        </div>

        {# Date prévue (si dispo) #}
        {% if game.dueDate %}
        <p class="text-sm text-center mb-6" style="color:var(--color-muted)">
            {{ 'play.intro.due_date'|trans({'%date%': game.dueDate|date('d/m/Y')}) }}
        </p>
        {% endif %}

        {# CTA #}
        <button type="button" @click="showIntro = false"
                class="btn btn-primary w-full">
            {{ 'play.intro.cta'|trans }} →
        </button>

    </div>

    {# ══════════════════════════════════════════════════════════ #}
    {# ── Wizard ─────────────────────────────────────────────── #}
    {# ══════════════════════════════════════════════════════════ #}
    <div x-show="!showIntro"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100">

        {# En-tête compact #}
        <div class="text-center mb-8">
            {% if game.image %}
            <img src="{{ asset(game.image) }}" alt="{{ game.displayTitle }}"
                 width="64" height="64" loading="lazy"
                 class="w-16 h-16 rounded-2xl object-cover mx-auto mb-3">
            {% else %}
            <img src="{{ asset('images/logo-mybabyguessr.png') }}" alt="MyBabyGuessr"
                 width="1024" height="1024" loading="lazy"
                 class="h-10 w-auto mx-auto mb-3">
            {% endif %}
            <h1 class="text-xl font-bold" style="color:var(--color-ink)">{{ game.displayTitle }}</h1>
            <p class="text-sm font-bold mt-1" style="color:var(--color-brand)">
                {{ 'play.guess.hello'|trans({'%name%': player.name}) }}
            </p>
        </div>

        {# Progression #}
        <div class="flex justify-center items-center gap-2 mb-10">
            <template x-for="(step, idx) in steps" :key="idx">
                <div class="h-2 rounded-full transition-all duration-300"
                     :class="idx === current ? 'w-6' : 'w-2'"
                     :style="idx <= current
                         ? 'background-color:var(--color-brand)'
                         : 'background-color:var(--color-line)'">
                </div>
            </template>
        </div>

        {# Formulaire #}
        <form method="post" novalidate
              @submit="if (!validate()) { $event.preventDefault(); stepError = true; }">
            <input type="hidden" name="_token" value="{{ csrf_token('play_guess') }}">
            {% if game.guessGender %}
            <input type="hidden" name="guess_gender" :value="gender">
            {% endif %}

            {# ── Sexe ──────────────────────────────────────────── #}
            {% if game.guessGender %}
            <div x-show="currentStep === 'gender'"
                 x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100">
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-bold mb-2" style="color:var(--color-ink)">
                        {{ 'play.guess.gender_title'|trans }}
                    </h2>
                    <p class="text-sm" style="color:var(--color-muted)">
                        {{ 'play.guess.gender_subtitle'|trans }}
                    </p>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <button type="button" @click="gender = 'boy'; stepError = false"
                            class="rounded-2xl py-10 flex flex-col items-center gap-3 border-2 transition-all duration-200"
                            :style="gender === 'boy'
                                ? 'border-color:var(--color-brand);background-color:rgba(196,113,74,0.10);color:var(--color-brand)'
                                : 'border-color:var(--color-line);background-color:#fff;color:var(--color-ink)'">
                        <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="10" cy="14" r="5"/>
                            <line x1="13.8" y1="10.2" x2="19" y2="5"/>
                            <polyline points="14 5 19 5 19 10"/>
                        </svg>
                        <span class="font-bold text-base">{{ 'play.guess.gender_boy'|trans }}</span>
                    </button>
                    <button type="button" @click="gender = 'girl'; stepError = false"
                            class="rounded-2xl py-10 flex flex-col items-center gap-3 border-2 transition-all duration-200"
                            :style="gender === 'girl'
                                ? 'border-color:var(--color-brand);background-color:rgba(196,113,74,0.10);color:var(--color-brand)'
                                : 'border-color:var(--color-line);background-color:#fff;color:var(--color-ink)'">
                        <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="9" r="5"/>
                            <line x1="12" y1="14" x2="12" y2="20"/>
                            <line x1="9" y1="17" x2="15" y2="17"/>
                        </svg>
                        <span class="font-bold text-base">{{ 'play.guess.gender_girl'|trans }}</span>
                    </button>
                </div>
                <p x-show="stepError" class="mt-3 text-sm text-center text-red-600" role="alert">
                    {{ 'play.guess.gender_error'|trans }}
                </p>
            </div>
            {% endif %}

            {# ── Prénom ────────────────────────────────────────── #}
            {% if game.guessName %}
            <div x-show="currentStep === 'name'"
                 x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100">

                {% if isHintsMode %}

                {# ── Mode hints — 3 essais avec indices ───────── #}
                <div class="text-center mb-6">
                    <h2 class="text-2xl font-bold mb-2" style="color:var(--color-ink)">
                        {{ 'play.guess.hints_title'|trans }}
                    </h2>
                    <p class="text-sm" style="color:var(--color-muted)">
                        {{ 'play.guess.hints_intro'|trans }}
                    </p>
                </div>

                {# Progression 3 points #}
                <div class="flex justify-center items-center gap-2 mb-6">
                    <template x-for="i in [1,2,3]" :key="i">
                        <div class="h-2 rounded-full transition-all duration-300"
                             :class="hintsCompleted || i < hintsStep ? 'w-2' : (i === hintsStep ? 'w-6' : 'w-2')"
                             :style="(hintsCompleted || i <= hintsStep) ? 'background:var(--color-brand)' : 'background:var(--color-line)'">
                        </div>
                    </template>
                </div>

                {# Historique des indices + propositions précédentes #}
                <template x-for="(clue, idx) in hintsClues.slice(0, hintsCompleted ? hintsClues.length : hintsStep - 1)" :key="idx">
                    <div class="mb-3 rounded-xl px-4 py-3" style="background:rgba(196,113,74,0.07)">
                        <div class="flex items-start justify-between gap-3">
                            <div class="flex-1">
                                <p class="text-xs font-bold uppercase tracking-wider mb-0.5" style="color:var(--color-muted)">
                                    {{ 'play.guess.hints_clue_label'|trans({'%n%': '?'}) | replace({'?': ''}) }}<span x-text="idx + 1"></span>/3
                                </p>
                                <p class="text-sm font-semibold" style="color:var(--color-ink)" x-text="clue"></p>
                            </div>
                            <template x-if="hintsProposals[idx]">
                                <div class="shrink-0 text-right">
                                    <p class="text-xs" style="color:var(--color-muted)">{{ 'play.guess.hints_your_proposal'|trans }}</p>
                                    <p class="text-sm font-bold" style="color:var(--color-brand)" x-text="hintsProposals[idx]"></p>
                                </div>
                            </template>
                        </div>
                    </div>
                </template>

                {# Indice actif (non complété) #}
                <template x-if="!hintsCompleted && hintsClues[hintsStep - 1]">
                    <div class="mb-5 rounded-xl px-4 py-3 border-2" style="border-color:var(--color-brand);background:rgba(196,113,74,0.04)">
                        <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color:var(--color-brand)">
                            {{ 'play.guess.hints_clue_label'|trans({'%n%': '?'}) | replace({'?': ''}) }}<span x-text="hintsStep"></span>/3
                        </p>
                        <p class="text-sm font-semibold" style="color:var(--color-ink)" x-text="hintsClues[hintsStep - 1]"></p>
                    </div>
                </template>

                {# Zone de saisie (tant que non complété) #}
                <div x-show="!hintsCompleted">
                    <div class="flex gap-2">
                        <input type="text"
                               x-model="hintsCurrentInput"
                               class="form-input flex-1"
                               placeholder="{{ 'play.guess.hints_input_placeholder'|trans }}"
                               maxlength="100"
                               autocomplete="off"
                               @keydown.enter.prevent="submitHint()">
                        <button type="button"
                                @click="submitHint()"
                                class="btn btn-primary shrink-0"
                                :disabled="hintsLoading || !hintsCurrentInput.trim().length">
                            <span x-show="!hintsLoading">{{ 'play.guess.hints_submit'|trans }}</span>
                            <span x-show="hintsLoading">
                                <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                                </svg>
                            </span>
                        </button>
                    </div>
                    <p class="text-xs text-center mt-2" style="color:var(--color-muted)">
                        {{ 'play.guess.try_label'|trans }} <span x-text="hintsStep"></span>/3
                    </p>
                </div>

                {# Message de fin #}
                <div x-show="hintsCompleted" class="text-center py-4 rounded-xl" style="background:rgba(196,113,74,0.08)">
                    <p class="text-base font-semibold" style="color:var(--color-brand)">
                        {{ 'play.guess.hints_completed'|trans }}
                    </p>
                </div>

                <p x-show="stepError && isHintsMode" class="mt-3 text-sm text-center text-red-600" role="alert">
                    {{ 'play.guess.hints_error'|trans }}
                </p>

                {% else %}

                {# ── Mode free — saisie libre ──────────────────── #}
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-bold mb-2" style="color:var(--color-ink)">
                        {{ 'play.guess.name_title'|trans }}
                    </h2>
                    <p class="text-sm" style="color:var(--color-muted)">
                        {{ 'play.guess.name_subtitle'|trans }}
                    </p>
                </div>
                <input type="text" id="guess_name" name="guess_name"
                       class="form-input"
                       value="{{ formData.name ?? '' }}"
                       placeholder="{{ 'play.guess.name_placeholder'|trans }}"
                       maxlength="100" autocomplete="off"
                       {% if errors.name is defined %}style="border-color:#ef4444"{% endif %}>
                <p x-show="stepError" class="mt-2 text-sm text-center text-red-600" role="alert">
                    {{ 'play.guess.name_error'|trans }}
                </p>

                {% endif %}

            </div>
            {% endif %}

            {# ── Date ──────────────────────────────────────────── #}
            {% if game.guessDate %}
            <div x-show="currentStep === 'date'"
                 x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100">
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-bold mb-2" style="color:var(--color-ink)">
                        {{ 'play.guess.date_title'|trans }}
                    </h2>
                    <p class="text-sm" style="color:var(--color-muted)">
                        {% if game.dueDate %}
                            {{ 'play.guess.due_date_hint'|trans({'%date%': game.dueDate|date('d/m/Y')}) }}
                        {% else %}
                            {{ 'play.guess.date_subtitle'|trans }}
                        {% endif %}
                    </p>
                </div>
                <input type="date" id="guess_date" name="guess_date"
                       class="form-input"
                       value="{{ formData.date ?? (game.dueDate ? game.dueDate|date('Y-m-d') : '') }}"
                       {% if errors.date is defined %}style="border-color:#ef4444"{% endif %}>
                <label class="block text-sm font-semibold mt-4 mb-1" style="color:var(--color-ink)">
                    {{ 'play.guess.time_label'|trans }}
                </label>
                <input type="time" id="guess_time" name="guess_time"
                       class="form-input"
                       value="{{ formData.time ?? '' }}">
                <p class="text-xs mt-1" style="color:var(--color-muted)">
                    {{ 'play.guess.time_optional'|trans }}
                </p>
                <p x-show="stepError" class="mt-2 text-sm text-center text-red-600" role="alert">
                    {{ 'play.guess.date_error'|trans }}
                </p>
            </div>
            {% endif %}

            {# ── Poids ─────────────────────────────────────────── #}
            {% if game.guessWeight %}
            <div x-show="currentStep === 'weight'"
                 x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100">
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-bold mb-2" style="color:var(--color-ink)">
                        {{ 'play.guess.weight_title'|trans }}
                        <span class="text-base font-normal" style="color:var(--color-muted)">
                            ({{ 'play.guess.weight_unit'|trans }})
                        </span>
                    </h2>
                    <p class="text-sm" style="color:var(--color-muted)">
                        {{ 'play.guess.weight_subtitle'|trans }}
                    </p>
                </div>
                <input type="number" id="guess_weight" name="guess_weight"
                       class="form-input text-center text-xl"
                       value="{{ formData.weight ?? '' }}"
                       placeholder="{{ 'play.guess.weight_placeholder'|trans }}"
                       step="0.001" min="0.5" max="7"
                       {% if errors.weight is defined %}style="border-color:#ef4444"{% endif %}>
                <p x-show="stepError" class="mt-2 text-sm text-center text-red-600" role="alert">
                    {{ 'play.guess.weight_error'|trans }}
                </p>
            </div>
            {% endif %}

            {# ── Taille ────────────────────────────────────────── #}
            {% if game.guessHeight %}
            <div x-show="currentStep === 'height'"
                 x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100">
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-bold mb-2" style="color:var(--color-ink)">
                        {{ 'play.guess.height_title'|trans }}
                        <span class="text-base font-normal" style="color:var(--color-muted)">
                            ({{ 'play.guess.height_unit'|trans }})
                        </span>
                    </h2>
                    <p class="text-sm" style="color:var(--color-muted)">
                        {{ 'play.guess.height_subtitle'|trans }}
                    </p>
                </div>
                <input type="number" id="guess_height" name="guess_height"
                       class="form-input text-center text-xl"
                       value="{{ formData.height ?? '' }}"
                       placeholder="{{ 'play.guess.height_placeholder'|trans }}"
                       step="1" min="20" max="70"
                       {% if errors.height is defined %}style="border-color:#ef4444"{% endif %}>
                <p x-show="stepError" class="mt-2 text-sm text-center text-red-600" role="alert">
                    {{ 'play.guess.height_error'|trans }}
                </p>
            </div>
            {% endif %}

            {# ── Navigation ────────────────────────────────────── #}
            <div class="flex gap-3 mt-10">
                <button type="button" @click="prev()"
                        x-show="current > 0"
                        class="btn btn-secondary flex-1">
                    ← {{ 'games.new.btn_prev'|trans }}
                </button>
                <button type="button" @click="next()"
                        x-show="!isLast && !(isHintsMode && currentStep === 'name' && !hintsCompleted)"
                        :class="current > 0 ? 'btn btn-primary flex-1' : 'btn btn-primary w-full'">
                    {{ 'games.new.btn_next'|trans }} →
                </button>
                <button type="submit"
                        x-show="isLast && !(isHintsMode && currentStep === 'name' && !hintsCompleted)"
                        :class="current > 0 ? 'btn btn-primary flex-1' : 'btn btn-primary w-full'">
                    {{ 'play.guess.submit'|trans }}
                </button>
            </div>

        </form>
    </div>

</div>
</div>
{% endblock %}
