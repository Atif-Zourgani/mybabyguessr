{% extends 'base.html.twig' %}

{% block title %}{{ 'games.new.title'|trans }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block stylesheets %}
<style>
.deco-new { position:absolute; pointer-events:none; z-index:2; }
.deco-new-liontete  { top:-2px; right:8px;  width:52px; opacity:0.80; }
.deco-new-papillon  { top:20px; left:10px;  width:42px; opacity:0.74; }
@media (min-width:640px) {
    .deco-new-liontete { top:-4px; left:calc(50% + 232px); width:62px; }
    .deco-new-papillon { top:24px; left:calc(50% - 318px); width:51px; }
}
</style>
{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 sm:px-6 py-8 sm:py-12" style="position:relative;overflow:hidden">

    <img src="{{ asset('images/illustration/lion_tete.png') }}" alt="" aria-hidden="true" class="deco-new deco-new-liontete">
    <img src="{{ asset('images/illustration/papillon3.png') }}" alt="" aria-hidden="true" class="deco-new deco-new-papillon">

    <a href="{{ path('app_dashboard', {'_locale': app.request.locale}) }}"
       class="inline-flex items-center gap-1 text-sm font-bold hover:text-brand mb-8"
       style="color: var(--color-muted); text-decoration:none">
        &larr; {{ 'games.new.back'|trans }}
    </a>

    <div x-data="gameForm"
         data-error-category="{{ 'games.new.error_category'|trans|e('html_attr') }}"
         data-error-name-mode="{{ 'games.new.error_name_mode'|trans|e('html_attr') }}"
         data-error-name-required="{{ 'games.new.error_name_required'|trans|e('html_attr') }}"
         data-error-image-type="{{ 'games.new.error_image_type'|trans|e('html_attr') }}"
         data-error-image-size="{{ 'games.new.error_image_size'|trans|e('html_attr') }}">

        {# ── Indicateur de progression ────────────────────────── #}
        <div class="flex items-center justify-between mb-6">
            <span class="text-sm font-bold"
                  style="color: var(--color-muted)"
                  x-text="'{{ 'games.new.step_label'|trans|e('js') }} ' + stepNumber + ' / ' + totalSteps">
            </span>
            <div class="flex items-center gap-2">
                <template x-for="(s, i) in stepSequence" :key="s">
                    <div class="h-2.5 rounded-full transition-all duration-300"
                         :style="`width: ${i === stepIndex ? '2rem' : '0.625rem'}; background-color: ${i <= stepIndex ? 'var(--color-brand)' : 'var(--color-line)'}`">
                    </div>
                </template>
            </div>
        </div>

        <form method="post" enctype="multipart/form-data" novalidate @submit="submitting = true">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('game_new') }}">

            {# Hidden inputs — carry Alpine boolean/enum state on submit #}
            <input type="hidden" name="guessGender" :value="guessGender ? '1' : '0'">
            <input type="hidden" name="guessName"   :value="guessName   ? '1' : '0'">
            <input type="hidden" name="guessDate"   :value="guessDate   ? '1' : '0'">
            <input type="hidden" name="guessWeight" :value="guessWeight ? '1' : '0'">
            <input type="hidden" name="guessHeight" :value="guessHeight ? '1' : '0'">
            <input type="hidden" name="nameMode"    :value="nameMode">

            {# ══════════════════════════════════════════════════ #}
            {# ÉTAPE 1 — Catégories                              #}
            {# ══════════════════════════════════════════════════ #}
            <div x-show="step === 'categories'" class="card">
                <h1 class="text-2xl mb-1">{{ 'games.new.step1.title'|trans }}</h1>
                <p class="mb-6" style="color: var(--color-muted)">{{ 'games.new.step1.subtitle'|trans }}</p>

                <div class="flex flex-col gap-3">

                    {# Gender #}
                    <button type="button"
                            @click="toggleCategory('guessGender')"
                            :aria-pressed="guessGender ? 'true' : 'false'"
                            class="w-full flex items-center gap-4 p-4 rounded-xl border-2 transition-all text-left cursor-pointer"
                            :style="guessGender
                                ? 'border-color: var(--color-brand); background-color: rgba(196,113,74,0.06)'
                                : 'border-color: var(--color-line); background-color: #fff'">
                        <div class="shrink-0 w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all"
                             :style="guessGender ? 'border-color: var(--color-brand); background-color: var(--color-brand)' : 'border-color: var(--color-line)'">
                            <svg x-show="guessGender" class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                                <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="shrink-0 w-11 h-11 rounded-xl flex items-center justify-center" style="background-color: rgba(196,113,74,0.12)">
                            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-brand)" aria-hidden="true">
                                <circle cx="10" cy="14" r="5"/>
                                <line x1="10" y1="9" x2="10" y2="3"/>
                                <polyline points="7 6 10 3 13 6"/>
                                <line x1="20" y1="3" x2="15" y2="8"/>
                                <polyline points="15 3 20 3 20 8"/>
                            </svg>
                        </div>
                        <div>
                            <div class="font-bold" style="color: var(--color-ink)">{{ 'games.new.step1.gender_title'|trans }}</div>
                            <div class="text-sm" style="color: var(--color-muted)">{{ 'games.new.step1.gender_desc'|trans }}</div>
                        </div>
                    </button>

                    {# Name #}
                    <button type="button"
                            @click="toggleCategory('guessName')"
                            :aria-pressed="guessName ? 'true' : 'false'"
                            class="w-full flex items-center gap-4 p-4 rounded-xl border-2 transition-all text-left cursor-pointer"
                            :style="guessName
                                ? 'border-color: var(--color-brand); background-color: rgba(196,113,74,0.06)'
                                : 'border-color: var(--color-line); background-color: #fff'">
                        <div class="shrink-0 w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all"
                             :style="guessName ? 'border-color: var(--color-brand); background-color: var(--color-brand)' : 'border-color: var(--color-line)'">
                            <svg x-show="guessName" class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                                <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="shrink-0 w-11 h-11 rounded-xl flex items-center justify-center" style="background-color: rgba(196,113,74,0.12)">
                            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-brand)" aria-hidden="true">
                                <path d="M4 20l7-16 7 16"/>
                                <line x1="6.5" y1="14" x2="17.5" y2="14"/>
                            </svg>
                        </div>
                        <div>
                            <div class="font-bold" style="color: var(--color-ink)">{{ 'games.new.step1.name_title'|trans }}</div>
                            <div class="text-sm" style="color: var(--color-muted)">{{ 'games.new.step1.name_desc'|trans }}</div>
                        </div>
                    </button>

                    {# Date #}
                    <button type="button"
                            @click="toggleCategory('guessDate')"
                            :aria-pressed="guessDate ? 'true' : 'false'"
                            class="w-full flex items-center gap-4 p-4 rounded-xl border-2 transition-all text-left cursor-pointer"
                            :style="guessDate
                                ? 'border-color: var(--color-brand); background-color: rgba(196,113,74,0.06)'
                                : 'border-color: var(--color-line); background-color: #fff'">
                        <div class="shrink-0 w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all"
                             :style="guessDate ? 'border-color: var(--color-brand); background-color: var(--color-brand)' : 'border-color: var(--color-line)'">
                            <svg x-show="guessDate" class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                                <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="shrink-0 w-11 h-11 rounded-xl flex items-center justify-center" style="background-color: rgba(196,113,74,0.12)">
                            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-brand)" aria-hidden="true">
                                <rect x="3" y="4" width="18" height="18" rx="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/>
                                <line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                        </div>
                        <div>
                            <div class="font-bold" style="color: var(--color-ink)">{{ 'games.new.step1.date_title'|trans }}</div>
                            <div class="text-sm" style="color: var(--color-muted)">{{ 'games.new.step1.date_desc'|trans }}</div>
                        </div>
                    </button>

                    {# Weight #}
                    <button type="button"
                            @click="toggleCategory('guessWeight')"
                            :aria-pressed="guessWeight ? 'true' : 'false'"
                            class="w-full flex items-center gap-4 p-4 rounded-xl border-2 transition-all text-left cursor-pointer"
                            :style="guessWeight
                                ? 'border-color: var(--color-brand); background-color: rgba(196,113,74,0.06)'
                                : 'border-color: var(--color-line); background-color: #fff'">
                        <div class="shrink-0 w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all"
                             :style="guessWeight ? 'border-color: var(--color-brand); background-color: var(--color-brand)' : 'border-color: var(--color-line)'">
                            <svg x-show="guessWeight" class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                                <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="shrink-0 w-11 h-11 rounded-xl flex items-center justify-center" style="background-color: rgba(196,113,74,0.12)">
                            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-brand)" aria-hidden="true">
                                <line x1="12" y1="2" x2="12" y2="22"/>
                                <path d="M5 8l7-4 7 4"/>
                                <path d="M6 8l-2 6a3 3 0 006 0L6 8z"/>
                                <path d="M18 8l-2 6a3 3 0 006 0L18 8z"/>
                                <line x1="4" y1="21" x2="20" y2="21"/>
                            </svg>
                        </div>
                        <div>
                            <div class="font-bold" style="color: var(--color-ink)">{{ 'games.new.step1.weight_title'|trans }}</div>
                            <div class="text-sm" style="color: var(--color-muted)">{{ 'games.new.step1.weight_desc'|trans }}</div>
                        </div>
                    </button>

                    {# Height #}
                    <button type="button"
                            @click="toggleCategory('guessHeight')"
                            :aria-pressed="guessHeight ? 'true' : 'false'"
                            class="w-full flex items-center gap-4 p-4 rounded-xl border-2 transition-all text-left cursor-pointer"
                            :style="guessHeight
                                ? 'border-color: var(--color-brand); background-color: rgba(196,113,74,0.06)'
                                : 'border-color: var(--color-line); background-color: #fff'">
                        <div class="shrink-0 w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all"
                             :style="guessHeight ? 'border-color: var(--color-brand); background-color: var(--color-brand)' : 'border-color: var(--color-line)'">
                            <svg x-show="guessHeight" class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                                <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="shrink-0 w-11 h-11 rounded-xl flex items-center justify-center" style="background-color: rgba(196,113,74,0.12)">
                            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-brand)" aria-hidden="true">
                                <line x1="12" y1="2" x2="12" y2="22"/>
                                <path d="M9 5l3-3 3 3"/>
                                <path d="M9 19l3 3 3-3"/>
                            </svg>
                        </div>
                        <div>
                            <div class="font-bold" style="color: var(--color-ink)">{{ 'games.new.step1.height_title'|trans }}</div>
                            <div class="text-sm" style="color: var(--color-muted)">{{ 'games.new.step1.height_desc'|trans }}</div>
                        </div>
                    </button>

                </div>

                {# Message d'erreur catégorie #}
                <div x-show="showCategoryError"
                     class="flex items-center gap-2 mt-4 px-3 py-2.5 rounded-lg"
                     style="background-color: #FEF2F2; color: #B91C1C;"
                     role="alert">
                    <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    <span class="text-sm font-bold"
                          x-text="$el.closest('[data-error-category]').dataset.errorCategory"></span>
                </div>

            </div>{# /step categories #}

            {# ══════════════════════════════════════════════════ #}
            {# ÉTAPE 2 — Date prévue (facultatif)                #}
            {# ══════════════════════════════════════════════════ #}
            <div x-show="step === 'date'" class="card">
                <h2 class="text-2xl mb-1">{{ 'games.new.step2.title'|trans }}</h2>
                <p class="mb-6" style="color: var(--color-muted)">{{ 'games.new.step2.subtitle'|trans }}</p>

                <label class="form-label" for="dueDate">{{ 'games.new.step2.label'|trans }}</label>
                <input type="date" id="dueDate" name="dueDate" class="form-input"
                       min="{{ 'today'|date('Y-m-d') }}">
            </div>{# /step date #}

            {# ══════════════════════════════════════════════════ #}
            {# ÉTAPE 3 — Mode prénom (2 choix)                   #}
            {# ══════════════════════════════════════════════════ #}
            <div x-show="step === 'name'" class="card">
                <h2 class="text-2xl mb-1">{{ 'games.new.step3.title'|trans }}</h2>
                <p class="mb-6" style="color: var(--color-muted)">{{ 'games.new.step3.subtitle'|trans }}</p>

                <div class="flex flex-col gap-3">

                    {# Option 1 : proposition libre #}
                    <button type="button"
                            @click="selectNameMode('free')"
                            :aria-pressed="nameMode === 'free' ? 'true' : 'false'"
                            class="w-full flex items-start gap-4 p-4 rounded-xl border-2 transition-all text-left cursor-pointer"
                            :style="nameMode === 'free'
                                ? 'border-color: var(--color-brand); background-color: rgba(196,113,74,0.06)'
                                : 'border-color: var(--color-line); background-color: #fff'">
                        <div class="shrink-0 mt-0.5 w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all"
                             :style="nameMode === 'free' ? 'border-color: var(--color-brand)' : 'border-color: var(--color-line)'">
                            <div class="w-2.5 h-2.5 rounded-full transition-all"
                                 :style="nameMode === 'free' ? 'background-color: var(--color-brand)' : 'background-color: transparent'">
                            </div>
                        </div>
                        <div>
                            <div class="font-bold" style="color: var(--color-ink)">{{ 'games.new.step3.free_title'|trans }}</div>
                            <div class="text-sm mt-0.5" style="color: var(--color-muted)">{{ 'games.new.step3.free_desc'|trans }}</div>
                        </div>
                    </button>

                    {# Option 2 : 3 propositions avec indices #}
                    <button type="button"
                            @click="selectNameMode('hints')"
                            :aria-pressed="nameMode === 'hints' ? 'true' : 'false'"
                            class="w-full flex items-start gap-4 p-4 rounded-xl border-2 transition-all text-left cursor-pointer"
                            :style="nameMode === 'hints'
                                ? 'border-color: var(--color-brand); background-color: rgba(196,113,74,0.06)'
                                : 'border-color: var(--color-line); background-color: #fff'">
                        <div class="shrink-0 mt-0.5 w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all"
                             :style="nameMode === 'hints' ? 'border-color: var(--color-brand)' : 'border-color: var(--color-line)'">
                            <div class="w-2.5 h-2.5 rounded-full transition-all"
                                 :style="nameMode === 'hints' ? 'background-color: var(--color-brand)' : 'background-color: transparent'">
                            </div>
                        </div>
                        <div>
                            <div class="font-bold" style="color: var(--color-ink)">{{ 'games.new.step3.hints_title'|trans }}</div>
                            <div class="text-sm mt-0.5" style="color: var(--color-muted)">{{ 'games.new.step3.hints_desc'|trans }}</div>
                        </div>
                    </button>

                </div>

                {# Champ prénom — visible uniquement si mode indices #}
                <div x-show="nameMode === 'hints'" class="mt-5">
                    <label class="form-label" for="answerName">{{ 'games.new.step3.name_label'|trans }}</label>
                    <input type="text"
                           id="answerName"
                           name="answerName"
                           x-model="answerName"
                           @input="showNameError = false"
                           maxlength="100"
                           class="form-input"
                           placeholder="{{ 'games.new.step3.name_placeholder'|trans }}">
                    <p class="text-xs mt-1.5" style="color: var(--color-muted)">
                        {{ 'games.new.step3.name_hint'|trans }}
                    </p>
                </div>

                {# Message d'erreur mode prénom #}
                <div x-show="showNameError"
                     class="flex items-center gap-2 mt-4 px-3 py-2.5 rounded-lg"
                     style="background-color: #FEF2F2; color: #B91C1C;"
                     role="alert">
                    <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    <span class="text-sm font-bold"
                          x-text="nameMode === '' ? $el.closest('[data-error-name-mode]').dataset.errorNameMode : $el.closest('[data-error-name-required]').dataset.errorNameRequired"></span>
                </div>

            </div>{# /step name #}

            {# ══════════════════════════════════════════════════ #}
            {# ÉTAPE 4 — Titre et photo                          #}
            {# ══════════════════════════════════════════════════ #}
            <div x-show="step === 'finish'" class="card">
                <h2 class="text-2xl mb-1">{{ 'games.new.step4.title'|trans }}</h2>
                <p class="mb-6" style="color: var(--color-muted)">{{ 'games.new.step4.subtitle'|trans }}</p>

                <div class="flex flex-col gap-5">

                    <div>
                        <label class="form-label" for="gameTitle">{{ 'games.new.step4.title_label'|trans }}</label>
                        <input type="text"
                               id="gameTitle"
                               name="title"
                               maxlength="100"
                               class="form-input"
                               placeholder="{{ 'games.new.step4.title_placeholder'|trans }}">
                        <p class="text-xs mt-1.5" style="color: var(--color-muted)">
                            {{ 'games.new.step4.title_help'|trans({'%name%': app.user.lastName}) }}
                        </p>
                    </div>

                    <div>
                        <label class="form-label" for="imageFile">{{ 'games.new.step4.image_label'|trans }}</label>
                        <input type="file"
                               id="imageFile"
                               name="imageFile"
                               accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                               @change="handleImageChange($event)"
                               class="w-full text-sm rounded-xl border-2 px-4 py-3 cursor-pointer transition-colors"
                               style="border-color: var(--color-line); color: var(--color-muted)">
                        <p class="text-xs mt-1.5" style="color: var(--color-muted)">{{ 'games.new.step4.image_help'|trans }}</p>

                        {# Erreur image #}
                        <div x-show="imageError"
                             class="mt-2 text-sm font-semibold"
                             style="color: #c0392b"
                             x-cloak>
                            <span x-show="imageError === 'type'"
                                  x-text="$el.closest('[data-error-image-type]').dataset.errorImageType"></span>
                            <span x-show="imageError === 'size'"
                                  x-text="$el.closest('[data-error-image-size]').dataset.errorImageSize"></span>
                        </div>

                        {# Aperçu de l'image #}
                        <div x-show="imagePreview"
                             class="mt-3 rounded-xl overflow-hidden"
                             style="height: 11rem;">
                            <img :src="imagePreview"
                                 alt=""
                                 style="width: 100%; height: 100%; object-fit: cover; display: block;">
                        </div>
                    </div>

                </div>
            </div>{# /step finish #}

            {# ── Navigation ──────────────────────────────────── #}
            <div class="flex items-center mt-6 gap-3">

                {# Précédent #}
                <button type="button"
                        @click="prev"
                        x-show="!isFirst"
                        class="btn btn-secondary">
                    &larr; {{ 'games.new.btn_prev'|trans }}
                </button>

                <div class="flex-1"></div>

                {# Suivant #}
                <button type="button"
                        @click="next"
                        x-show="!isLast"
                        class="btn btn-primary">
                    {{ 'games.new.btn_next'|trans }} &rarr;
                </button>

                {# Créer (dernière étape uniquement) #}
                <button type="submit"
                        x-show="isLast"
                        :disabled="submitting"
                        class="btn btn-primary"
                        :class="submitting ? 'opacity-60 cursor-not-allowed' : ''">
                    <svg x-show="submitting" class="w-4 h-4 animate-spin shrink-0" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
                    </svg>
                    <span>{{ 'games.new.btn_create'|trans }}</span>
                </button>

            </div>

        </form>
    </div>

</div>
{% endblock %}
