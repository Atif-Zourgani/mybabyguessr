{% extends 'base.html.twig' %}

{% block title %}{{ 'games.new.title'|trans }}{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 py-12">

    <a href="{{ path('app_dashboard', {'_locale': app.request.locale}) }}"
       class="inline-flex items-center gap-1 text-sm text-muted no-underline hover:text-brand mb-8 block">
        ← {{ 'games.new.back'|trans }}
    </a>

    <div class="card text-center py-16">
        <h1 class="text-2xl mb-3">{{ 'games.new.title'|trans }}</h1>
        <p class="text-muted">{{ 'games.new.coming_soon'|trans }}</p>
    </div>

</div>
{% endblock %}
