{% extends 'base.html.twig' %}

{% block title %}{{ 'play.done.title'|trans }} — {{ game.displayTitle }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block og_title %}{{ app.request.locale == 'fr'
    ? 'Crée ton propre Baby Guessr — MyBabyGuessr'
    : (app.request.locale == 'es'
        ? 'Crea tu propio Baby Guessr — MyBabyGuessr'
        : (app.request.locale == 'pt'
            ? 'Cria o teu próprio Baby Guessr — MyBabyGuessr'
            : (app.request.locale == 'de'
                ? 'Erstelle dein eigenes Baby-Tippspiel — MyBabyGuessr'
                : (app.request.locale == 'it'
                    ? 'Crea il tuo Baby Guessr — MyBabyGuessr'
                    : 'Create your own Baby Guessr — MyBabyGuessr')))) }}{% endblock %}

{% block og_description %}{{ app.request.locale == 'fr'
    ? 'Crée ton jeu de pronostics bébé en 2 minutes. Famille et amis devinent le prénom, le sexe et la date — sans créer de compte. Partage juste un lien.'
    : (app.request.locale == 'es'
        ? 'Crea tu juego de pronósticos bebé en minutos. Familia y amigos adivinan el nombre, el sexo y la fecha — sin crear cuenta.'
        : (app.request.locale == 'pt'
            ? 'Cria o teu jogo de apostas sobre o bebé em minutos. Família e amigos adivinham o nome, o sexo e a data — sem criar conta.'
            : (app.request.locale == 'de'
                ? 'Erstelle dein Baby-Tippspiel in Minuten. Familie und Freunde tippen auf Name, Geschlecht und Datum — ohne Konto.'
                : (app.request.locale == 'it'
                    ? 'Crea il tuo gioco di pronostici sul bebè in pochi minuti. Famiglia e amici indovinano nome, sesso e data — senza account.'
                    : 'Create your baby guessing game in minutes. Family and friends guess name, gender and due date — no account needed.')))) }}{% endblock %}

{% block og_image %}
<meta property="og:image"        content="{{ absolute_url(asset('images/logo-mybabyguessr.png')) }}">
<meta property="og:image:width"  content="1024">
<meta property="og:image:height" content="1024">
<meta property="og:image:alt"    content="MyBabyGuessr">
{% endblock %}
{% block twitter_card %}summary{% endblock %}
{% block twitter_image %}{{ absolute_url(asset('images/logo-mybabyguessr.png')) }}{% endblock %}

{% block stylesheets %}
<style>
.deco-done { position:absolute; pointer-events:none; z-index:2; }
.deco-done-papillon { top:16px; right:12px; width:48px; opacity:0.75; }
.deco-done-etoile   { top:20px; left:14px;  width:33px; opacity:0.85; }
.deco-done-elephant { bottom:-8px; left:8px; width:68px; opacity:0.80; }
@media (min-width:640px) {
    .deco-done-papillon { top:20px; left:calc(50% + 198px); width:60px; }
    .deco-done-etoile   { top:24px; left:calc(50% - 250px); width:39px; }
    .deco-done-elephant { bottom:-10px; left:calc(50% - 260px); width:80px; }
}
</style>
{% endblock %}

{% set locale     = app.request.locale %}
{% set dateFormat = locale == 'en' ? 'm/d/Y' : (locale == 'de' ? 'd.m.Y' : 'd/m/Y') %}

{% block body %}
<section class="flex items-center justify-center min-h-[calc(100vh-10rem)] px-4 py-6 sm:py-12"
         style="position:relative;overflow:hidden">

    <img src="{{ asset('images/illustration/papillon1.png') }}" alt="" aria-hidden="true" class="deco-done deco-done-papillon">
    <img src="{{ asset('images/illustration/etoile.png') }}"    alt="" aria-hidden="true" class="deco-done deco-done-etoile">
    <img src="{{ asset('images/illustration/elephant.png') }}"  alt="" aria-hidden="true" class="deco-done deco-done-elephant">

<div class="card w-full max-w-md" style="position:relative;z-index:1">

    {# ── Icône succès ─────────────────────────────────────────── #}
    <div class="flex justify-center mb-6">
        <div class="w-16 h-16 rounded-full flex items-center justify-center"
             style="background-color: rgba(196,113,74,0.12)">
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none"
                 stroke="var(--color-brand)" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
        </div>
    </div>

    {# ── Titre ────────────────────────────────────────────────── #}
    <div class="text-center mb-6">
        <h1 class="text-2xl font-bold mb-2" style="color: var(--color-ink)">
            {{ 'play.done.title'|trans }}
        </h1>
        <p class="text-base font-semibold mb-3" style="color: var(--color-brand)">
            {{ 'play.done.heading'|trans({'%name%': playerName}) }}
        </p>
        <p class="text-sm leading-relaxed" style="color: var(--color-muted)">
            {{ 'play.done.message'|trans }}
        </p>
        {% if guess and guess.playerEmail %}
        <p class="text-sm leading-relaxed mt-1" style="color: var(--color-muted)">
            {{ 'play.done.notify_if_email'|trans }}
        </p>
        {% endif %}
    </div>

    {# ── Récapitulatif ────────────────────────────────────────── #}
    {% if guess and (guess.guessGender or guess.guessName or guess.guessDate or guess.guessWeight or guess.guessHeight) %}
    <div class="rounded-xl p-4 mb-6"
         style="background-color: rgba(196,113,74,0.06); border: 1px solid rgba(196,113,74,0.15)">
        <h2 class="text-sm font-semibold mb-3" style="color: var(--color-ink)">
            {{ 'play.done.your_guesses'|trans }}
        </h2>
        <dl class="space-y-2">
            {% if guess.guessGender %}
            <div class="flex justify-between text-sm">
                <dt style="color: var(--color-muted)">{{ 'play.done.gender_summary'|trans }}</dt>
                <dd class="font-medium" style="color: var(--color-ink)">
                    {{ guess.guessGender.value == 'boy' ? 'play.done.gender_boy'|trans : 'play.done.gender_girl'|trans }}
                </dd>
            </div>
            {% endif %}
            {% if guess.guessName %}
            <div class="flex justify-between text-sm">
                <dt style="color: var(--color-muted)">{{ 'play.done.name_summary'|trans }}</dt>
                <dd class="font-medium" style="color: var(--color-ink)">{{ guess.guessName }}</dd>
            </div>
            {% endif %}
            {% if guess.guessDate %}
            <div class="flex justify-between text-sm">
                <dt style="color: var(--color-muted)">{{ 'play.done.date_summary'|trans }}</dt>
                <dd class="font-medium" style="color: var(--color-ink)">
                    {{ guess.guessDate|date(dateFormat) }}{% if guess.guessDate|date('H:i') != '00:00' %} · {{ guess.guessDate|date('H:i') }}{% endif %}
                </dd>
            </div>
            {% endif %}
            {% if guess.guessWeight %}
            <div class="flex justify-between text-sm">
                <dt style="color: var(--color-muted)">{{ 'play.done.weight_summary'|trans }}</dt>
                <dd class="font-medium" style="color: var(--color-ink)">{{ (guess.guessWeight / 1000) }} kg</dd>
            </div>
            {% endif %}
            {% if guess.guessHeight %}
            <div class="flex justify-between text-sm">
                <dt style="color: var(--color-muted)">{{ 'play.done.height_summary'|trans }}</dt>
                <dd class="font-medium" style="color: var(--color-ink)">{{ (guess.guessHeight / 10) }} cm</dd>
            </div>
            {% endif %}
        </dl>
    </div>
    {% endif %}

    {# ── Message optionnel ───────────────────────────────────── #}
    {% if guess %}
    <div class="py-5" style="border-top: 1px solid var(--color-line)">
        {% if not messageSent %}
        <p class="text-sm font-semibold mb-1 text-center" style="color: var(--color-ink)">
            {{ 'play.done.msg_heading'|trans }}
        </p>
        <p class="text-xs mb-3 text-center" style="color: var(--color-muted)">
            {{ 'play.done.msg_desc'|trans }}
        </p>
        <form method="post"
              action="{{ path('app_game_done', {'_locale': app.request.locale, 'slug': game.slug, 'token': game.token}) }}"
              x-data="{ chars: 0, max: 500 }"
              novalidate>
            <input type="hidden" name="_token" value="{{ csrf_token('guess_message') }}">
            <div class="relative">
                <textarea name="message"
                          id="player-message"
                          maxlength="500"
                          rows="3"
                          class="form-input w-full resize-none"
                          style="padding-bottom:1.75rem;{% if messageError == 'too_long' %}border-color:#ef4444;{% endif %}"
                          placeholder="{{ 'play.done.msg_placeholder'|trans }}"
                          aria-label="{{ 'play.done.msg_heading'|trans }}"
                          aria-describedby="msg-counter{% if messageError == 'too_long' %} msg-error{% endif %}"
                          @input="chars = $el.value.length"></textarea>
                <span id="msg-counter"
                      class="absolute bottom-2 right-3 text-xs select-none pointer-events-none"
                      style="color: var(--color-muted)"
                      aria-live="polite"
                      x-text="max - chars"></span>
            </div>
            {% if messageError == 'too_long' %}
            <p id="msg-error" class="mt-1 text-sm text-red-600" role="alert">
                {{ 'play.done.msg_error_too_long'|trans }}
            </p>
            {% endif %}
            <div class="flex gap-3 mt-3">
                <button type="submit" name="skip" value="1"
                        class="btn btn-secondary flex-1 text-sm">
                    {{ 'play.done.msg_skip'|trans }}
                </button>
                <button type="submit"
                        class="btn btn-primary flex-1 text-sm">
                    {{ 'play.done.msg_submit'|trans }}
                </button>
            </div>
        </form>
        {% elseif guess.message %}
        <div class="flex flex-col items-center gap-1 py-1 text-center">
            <span class="text-2xl" aria-hidden="true">💌</span>
            <p class="text-sm font-semibold" style="color: var(--color-brand)">
                {{ 'play.done.msg_sent_title'|trans }}
            </p>
            <p class="text-xs" style="color: var(--color-muted)">
                {{ 'play.done.msg_sent_desc'|trans }}
            </p>
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# ── Promo ────────────────────────────────────────────────── #}
    <div class="pt-5" style="border-top: 1px solid var(--color-line)">
        <p class="text-sm font-semibold mb-1 text-center" style="color: var(--color-ink)">
            {{ 'play.done.share_heading'|trans }}
        </p>
        <p class="text-sm mb-4 text-center" style="color: var(--color-muted)">
            {{ 'play.done.share_desc'|trans }}
        </p>
        <a href="{{ path('app_home', {'_locale': app.request.locale}) }}"
           class="btn btn-primary w-full text-center">
            {{ 'play.done.share_btn'|trans }}
        </a>
    </div>

</div>
</section>
{% endblock %}
