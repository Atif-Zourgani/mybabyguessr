{% extends 'base.html.twig' %}
{% block title %}{{ 'play.closed.title'|trans }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 py-16 text-center">

    <div class="card-panel px-8 py-12">

        <div class="flex justify-center mb-6">
            <div class="flex items-center justify-center w-16 h-16 rounded-2xl"
                 style="background-color: rgba(196,113,74,0.10)">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"
                     stroke="var(--color-brand)" stroke-width="1.75"
                     stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </div>
        </div>

        <div class="w-16 h-16 rounded-xl mx-auto mb-4 overflow-hidden"
             style="background:rgba(196,113,74,0.08)">
            <img src="{{ game.image ? asset(game.image) : asset('images/logo-mybabyguessr.png') }}"
                 alt="{{ game.image ? '' : 'MyBabyGuessr' }}"
                 style="width:100%;height:100%;object-fit:{{ game.image ? 'cover' : 'contain' }};display:block;padding:{{ game.image ? '0' : '10px' }};box-sizing:border-box">
        </div>

        <h1 class="text-xl font-bold mb-3" style="color: var(--color-ink)">
            {{ game.displayTitle }}
        </h1>

        <p class="text-base font-semibold mb-2" style="color: var(--color-brand)">
            {{ 'play.closed.heading'|trans }}
        </p>

        <p class="text-sm leading-relaxed" style="color: var(--color-muted)">
            {{ 'play.closed.message'|trans }}
        </p>

    </div>

</div>
{% endblock %}
