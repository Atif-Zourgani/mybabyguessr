{% extends 'base.html.twig' %}
{% block title %}{{ 'games.reveal_share.title'|trans }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block og_title %}{{ app.request.locale == 'fr'
    ? 'Révélation — ' ~ game.displayTitle
    : (app.request.locale == 'es'
        ? 'Revelación — ' ~ game.displayTitle
        : (app.request.locale == 'pt'
            ? 'Revelação — ' ~ game.displayTitle
            : (app.request.locale == 'de'
                ? 'Enthüllung — ' ~ game.displayTitle
                : (app.request.locale == 'it'
                    ? 'Rivelazione — ' ~ game.displayTitle
                    : 'The Reveal — ' ~ game.displayTitle)))) }}{% endblock %}

{% block og_description %}{{ app.request.locale == 'fr'
    ? 'Les vraies réponses du Baby Guessr ' ~ game.displayTitle ~ ' sont révélées ! Découvrez qui a deviné juste.'
    : (app.request.locale == 'es'
        ? '¡Las respuestas reales del Baby Guessr ' ~ game.displayTitle ~ ' ya están aquí! Descubre quién ha acertado.'
        : (app.request.locale == 'pt'
            ? 'As respostas reais do Baby Guessr ' ~ game.displayTitle ~ ' foram reveladas! Veja quem adivinhou certo.'
            : (app.request.locale == 'de'
                ? 'Die echten Antworten für ' ~ game.displayTitle ~ ' sind da! Sieh, wer richtig getippt hat.'
                : (app.request.locale == 'it'
                    ? 'Le risposte vere del Baby Guessr ' ~ game.displayTitle ~ ' sono qui! Scopri chi ha indovinato.'
                    : 'The real answers for ' ~ game.displayTitle ~ ' are here! See who guessed right.')))) }}{% endblock %}

{% block og_image %}
{% set _base = app.request.schemeAndHttpHost %}
{% set _og_img = game.image ? (_base ~ '/' ~ game.image) : (_base ~ asset('images/logo-mybabyguessr.png')) %}
<meta property="og:image" content="{{ _og_img }}">
{% if game.image %}
<meta property="og:image:alt" content="{{ game.displayTitle }}">
{% else %}
<meta property="og:image:width"  content="1024">
<meta property="og:image:height" content="1024">
<meta property="og:image:alt"    content="MyBabyGuessr">
{% endif %}
{% endblock %}
{% block twitter_card %}{{ game.image ? 'summary_large_image' : 'summary' }}{% endblock %}
{% block twitter_image %}{% set _b = app.request.schemeAndHttpHost %}{{ game.image ? (_b ~ '/' ~ game.image) : (_b ~ asset('images/logo-mybabyguessr.png')) }}{% endblock %}

{% block stylesheets %}
<style>
.deco-revs { position:absolute; pointer-events:none; z-index:2; }
.deco-revs-soleil   { top:4px;  right:8px;  width:72px; opacity:0.68; }
.deco-revs-feuille  { bottom:10px; left:8px; width:36px; opacity:0.72; transform:rotate(-20deg); }
@media (min-width:640px) {
    .deco-revs-soleil  { top:6px;  left:calc(50% + 228px); width:84px; }
    .deco-revs-feuille { bottom:12px; left:calc(50% - 316px); width:42px; }
}
</style>
{% endblock %}

{% block body %}
{% set revealUrl = url('app_game_reveal_public', {'_locale': app.request.locale, 'slug': game.slug, 'token': game.token}) %}
{% set waText    = 'games.reveal_share.whatsapp_text'|trans({'%game%': game.displayTitle}) ~ "\n\n" ~ revealUrl %}
{% set emailBody = 'games.reveal_share.email_body'|trans({'%game%': game.displayTitle}) ~ "\n\n" ~ revealUrl %}

<div class="max-w-xl mx-auto px-4 sm:px-6 py-8 sm:py-12"
     id="share-page"
     style="position:relative;overflow:hidden"
     data-share-url="{{ revealUrl }}"
     data-share-title="{{ game.displayTitle|e('html_attr') }}"
     data-copy-label="{{ 'games.reveal_share.btn_copy'|trans|e('html_attr') }}"
     data-copied-label="{{ 'games.reveal_share.btn_copied'|trans|e('html_attr') }}">

    <img src="{{ asset('images/illustration/soleil.png') }}"        alt="" aria-hidden="true" class="deco-revs deco-revs-soleil">
    <img src="{{ asset('images/illustration/feuille_orange.png') }}" alt="" aria-hidden="true" class="deco-revs deco-revs-feuille">

    {# ── En-tête ──────────────────────────────────────────────── #}
    <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full mb-6"
             style="background-color: rgba(196,113,74,0.12)">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"
                      stroke="var(--color-brand)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold mb-3" style="color: var(--color-ink)">
            {{ 'games.reveal_share.title'|trans }}
        </h1>
        <p class="text-base font-semibold leading-relaxed max-w-sm mx-auto" style="color: var(--color-ink)">
            {{ 'games.reveal_share.subtitle'|trans }}
        </p>
    </div>

    {# ── Nom du jeu ───────────────────────────────────────────── #}
    <div class="card mb-5 text-center py-5">
        <div class="mx-auto mb-4 rounded-xl overflow-hidden"
             style="width:5rem;height:5rem;background:rgba(196,113,74,0.08)">
            <img src="{{ game.image ? asset(game.image) : asset('images/logo-mybabyguessr.png') }}"
                 alt="{{ game.image ? '' : 'MyBabyGuessr' }}"
                 width="80" height="80" loading="lazy"
                 style="width:100%;height:100%;object-fit:{{ game.image ? 'cover' : 'contain' }};display:block;padding:{{ game.image ? '0' : '12px' }};box-sizing:border-box">
        </div>
        <p class="text-xs font-bold uppercase tracking-widest mb-1"
           style="color: var(--color-muted)">Baby Guessr</p>
        <p class="text-xl font-bold" style="color: var(--color-ink)">{{ game.displayTitle }}</p>
    </div>

    {# ── Lien + copier ────────────────────────────────────────── #}
    <div class="card mb-4">
        <p class="text-xs font-bold uppercase tracking-widest mb-2"
           style="color: var(--color-muted)">{{ 'games.reveal_share.link_label'|trans }}</p>
        <div class="flex items-center gap-2">
            <input id="share-url-input"
                   type="text" readonly
                   value="{{ revealUrl }}"
                   class="flex-1 text-sm px-3 py-2.5 rounded-lg border-0 outline-none"
                   style="background-color: var(--color-cream); color: var(--color-ink); font-family: monospace; min-width: 0">
            <button id="copy-link-btn"
                    type="button"
                    class="btn btn-primary shrink-0 text-sm px-4 py-2.5"
                    aria-label="{{ 'games.reveal_share.btn_copy'|trans }}">
                <svg id="copy-icon" class="w-4 h-4 inline-block mr-1.5 shrink-0" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2"/>
                    <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                </svg>
                <span id="copy-label">{{ 'games.reveal_share.btn_copy'|trans }}</span>
            </button>
        </div>
    </div>

    {# ── Bouton natif (Web Share API) ─────────────────────────── #}
    <div id="mobile-share" class="hidden mb-2">
        <button id="native-share-btn" class="btn btn-primary w-full text-base py-3.5">
            <svg class="w-5 h-5 inline-block mr-2 shrink-0" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
            {{ 'games.reveal_share.btn_share'|trans }}
        </button>
        <p class="text-center text-xs mt-2 mb-3" style="color: var(--color-muted)">{{ 'games.share.or_via'|trans }}</p>
    </div>

    {# ── Boutons directs ──────────────────────────────────────── #}
    <div id="desktop-share" class="flex flex-col gap-3 mb-4">
        <div class="flex flex-col gap-3 sm:grid sm:grid-cols-3">

            {# WhatsApp #}
            <a href="https://wa.me/?text={{ waText|url_encode }}"
               target="_blank" rel="noopener noreferrer"
               class="btn btn-primary flex items-center justify-center gap-2 text-sm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                {{ 'games.reveal_share.btn_whatsapp'|trans }}
            </a>

            {# Email #}
            <a href="mailto:?subject={{ 'games.reveal_share.email_subject'|trans({'%game%': game.displayTitle})|url_encode }}&body={{ emailBody|url_encode }}"
               class="btn btn-secondary flex items-center justify-center gap-2 text-sm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
                {{ 'games.reveal_share.btn_email'|trans }}
            </a>

            {# Facebook #}
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ revealUrl|url_encode }}"
               target="_blank" rel="noopener noreferrer"
               class="btn btn-secondary flex items-center justify-center gap-2 text-sm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                {{ 'games.share.btn_facebook'|trans }}
            </a>

        </div>
    </div>

    {# ── Navigation ───────────────────────────────────────────── #}
    <div class="flex flex-col gap-3 mt-6">
        <a href="{{ path('app_game_show', {'_locale': app.request.locale, 'token': game.token}) }}"
           class="btn btn-secondary w-full text-center text-sm">
            {{ 'games.reveal_share.btn_game'|trans }}
        </a>
        <div class="text-center">
            <a href="{{ path('app_dashboard', {'_locale': app.request.locale}) }}"
               class="text-sm font-bold"
               style="color: var(--color-muted); text-decoration: none">
                &larr; {{ 'games.reveal_share.btn_dashboard'|trans }}
            </a>
        </div>
    </div>

</div>
{% endblock %}
