{% extends 'base.html.twig' %}
{% block title %}{{ 'play.reveal.title'|trans({'%game%': game.displayTitle}) }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block og_title %}{{ 'play.reveal.title'|trans({'%game%': game.displayTitle}) }} — MyBabyGuessr{% endblock %}
{% block og_description %}{{ app.request.locale == 'fr'
    ? 'Découvrez les vraies réponses et les gagnants du Baby Guessr ' ~ game.displayTitle ~ ' !'
    : (app.request.locale == 'es'
        ? '¡Descubre las respuestas reales y los ganadores del Baby Guessr ' ~ game.displayTitle ~ '!'
        : (app.request.locale == 'pt'
            ? 'Descubra as respostas reais e os vencedores do Baby Guessr ' ~ game.displayTitle ~ '!'
            : (app.request.locale == 'de'
                ? 'Entdecke die echten Antworten und die Gewinner des Baby Guessr ' ~ game.displayTitle ~ '!'
                : (app.request.locale == 'it'
                    ? 'Scopri le risposte vere e i vincitori del Baby Guessr ' ~ game.displayTitle ~ '!'
                    : 'Discover the real answers and the winners of the ' ~ game.displayTitle ~ ' Baby Guessr!')))) }}{% endblock %}
{% block og_image %}
{% set _base = app.request.schemeAndHttpHost %}
{% set _og_img = game.image ? (_base ~ '/' ~ game.image) : (_base ~ asset('images/logo-mybabyguessr.png')) %}
<meta property="og:image" content="{{ _og_img }}">
<meta property="og:image:width"  content="{{ game.image ? '800' : '1024' }}">
<meta property="og:image:height" content="{{ game.image ? '800' : '1024' }}">
<meta property="og:image:alt"    content="{{ game.displayTitle|e('html_attr') }}">
{% endblock %}
{% block twitter_card %}{{ game.image ? 'summary_large_image' : 'summary' }}{% endblock %}
{% block twitter_image %}{% set _b = app.request.schemeAndHttpHost %}{{ game.image ? (_b ~ '/' ~ game.image) : (_b ~ asset('images/logo-mybabyguessr.png')) }}{% endblock %}

{% block stylesheets %}
<style>
@keyframes mbg-twinkle {
    0%, 100% { opacity: 0.2;  transform: scale(0.65) rotate(0deg);  }
    50%       { opacity: 1;    transform: scale(1.15) rotate(25deg); }
}
.mbg-cover {
    position: absolute; inset: 0; z-index: 10; cursor: pointer;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 1.5rem;
    background: linear-gradient(135deg, #C4714A 0%, #8B4F2E 55%, #6B3A22 100%);
}
.mbg-sp {
    position: absolute; font-style: normal; line-height: 1;
    color: rgba(255,248,235,0.75);
    pointer-events: none; user-select: none;
    animation: mbg-twinkle 2.8s ease-in-out infinite;
}
.mbg-sp-1 { top:8%;    left:8%;    font-size:1.25rem; animation-delay:0s;    }
.mbg-sp-2 { top:10%;   right:12%;  font-size:0.7rem;  animation-delay:0.6s;  }
.mbg-sp-3 { top:55%;   left:4%;    font-size:0.85rem; animation-delay:1.1s;  }
.mbg-sp-4 { top:65%;   right:6%;   font-size:1.1rem;  animation-delay:1.6s;  }
.mbg-sp-5 { bottom:12%;left:22%;   font-size:0.6rem;  animation-delay:0.9s;  }
.mbg-sp-6 { bottom:18%;right:20%;  font-size:0.95rem; animation-delay:0.3s;  }
.mbg-sp-7 { top:32%;   left:2%;    font-size:0.5rem;  animation-delay:1.4s;  }
.mbg-sp-8 { top:40%;   right:3%;   font-size:0.65rem; animation-delay:0.7s;  }
@property --mbg-r { syntax: '<percentage>'; inherits: false; initial-value: 0%; }
@keyframes mbg-ink-dissolve { from { --mbg-r: 0%; } to { --mbg-r: 200%; } }
@keyframes mbg-fog-lift { from { opacity: 1; } to { opacity: 0; } }
.mbg-cover.mbg-dissolving {
    animation: mbg-ink-dissolve 1.2s ease-in forwards;
    -webkit-mask-image: radial-gradient(circle at var(--ox,50%) var(--oy,50%), transparent var(--mbg-r), #000 calc(var(--mbg-r) + 12%));
    mask-image: radial-gradient(circle at var(--ox,50%) var(--oy,50%), transparent var(--mbg-r), #000 calc(var(--mbg-r) + 12%));
    pointer-events: none;
}
.mbg-fog {
    position: absolute; inset: 0; z-index: 5; pointer-events: none;
    background: rgba(248,243,238,0.65);
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
}
.mbg-fog.mbg-lifting { animation: mbg-fog-lift 0.8s ease-out 0.55s forwards; }
</style>
{% endblock %}

{% set locale = app.request.locale %}
{% set dateFormat = locale == 'en' ? 'm/d/Y' : (locale == 'de' ? 'd.m.Y' : 'd/m/Y') %}
{% set isFr = locale == 'fr' %}
{% set isEs = locale == 'es' %}
{% set isPt = locale == 'pt' %}
{% set isDe = locale == 'de' %}
{% set isIt = locale == 'it' %}

{% block body %}

{# ── En-tête ──────────────────────────────────────────────────── #}
<div class="max-w-2xl mx-auto px-4 sm:px-6 pt-10 pb-2 sm:pt-14 sm:pb-4 text-center">

    <div class="mx-auto mb-5 rounded-2xl overflow-hidden"
         style="width:5rem;height:5rem;background:rgba(196,113,74,0.08)">
        <img src="{{ game.image ? asset(game.image) : asset('images/logo-mybabyguessr.png') }}"
             alt="{{ game.image ? '' : 'MyBabyGuessr' }}"
             style="width:100%;height:100%;object-fit:{{ game.image ? 'cover' : 'contain' }};display:block;padding:{{ game.image ? '0' : '12px' }};box-sizing:border-box">
    </div>

    <p class="text-xs font-bold uppercase tracking-widest mb-3"
       style="color:var(--color-brand)">
        {{ 'play.reveal.label'|trans }}
    </p>
    <h1 class="text-3xl sm:text-4xl font-bold mb-2" style="color:var(--color-ink)">
        {{ game.displayTitle }}
    </h1>
    <p class="text-sm" style="color:var(--color-muted)">
        {{ 'play.reveal.subtitle'|trans }}
    </p>

    <div class="mt-6 mb-2"
         style="height:2px;background:linear-gradient(to right,transparent,var(--color-brand),transparent)"></div>

</div>

{# ── Contenu ──────────────────────────────────────────────────── #}
<div class="max-w-2xl mx-auto px-4 sm:px-6 py-6 sm:py-8">

    {# ── Sexe ─────────────────────────────────────────────────── #}
    {% if game.isGuessGender() %}
    <div class="card mb-4 text-center py-8"
         style="position:relative;overflow:hidden;{% if game.answerGender %}background:linear-gradient(135deg,rgba(196,113,74,0.07) 0%,rgba(122,78,59,0.04) 100%);border:2px solid rgba(196,113,74,0.18){% endif %}"
         x-data="{ revealed: false, dissolving: false }">

        <div class="mbg-cover" x-show="!revealed" @click="dissolving=true; const _r=$el.getBoundingClientRect(); $el.style.setProperty('--ox',((event.clientX-_r.left)/_r.width*100).toFixed(1)+'%'); $el.style.setProperty('--oy',((event.clientY-_r.top)/_r.height*100).toFixed(1)+'%'); $el.classList.add('mbg-dissolving'); setTimeout(()=>{revealed=true},1400)">
            <em class="mbg-sp mbg-sp-1">✦</em><em class="mbg-sp mbg-sp-2">✧</em>
            <em class="mbg-sp mbg-sp-3">✦</em><em class="mbg-sp mbg-sp-4">✧</em>
            <em class="mbg-sp mbg-sp-5">✦</em><em class="mbg-sp mbg-sp-6">✧</em>
            <em class="mbg-sp mbg-sp-7">✦</em><em class="mbg-sp mbg-sp-8">✧</em>
            <p style="font-size:1.125rem;font-weight:800;color:#fff;margin:0 0 0.5rem;text-align:center;line-height:1.35;text-shadow:0 1px 4px rgba(0,0,0,0.18)">
                {{ isFr ? 'C\'est un garçon ou une fille ?' : (isEs ? '¿Niño o niña?' : (isPt ? 'Menino ou menina?' : (isDe ? 'Junge oder Mädchen?' : (isIt ? 'Maschio o femmina?' : 'Boy or girl?')))) }}
            </p>
            <p style="font-size:0.8rem;font-weight:600;color:rgba(255,248,235,0.8);margin:0;text-align:center">
                {{ isFr ? 'Appuyer pour révéler' : (isEs ? 'Toca para revelar' : (isPt ? 'Toque para revelar' : (isDe ? 'Tippen zum Enthüllen' : (isIt ? 'Tocca per rivelare' : 'Tap to reveal')))) }} ✦
            </p>
        </div>
        <div class="mbg-fog" x-show="!revealed" :class="{ 'mbg-lifting': dissolving }"></div>

        <p class="text-xs font-bold uppercase tracking-widest mb-5"
           style="color:var(--color-muted)">{{ 'play.reveal.winners_gender'|trans }}</p>

        {% if game.answerGender %}
            <p style="font-size:clamp(1.75rem,6vw,2.5rem);font-weight:800;color:var(--color-brand);line-height:1.2;margin-bottom:1.5rem">
                {{ game.answerGender.value == 'boy' ? 'play.reveal.gender_boy'|trans : 'play.reveal.gender_girl'|trans }}
            </p>
            {% if winners.gender is defined and winners.gender|length > 0 %}
            {% set genderVisible = winners.gender|slice(0, 5) %}
            {% set genderHidden  = winners.gender|slice(5) %}
            <div x-data="{ open: false }">
                <div class="flex flex-wrap justify-center gap-2">
                    {% for item in genderVisible %}
                    <span class="text-sm font-bold px-3 py-1.5 rounded-full"
                          style="background-color:rgba(196,113,74,0.14);color:var(--color-brand)">
                        {{ item.guess.playerName }}
                    </span>
                    {% endfor %}
                </div>
                {% if genderHidden|length > 0 %}
                <div class="flex flex-wrap justify-center gap-2 mt-2" x-show="open" style="display:none">
                    {% for item in genderHidden %}
                    <span class="text-sm font-bold px-3 py-1.5 rounded-full"
                          style="background-color:rgba(196,113,74,0.14);color:var(--color-brand)">
                        {{ item.guess.playerName }}
                    </span>
                    {% endfor %}
                </div>
                <button @click="open = !open" type="button"
                        class="mt-3 text-sm font-semibold"
                        style="background:none;border:none;cursor:pointer;padding:0;color:var(--color-brand)">
                    <span x-show="!open">+ {{ isFr ? 'Voir les ' ~ genderHidden|length ~ ' autres' : (isEs ? 'Ver los ' ~ genderHidden|length ~ ' más' : (isPt ? 'Ver os ' ~ genderHidden|length ~ ' outros' : (isDe ? genderHidden|length ~ ' weitere anzeigen' : (isIt ? 'Vedi altri ' ~ genderHidden|length : 'See ' ~ genderHidden|length ~ ' more')))) }}</span>
                    <span x-show="open" style="display:none">▲ {{ isFr ? 'Réduire' : (isEs ? 'Mostrar menos' : (isPt ? 'Mostrar menos' : (isDe ? 'Weniger' : (isIt ? 'Mostra meno' : 'Show less')))) }}</span>
                </button>
                {% endif %}
            </div>
            {% else %}
            <p class="text-sm italic" style="color:var(--color-muted)">{{ 'play.reveal.no_winner'|trans }}</p>
            {% endif %}
        {% else %}
            <p class="text-base italic" style="color:var(--color-muted)">{{ 'play.reveal.not_revealed'|trans }}</p>
        {% endif %}

    </div>
    {% endif %}

    {# ── Prénom ───────────────────────────────────────────────── #}
    {% if game.isGuessName() %}
    <div class="card mb-4 text-center py-8" style="position:relative;overflow:hidden" x-data="{ revealed: false, dissolving: false }">

        <div class="mbg-cover" x-show="!revealed" @click="dissolving=true; const _r=$el.getBoundingClientRect(); $el.style.setProperty('--ox',((event.clientX-_r.left)/_r.width*100).toFixed(1)+'%'); $el.style.setProperty('--oy',((event.clientY-_r.top)/_r.height*100).toFixed(1)+'%'); $el.classList.add('mbg-dissolving'); setTimeout(()=>{revealed=true},1400)">
            <em class="mbg-sp mbg-sp-1">✦</em><em class="mbg-sp mbg-sp-2">✧</em>
            <em class="mbg-sp mbg-sp-3">✦</em><em class="mbg-sp mbg-sp-4">✧</em>
            <em class="mbg-sp mbg-sp-5">✦</em><em class="mbg-sp mbg-sp-6">✧</em>
            <em class="mbg-sp mbg-sp-7">✦</em><em class="mbg-sp mbg-sp-8">✧</em>
            <p style="font-size:1.125rem;font-weight:800;color:#fff;margin:0 0 0.5rem;text-align:center;line-height:1.35;text-shadow:0 1px 4px rgba(0,0,0,0.18)">
                {{ isFr ? 'Quel prénom ont-ils choisi ?' : (isEs ? '¿Qué nombre eligieron?' : (isPt ? 'Que nome escolheram?' : (isDe ? 'Welchen Namen haben sie gewählt?' : (isIt ? 'Che nome hanno scelto?' : 'What name did they choose?')))) }}
            </p>
            <p style="font-size:0.8rem;font-weight:600;color:rgba(255,248,235,0.8);margin:0;text-align:center">
                {{ isFr ? 'Appuyer pour révéler' : (isEs ? 'Toca para revelar' : (isPt ? 'Toque para revelar' : (isDe ? 'Tippen zum Enthüllen' : (isIt ? 'Tocca per rivelare' : 'Tap to reveal')))) }} ✦
            </p>
        </div>
        <div class="mbg-fog" x-show="!revealed" :class="{ 'mbg-lifting': dissolving }"></div>

        <p class="text-xs font-bold uppercase tracking-widest mb-5"
           style="color:var(--color-muted)">{{ 'play.reveal.winners_name'|trans }}</p>

        {% if game.answerName %}
            <p style="font-size:clamp(2rem,7vw,3rem);font-weight:800;color:var(--color-ink);line-height:1.15;margin-bottom:1.5rem">
                {{ game.answerName }}
            </p>
            {% if winners.name is defined and winners.name|length > 0 %}
            {% set nameVisible = winners.name|slice(0, 5) %}
            {% set nameHidden  = winners.name|slice(5) %}
            <div x-data="{ open: false }">
                <div class="space-y-2">
                    {% for item in nameVisible %}
                    <div class="rounded-xl px-4 py-3 text-center"
                         style="background-color:rgba(196,113,74,0.07);border:1px solid rgba(196,113,74,0.18)">
                        <div class="text-xs font-bold mb-0.5" style="color:var(--color-muted)">{{ loop.index }}</div>
                        <div class="text-sm font-bold" style="color:var(--color-ink)">{{ item.guess.playerName }}</div>
                        <div class="text-xs" style="margin-top:0.125rem;color:var(--color-muted)">{{ item.guess.createdAt|date(dateFormat) }}</div>
                    </div>
                    {% endfor %}
                </div>
                {% if nameHidden|length > 0 %}
                <div class="space-y-2 mt-2" x-show="open" style="display:none">
                    {% for item in nameHidden %}
                    <div class="rounded-xl px-4 py-3 text-center"
                         style="background-color:rgba(196,113,74,0.07);border:1px solid rgba(196,113,74,0.18)">
                        <div class="text-xs font-bold mb-0.5" style="color:var(--color-muted)">{{ loop.index + 5 }}</div>
                        <div class="text-sm font-bold" style="color:var(--color-ink)">{{ item.guess.playerName }}</div>
                        <div class="text-xs" style="margin-top:0.125rem;color:var(--color-muted)">{{ item.guess.createdAt|date(dateFormat) }}</div>
                    </div>
                    {% endfor %}
                </div>
                <button @click="open = !open" type="button"
                        class="mt-3 text-sm font-semibold w-full"
                        style="background:none;border:none;cursor:pointer;padding:0;color:var(--color-brand)">
                    <span x-show="!open">+ {{ isFr ? 'Voir les ' ~ nameHidden|length ~ ' autres' : (isEs ? 'Ver los ' ~ nameHidden|length ~ ' más' : (isPt ? 'Ver os ' ~ nameHidden|length ~ ' outros' : (isDe ? nameHidden|length ~ ' weitere anzeigen' : (isIt ? 'Vedi altri ' ~ nameHidden|length : 'See ' ~ nameHidden|length ~ ' more')))) }}</span>
                    <span x-show="open" style="display:none">▲ {{ isFr ? 'Réduire' : (isEs ? 'Mostrar menos' : (isPt ? 'Mostrar menos' : (isDe ? 'Weniger' : (isIt ? 'Mostra meno' : 'Show less')))) }}</span>
                </button>
                {% endif %}
            </div>
            {% else %}
            <p class="text-sm italic" style="color:var(--color-muted)">{{ 'play.reveal.no_winner'|trans }}</p>
            {% endif %}
        {% else %}
            <p class="text-base italic" style="color:var(--color-muted)">{{ 'play.reveal.not_revealed'|trans }}</p>
        {% endif %}

    </div>
    {% endif %}

    {# ── Date / Poids / Taille — grille responsive ────────────── #}
    {% set hasDate   = game.isGuessDate() %}
    {% set hasWeight = game.isGuessWeight() %}
    {% set hasHeight = game.isGuessHeight() %}

    {% if hasDate or hasWeight or hasHeight %}

        {% if hasDate and hasWeight and hasHeight %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">
        {% elseif (hasDate and hasWeight) or (hasDate and hasHeight) or (hasWeight and hasHeight) %}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        {% else %}
        <div class="grid grid-cols-1 gap-4 mb-4">
        {% endif %}

            {% if hasDate %}
            <div class="card text-center py-6" style="position:relative;overflow:hidden" x-data="{ revealed: false, dissolving: false }">
                <div class="mbg-cover" x-show="!revealed" @click="dissolving=true; const _r=$el.getBoundingClientRect(); $el.style.setProperty('--ox',((event.clientX-_r.left)/_r.width*100).toFixed(1)+'%'); $el.style.setProperty('--oy',((event.clientY-_r.top)/_r.height*100).toFixed(1)+'%'); $el.classList.add('mbg-dissolving'); setTimeout(()=>{revealed=true},1400)">
                    <em class="mbg-sp mbg-sp-1">✦</em><em class="mbg-sp mbg-sp-2">✧</em>
                    <em class="mbg-sp mbg-sp-3">✦</em><em class="mbg-sp mbg-sp-4">✧</em>
                    <em class="mbg-sp mbg-sp-5">✦</em><em class="mbg-sp mbg-sp-6">✧</em>
                    <em class="mbg-sp mbg-sp-7">✦</em><em class="mbg-sp mbg-sp-8">✧</em>
                    <p style="font-size:1rem;font-weight:800;color:#fff;margin:0 0 0.5rem;text-align:center;line-height:1.35;text-shadow:0 1px 4px rgba(0,0,0,0.18)">
                        {{ isFr ? 'Quelle était la bonne date ?' : (isEs ? '¿Cuál era la fecha correcta?' : (isPt ? 'Qual era a data certa?' : (isDe ? 'Was war das richtige Datum?' : (isIt ? 'Qual era la data giusta?' : 'What was the right date?')))) }}
                    </p>
                    <p style="font-size:0.75rem;font-weight:600;color:rgba(255,248,235,0.8);margin:0;text-align:center">
                        {{ isFr ? 'Appuyer pour révéler' : (isEs ? 'Toca para revelar' : (isPt ? 'Toque para revelar' : (isDe ? 'Tippen zum Enthüllen' : (isIt ? 'Tocca per rivelare' : 'Tap to reveal')))) }} ✦
                    </p>
                </div>
                <div class="mbg-fog" x-show="!revealed" :class="{ 'mbg-lifting': dissolving }"></div>
                <p class="text-xs font-bold uppercase tracking-widest mb-4"
                   style="color:var(--color-muted)">{{ 'play.reveal.winners_date'|trans }}</p>
                {% if game.answerDate %}
                    <p class="text-xl font-bold mb-4" style="color:var(--color-ink)">
                        {{ game.answerDate|date(dateFormat) }}
                    </p>
                    {% if winners.date is defined and winners.date|length > 0 %}
                    {% set dateVisible = winners.date|slice(0, 5) %}
                    {% set dateHidden  = winners.date|slice(5) %}
                    <div x-data="{ open: false }">
                        <div class="space-y-2">
                            {% for item in dateVisible %}
                            {% set diffDays = (item.diff / 86400)|round %}
                            <div class="rounded-lg px-3 py-3 text-center"
                                 style="background-color:var(--color-cream)">
                                <div class="text-xs font-bold mb-0.5" style="color:var(--color-muted)">{{ loop.index }}</div>
                                <div class="text-sm font-bold" style="color:var(--color-ink)">{{ item.guess.playerName }}</div>
                                <div class="text-xs font-semibold" style="margin-top:0.125rem;color:{{ diffDays == 0 ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                                    {% if diffDays == 0 %}{{ isFr ? 'Exact !' : (isEs ? '¡Exacto!' : (isPt ? 'Exato!' : (isDe ? 'Genau!' : (isIt ? 'Esatto!' : 'Exact!')))) }}
                                    {% elseif diffDays == 1 %}{{ isFr ? '1 jour' : (isEs ? '1 día' : (isPt ? '1 dia' : (isDe ? '1 Tag' : (isIt ? '1 giorno' : '1 day')))) }}
                                    {% else %}{{ diffDays }}{{ isFr ? ' jours' : (isEs ? ' días' : (isPt ? ' dias' : (isDe ? ' Tage' : (isIt ? ' giorni' : ' days')))) }}
                                    {% endif %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        {% if dateHidden|length > 0 %}
                        <div class="space-y-2 mt-2" x-show="open" style="display:none">
                            {% for item in dateHidden %}
                            {% set diffDays = (item.diff / 86400)|round %}
                            <div class="rounded-lg px-3 py-3 text-center"
                                 style="background-color:var(--color-cream)">
                                <div class="text-xs font-bold mb-0.5" style="color:var(--color-muted)">{{ loop.index + 5 }}</div>
                                <div class="text-sm font-bold" style="color:var(--color-ink)">{{ item.guess.playerName }}</div>
                                <div class="text-xs font-semibold" style="margin-top:0.125rem;color:{{ diffDays == 0 ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                                    {% if diffDays == 0 %}{{ isFr ? 'Exact !' : (isEs ? '¡Exacto!' : (isPt ? 'Exato!' : (isDe ? 'Genau!' : (isIt ? 'Esatto!' : 'Exact!')))) }}
                                    {% elseif diffDays == 1 %}{{ isFr ? '1 jour' : (isEs ? '1 día' : (isPt ? '1 dia' : (isDe ? '1 Tag' : (isIt ? '1 giorno' : '1 day')))) }}
                                    {% else %}{{ diffDays }}{{ isFr ? ' jours' : (isEs ? ' días' : (isPt ? ' dias' : (isDe ? ' Tage' : (isIt ? ' giorni' : ' days')))) }}
                                    {% endif %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        <button @click="open = !open" type="button"
                                class="mt-3 text-xs font-semibold w-full"
                                style="background:none;border:none;cursor:pointer;padding:0;color:var(--color-brand)">
                            <span x-show="!open">+ {{ isFr ? 'Voir les ' ~ dateHidden|length ~ ' autres' : (isEs ? 'Ver los ' ~ dateHidden|length ~ ' más' : (isPt ? 'Ver os ' ~ dateHidden|length ~ ' outros' : (isDe ? dateHidden|length ~ ' weitere anzeigen' : (isIt ? 'Vedi altri ' ~ dateHidden|length : 'See ' ~ dateHidden|length ~ ' more')))) }}</span>
                            <span x-show="open" style="display:none">▲ {{ isFr ? 'Réduire' : (isEs ? 'Mostrar menos' : (isPt ? 'Mostrar menos' : (isDe ? 'Weniger' : (isIt ? 'Mostra meno' : 'Show less')))) }}</span>
                        </button>
                        {% endif %}
                    </div>
                    {% endif %}
                {% else %}
                    <p class="text-sm italic" style="color:var(--color-muted)">{{ 'play.reveal.not_revealed'|trans }}</p>
                {% endif %}
            </div>
            {% endif %}

            {% if hasWeight %}
            <div class="card text-center py-6" style="position:relative;overflow:hidden" x-data="{ revealed: false, dissolving: false }">
                <div class="mbg-cover" x-show="!revealed" @click="dissolving=true; const _r=$el.getBoundingClientRect(); $el.style.setProperty('--ox',((event.clientX-_r.left)/_r.width*100).toFixed(1)+'%'); $el.style.setProperty('--oy',((event.clientY-_r.top)/_r.height*100).toFixed(1)+'%'); $el.classList.add('mbg-dissolving'); setTimeout(()=>{revealed=true},1400)">
                    <em class="mbg-sp mbg-sp-1">✦</em><em class="mbg-sp mbg-sp-2">✧</em>
                    <em class="mbg-sp mbg-sp-3">✦</em><em class="mbg-sp mbg-sp-4">✧</em>
                    <em class="mbg-sp mbg-sp-5">✦</em><em class="mbg-sp mbg-sp-6">✧</em>
                    <em class="mbg-sp mbg-sp-7">✦</em><em class="mbg-sp mbg-sp-8">✧</em>
                    <p style="font-size:1rem;font-weight:800;color:#fff;margin:0 0 0.5rem;text-align:center;line-height:1.35;text-shadow:0 1px 4px rgba(0,0,0,0.18)">
                        {{ isFr ? 'Combien pesait bébé ?' : (isEs ? '¿Cuánto pesaba el bebé?' : (isPt ? 'Quanto pesava o bebé?' : (isDe ? 'Wie schwer war das Baby?' : (isIt ? 'Quanto pesava il bebè?' : 'How much did baby weigh?')))) }}
                    </p>
                    <p style="font-size:0.75rem;font-weight:600;color:rgba(255,248,235,0.8);margin:0;text-align:center">
                        {{ isFr ? 'Appuyer pour révéler' : (isEs ? 'Toca para revelar' : (isPt ? 'Toque para revelar' : (isDe ? 'Tippen zum Enthüllen' : (isIt ? 'Tocca per rivelare' : 'Tap to reveal')))) }} ✦
                    </p>
                </div>
                <div class="mbg-fog" x-show="!revealed" :class="{ 'mbg-lifting': dissolving }"></div>
                <p class="text-xs font-bold uppercase tracking-widest mb-4"
                   style="color:var(--color-muted)">{{ 'play.reveal.winners_weight'|trans }}</p>
                {% if game.answerWeight %}
                    <p class="text-xl font-bold mb-4" style="color:var(--color-ink)">
                        {{ (game.answerWeight / 1000)|number_format(3, '.', '') }} kg
                    </p>
                    {% if winners.weight is defined and winners.weight|length > 0 %}
                    {% set weightVisible = winners.weight|slice(0, 5) %}
                    {% set weightHidden  = winners.weight|slice(5) %}
                    <div x-data="{ open: false }">
                        <div class="space-y-2">
                            {% for item in weightVisible %}
                            <div class="rounded-lg px-3 py-3 text-center"
                                 style="background-color:var(--color-cream)">
                                <div class="text-xs font-bold mb-0.5" style="color:var(--color-muted)">{{ loop.index }}</div>
                                <div class="text-sm font-bold" style="color:var(--color-ink)">{{ item.guess.playerName }}</div>
                                <div class="text-xs font-semibold" style="margin-top:0.125rem;color:{{ item.diff == 0 ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                                    {% if item.diff == 0 %}{{ isFr ? 'Exact !' : (isEs ? '¡Exacto!' : (isPt ? 'Exato!' : (isDe ? 'Genau!' : (isIt ? 'Esatto!' : 'Exact!')))) }}
                                    {% elseif item.diff < 1000 %}{{ item.diff }} g
                                    {% else %}{{ (item.diff / 1000)|number_format(2, '.', '') }} kg
                                    {% endif %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        {% if weightHidden|length > 0 %}
                        <div class="space-y-2 mt-2" x-show="open" style="display:none">
                            {% for item in weightHidden %}
                            <div class="rounded-lg px-3 py-3 text-center"
                                 style="background-color:var(--color-cream)">
                                <div class="text-xs font-bold mb-0.5" style="color:var(--color-muted)">{{ loop.index + 5 }}</div>
                                <div class="text-sm font-bold" style="color:var(--color-ink)">{{ item.guess.playerName }}</div>
                                <div class="text-xs font-semibold" style="margin-top:0.125rem;color:{{ item.diff == 0 ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                                    {% if item.diff == 0 %}{{ isFr ? 'Exact !' : (isEs ? '¡Exacto!' : (isPt ? 'Exato!' : (isDe ? 'Genau!' : (isIt ? 'Esatto!' : 'Exact!')))) }}
                                    {% elseif item.diff < 1000 %}{{ item.diff }} g
                                    {% else %}{{ (item.diff / 1000)|number_format(2, '.', '') }} kg
                                    {% endif %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        <button @click="open = !open" type="button"
                                class="mt-3 text-xs font-semibold w-full"
                                style="background:none;border:none;cursor:pointer;padding:0;color:var(--color-brand)">
                            <span x-show="!open">+ {{ isFr ? 'Voir les ' ~ weightHidden|length ~ ' autres' : (isEs ? 'Ver los ' ~ weightHidden|length ~ ' más' : (isPt ? 'Ver os ' ~ weightHidden|length ~ ' outros' : (isDe ? weightHidden|length ~ ' weitere anzeigen' : (isIt ? 'Vedi altri ' ~ weightHidden|length : 'See ' ~ weightHidden|length ~ ' more')))) }}</span>
                            <span x-show="open" style="display:none">▲ {{ isFr ? 'Réduire' : (isEs ? 'Mostrar menos' : (isPt ? 'Mostrar menos' : (isDe ? 'Weniger' : (isIt ? 'Mostra meno' : 'Show less')))) }}</span>
                        </button>
                        {% endif %}
                    </div>
                    {% endif %}
                {% else %}
                    <p class="text-sm italic" style="color:var(--color-muted)">{{ 'play.reveal.not_revealed'|trans }}</p>
                {% endif %}
            </div>
            {% endif %}

            {% if hasHeight %}
            <div class="card text-center py-6" style="position:relative;overflow:hidden" x-data="{ revealed: false, dissolving: false }">
                <div class="mbg-cover" x-show="!revealed" @click="dissolving=true; const _r=$el.getBoundingClientRect(); $el.style.setProperty('--ox',((event.clientX-_r.left)/_r.width*100).toFixed(1)+'%'); $el.style.setProperty('--oy',((event.clientY-_r.top)/_r.height*100).toFixed(1)+'%'); $el.classList.add('mbg-dissolving'); setTimeout(()=>{revealed=true},1400)">
                    <em class="mbg-sp mbg-sp-1">✦</em><em class="mbg-sp mbg-sp-2">✧</em>
                    <em class="mbg-sp mbg-sp-3">✦</em><em class="mbg-sp mbg-sp-4">✧</em>
                    <em class="mbg-sp mbg-sp-5">✦</em><em class="mbg-sp mbg-sp-6">✧</em>
                    <em class="mbg-sp mbg-sp-7">✦</em><em class="mbg-sp mbg-sp-8">✧</em>
                    <p style="font-size:1rem;font-weight:800;color:#fff;margin:0 0 0.5rem;text-align:center;line-height:1.35;text-shadow:0 1px 4px rgba(0,0,0,0.18)">
                        {{ isFr ? 'Et quelle était sa taille ?' : (isEs ? '¿Y cuánto medía?' : (isPt ? 'E qual era o seu tamanho?' : (isDe ? 'Und wie groß war es?' : (isIt ? 'E quanto misurava?' : 'How tall was baby?')))) }}
                    </p>
                    <p style="font-size:0.75rem;font-weight:600;color:rgba(255,248,235,0.8);margin:0;text-align:center">
                        {{ isFr ? 'Appuyer pour révéler' : (isEs ? 'Toca para revelar' : (isPt ? 'Toque para revelar' : (isDe ? 'Tippen zum Enthüllen' : (isIt ? 'Tocca per rivelare' : 'Tap to reveal')))) }} ✦
                    </p>
                </div>
                <div class="mbg-fog" x-show="!revealed" :class="{ 'mbg-lifting': dissolving }"></div>
                <p class="text-xs font-bold uppercase tracking-widest mb-4"
                   style="color:var(--color-muted)">{{ 'play.reveal.winners_height'|trans }}</p>
                {% if game.answerHeight %}
                    <p class="text-xl font-bold mb-4" style="color:var(--color-ink)">
                        {{ (game.answerHeight / 10)|number_format(1, '.', '') }} cm
                    </p>
                    {% if winners.height is defined and winners.height|length > 0 %}
                    {% set heightVisible = winners.height|slice(0, 5) %}
                    {% set heightHidden  = winners.height|slice(5) %}
                    <div x-data="{ open: false }">
                        <div class="space-y-2">
                            {% for item in heightVisible %}
                            <div class="rounded-lg px-3 py-3 text-center"
                                 style="background-color:var(--color-cream)">
                                <div class="text-xs font-bold mb-0.5" style="color:var(--color-muted)">{{ loop.index }}</div>
                                <div class="text-sm font-bold" style="color:var(--color-ink)">{{ item.guess.playerName }}</div>
                                <div class="text-xs font-semibold" style="margin-top:0.125rem;color:{{ item.diff == 0 ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                                    {% if item.diff == 0 %}{{ isFr ? 'Exact !' : (isEs ? '¡Exacto!' : (isPt ? 'Exato!' : (isDe ? 'Genau!' : (isIt ? 'Esatto!' : 'Exact!')))) }}
                                    {% elseif item.diff < 10 %}{{ item.diff }} mm
                                    {% else %}{{ (item.diff / 10)|number_format(1, '.', '') }} cm
                                    {% endif %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        {% if heightHidden|length > 0 %}
                        <div class="space-y-2 mt-2" x-show="open" style="display:none">
                            {% for item in heightHidden %}
                            <div class="rounded-lg px-3 py-3 text-center"
                                 style="background-color:var(--color-cream)">
                                <div class="text-xs font-bold mb-0.5" style="color:var(--color-muted)">{{ loop.index + 5 }}</div>
                                <div class="text-sm font-bold" style="color:var(--color-ink)">{{ item.guess.playerName }}</div>
                                <div class="text-xs font-semibold" style="margin-top:0.125rem;color:{{ item.diff == 0 ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                                    {% if item.diff == 0 %}{{ isFr ? 'Exact !' : (isEs ? '¡Exacto!' : (isPt ? 'Exato!' : (isDe ? 'Genau!' : (isIt ? 'Esatto!' : 'Exact!')))) }}
                                    {% elseif item.diff < 10 %}{{ item.diff }} mm
                                    {% else %}{{ (item.diff / 10)|number_format(1, '.', '') }} cm
                                    {% endif %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        <button @click="open = !open" type="button"
                                class="mt-3 text-xs font-semibold w-full"
                                style="background:none;border:none;cursor:pointer;padding:0;color:var(--color-brand)">
                            <span x-show="!open">+ {{ isFr ? 'Voir les ' ~ heightHidden|length ~ ' autres' : (isEs ? 'Ver los ' ~ heightHidden|length ~ ' más' : (isPt ? 'Ver os ' ~ heightHidden|length ~ ' outros' : (isDe ? heightHidden|length ~ ' weitere anzeigen' : (isIt ? 'Vedi altri ' ~ heightHidden|length : 'See ' ~ heightHidden|length ~ ' more')))) }}</span>
                            <span x-show="open" style="display:none">▲ {{ isFr ? 'Réduire' : (isEs ? 'Mostrar menos' : (isPt ? 'Mostrar menos' : (isDe ? 'Weniger' : (isIt ? 'Mostra meno' : 'Show less')))) }}</span>
                        </button>
                        {% endif %}
                    </div>
                    {% endif %}
                {% else %}
                    <p class="text-sm italic" style="color:var(--color-muted)">{{ 'play.reveal.not_revealed'|trans }}</p>
                {% endif %}
            </div>
            {% endif %}

        </div>

    {% endif %}

    {# ── CTA ──────────────────────────────────────────────────── #}
    {% set homeUrl   = url('app_home', {'_locale': app.request.locale}) %}
    {% set waText    = 'play.reveal.cta_whatsapp'|trans ~ ' ' ~ homeUrl %}
    {% set emailBody = 'play.reveal.cta_whatsapp'|trans ~ "\n\n" ~ homeUrl %}

    <div class="mt-4"
         id="share-page"
         data-share-url="{{ homeUrl }}"
         data-share-title="MyBabyGuessr"
         data-copy-label="{{ 'games.share.btn_copy'|trans|e('html_attr') }}"
         data-copied-label="{{ 'games.share.btn_copied'|trans|e('html_attr') }}">

        {# ── En-tête ── #}
        <div class="text-center mb-6">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full mb-4"
                 style="background-color: rgba(196,113,74,0.12)">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                          stroke="var(--color-brand)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2" style="color: var(--color-ink)">
                {{ 'play.reveal.cta_heading'|trans }}
            </h2>
            <p class="text-sm leading-relaxed max-w-sm mx-auto" style="color: var(--color-muted)">
                {{ 'play.reveal.cta_desc'|trans }}
            </p>
        </div>

        {# ── Identité de l'app ── #}
        <div class="card mb-4 text-center py-5">
            <img src="{{ asset('images/logo-mybabyguessr.png') }}" alt="MyBabyGuessr"
                 width="64" height="64" loading="lazy"
                 class="mx-auto mb-3 rounded-xl"
                 style="width:4rem;height:4rem;object-fit:contain;display:block">
            <p class="text-xs font-bold uppercase tracking-widest mb-1"
               style="color: var(--color-muted)">MyBabyGuessr</p>
            <p class="text-base font-bold" style="color: var(--color-ink)">
                {{ isFr ? 'Gratuit · 2 minutes' : (isEs ? 'Gratis · 2 minutos' : (isPt ? 'Grátis · 2 minutos' : (isDe ? 'Kostenlos · 2 Minuten' : (isIt ? 'Gratuito · 2 minuti' : 'Free · 2 minutes')))) }}
            </p>
        </div>

        {# ── Lien + copier ── #}
        <div class="card mb-4">
            <p class="text-xs font-bold uppercase tracking-widest mb-2"
               style="color: var(--color-muted)">{{ 'games.share.link_label'|trans }}</p>
            <div class="flex items-center gap-2">
                <input id="share-url-input" type="text" readonly value="{{ homeUrl }}"
                       class="flex-1 text-sm px-3 py-2.5 rounded-lg border-0 outline-none"
                       style="background-color: var(--color-cream); color: var(--color-ink); font-family: monospace; min-width: 0">
                <button id="copy-link-btn" type="button"
                        class="btn btn-primary shrink-0 text-sm px-4 py-2.5"
                        aria-label="{{ 'games.share.btn_copy'|trans }}">
                    <svg id="copy-icon" class="w-4 h-4 inline-block mr-1.5 shrink-0" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="9" y="9" width="13" height="13" rx="2"/>
                        <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                    </svg>
                    <span id="copy-label">{{ 'games.share.btn_copy'|trans }}</span>
                </button>
            </div>
        </div>

        {# ── Bouton natif (Web Share API) ── #}
        <div id="mobile-share" class="hidden mb-2">
            <button id="native-share-btn" class="btn btn-primary w-full text-base py-3.5">
                <svg class="w-5 h-5 inline-block mr-2 shrink-0" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                    <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                </svg>
                {{ 'play.reveal.cta_btn'|trans }}
            </button>
            <p class="text-center text-xs mt-2 mb-3" style="color: var(--color-muted)">{{ 'games.share.or_via'|trans }}</p>
        </div>

        {# ── WhatsApp + Email + Facebook ── #}
        <div class="flex flex-col gap-3 sm:grid sm:grid-cols-3 mb-4">
            <a href="https://wa.me/?text={{ waText|url_encode }}"
               target="_blank" rel="noopener noreferrer"
               class="btn btn-primary flex items-center justify-center gap-2 text-sm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                {{ 'games.share.btn_whatsapp'|trans }}
            </a>
            <a href="mailto:?subject={{ 'play.reveal.cta_email_subject'|trans|url_encode }}&body={{ emailBody|url_encode }}"
               class="btn btn-secondary flex items-center justify-center gap-2 text-sm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
                {{ 'games.share.btn_email'|trans }}
            </a>
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ homeUrl|url_encode }}"
               target="_blank" rel="noopener noreferrer"
               class="btn btn-secondary flex items-center justify-center gap-2 text-sm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                {{ 'games.share.btn_facebook'|trans }}
            </a>
        </div>

        <p class="text-center text-sm" style="color: var(--color-muted)">
            <a href="{{ path('app_home', {'_locale': app.request.locale}) }}"
               style="color: var(--color-muted); text-decoration: underline; text-underline-offset: 2px">
                {{ 'play.reveal.cta_secondary'|trans }}
            </a>
        </p>

    </div>

</div>
{% endblock %}
