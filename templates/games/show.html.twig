{% extends 'base.html.twig' %}
{% block title %}{{ game.displayTitle }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% set locale = app.request.locale %}
{% set dateFormat = locale == 'en' ? 'm/d/Y' : (locale == 'de' ? 'd.m.Y' : 'd/m/Y') %}
{% set isEsOrPt = locale == 'es' or locale == 'pt' %}
{% set isIt = locale == 'it' %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12" style="position:relative">

    <img src="{{ asset('images/illustration/papillon2.png') }}" alt="" aria-hidden="true"
         style="position:absolute;top:0;right:0;width:48px;opacity:0.70;pointer-events:none;z-index:0">
    <img src="{{ asset('images/illustration/etoile.png') }}" alt="" aria-hidden="true"
         style="position:absolute;top:0;left:0;width:39px;opacity:0.65;pointer-events:none;z-index:0">
    <img src="{{ asset('images/illustration/singe.png') }}" alt="" aria-hidden="true"
         style="position:absolute;bottom:0;right:0;width:65px;opacity:0.72;pointer-events:none;z-index:0">

    {# ── Retour ───────────────────────────────────────────────── #}
    <a href="{{ path('app_dashboard', {'_locale': app.request.locale}) }}"
       class="inline-flex items-center gap-1 text-sm font-bold mb-8 hover:underline"
       style="color: var(--color-muted); text-decoration: none">
        &larr; {{ 'games.new.back'|trans }}
    </a>

    {# ── En-tête ──────────────────────────────────────────────── #}
    <div class="card-panel mb-6">

        {% if game.image %}
        <div style="height:11rem;overflow:hidden">
            <img src="{{ asset(game.image) }}" alt="{{ game.displayTitle }}"
                 style="width:100%;height:100%;object-fit:cover;display:block">
        </div>
        {% else %}
        <div style="height:11rem;overflow:hidden;background:rgba(196,113,74,0.06);display:flex;align-items:center;justify-content:center">
            <img src="{{ asset('images/logo-mybabyguessr.png') }}" alt="MyBabyGuessr"
                 style="height:5rem;width:auto;opacity:0.55">
        </div>
        {% endif %}

        <div class="flex items-start gap-4 px-5 sm:px-7 py-5">

            <div class="flex-1 min-w-0">
                <h1 class="text-2xl font-bold leading-tight" style="color: var(--color-ink)">
                    {{ game.displayTitle }}
                </h1>
                <p class="text-sm mt-1" style="color: var(--color-muted)">
                    {{ 'games.show.created_at'|trans }} {{ game.createdAt|date(dateFormat) }}
                    {% if game.dueDate %}
                    &nbsp;·&nbsp; {{ 'games.show.due_date_label'|trans }}
                    <span class="font-semibold" style="color: var(--color-ink)">{{ game.dueDate|date(dateFormat) }}</span>
                    {% endif %}
                </p>
                <p class="text-sm font-semibold mt-0.5" style="color: var(--color-brand)">
                    {{ 'games.show.players_count'|trans({'%count%': stats.total}) }}
                </p>
            </div>

            <div class="shrink-0 flex flex-col items-end gap-2"
                 x-data="{ confirm: false }">

                {% set statusStyles = {
                    'open':     'background-color: rgba(196,113,74,0.12); color: var(--color-brand)',
                    'closed':   'background-color: #f3f4f6; color: #6b7280',
                    'revealed': 'background-color: rgba(39,103,73,0.10); color: #276749'
                } %}
                <span class="text-sm font-bold px-3 py-1.5 rounded-full"
                      style="{{ statusStyles[game.status.value] }}">
                    {{ ('games.status.' ~ game.status.value)|trans }}
                </span>

                <a href="{{ path('app_game_share', {'_locale': app.request.locale, 'token': game.token}) }}"
                   class="btn btn-primary flex flex-col sm:flex-row items-center gap-0 sm:gap-1.5"
                   style="font-size:0.8125rem;padding:0.375rem 0.875rem">
                    <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                    </svg>
                    <span class="hidden sm:inline">{{ 'games.show.share_btn'|trans }}</span>
                    <span class="sm:hidden" style="font-size:0.6rem;line-height:1.3;margin-top:0.1rem">
                        {{ locale == 'fr' ? 'Partager' : (locale == 'es' ? 'Compartir' : (locale == 'pt' ? 'Partilhar' : (locale == 'de' ? 'Teilen' : (locale == 'it' ? 'Condividi' : 'Share')))) }}
                    </span>
                </a>

                <a href="{{ path('app_game_reveal', {'_locale': app.request.locale, 'token': game.token}) }}"
                   class="btn btn-secondary flex flex-col sm:flex-row items-center gap-0 sm:gap-1.5"
                   style="font-size:0.8125rem;padding:0.375rem 0.875rem">
                    <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                    </svg>
                    <span class="hidden sm:inline">
                        {% if game.status.value == 'revealed' %}
                            {{ 'games.reveal.btn_edit_short'|trans }}
                        {% else %}
                            {{ 'games.reveal.btn_reveal_short'|trans }}
                        {% endif %}
                    </span>
                    <span class="sm:hidden" style="font-size:0.6rem;line-height:1.3;margin-top:0.1rem">
                        {% if game.status.value == 'revealed' %}
                            {{ 'games.reveal.btn_edit_short'|trans }}
                        {% else %}
                            {{ 'games.reveal.btn_reveal_short'|trans }}
                        {% endif %}
                    </span>
                </a>

                {% if game.status.value != 'revealed' %}
                <button @click="confirm = true"
                        class="btn btn-secondary flex flex-col sm:flex-row items-center gap-0 sm:gap-1.5"
                        style="font-size:0.8125rem;padding:0.375rem 0.875rem">
                    {% if game.status.value == 'open' %}
                        <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        <span class="hidden sm:inline">{{ 'games.toggle.btn_close'|trans }}</span>
                        <span class="sm:hidden" style="font-size:0.6rem;line-height:1.3;margin-top:0.1rem">
                            {{ locale == 'fr' ? 'Fermer' : (locale == 'es' ? 'Cerrar' : (locale == 'pt' ? 'Fechar' : (locale == 'de' ? 'Schließen' : (locale == 'it' ? 'Chiudi' : 'Close')))) }}
                        </span>
                    {% else %}
                        <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="3" y="11" width="18" height="11" rx="2"/>
                            <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
                        </svg>
                        <span class="hidden sm:inline">{{ 'games.toggle.btn_open'|trans }}</span>
                        <span class="sm:hidden" style="font-size:0.6rem;line-height:1.3;margin-top:0.1rem">
                            {{ locale == 'fr' ? 'Ouvrir' : (locale == 'es' or locale == 'pt' ? 'Abrir' : (locale == 'de' ? 'Öffnen' : (locale == 'it' ? 'Apri' : 'Open'))) }}
                        </span>
                    {% endif %}
                </button>
                {% endif %}

                {# ── Modale de confirmation ──────────────────────── #}
                <div x-show="confirm"
                     x-cloak
                     x-transition:enter="transition ease-out duration-150"
                     x-transition:enter-start="opacity-0"
                     x-transition:enter-end="opacity-100"
                     class="fixed inset-0"
                     style="background: rgba(44,31,21,0.55); z-index: 40"
                     @click.self="confirm = false">
                </div>

                <div x-show="confirm"
                     x-cloak
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 scale-95"
                     x-transition:enter-end="opacity-100 scale-100"
                     class="fixed inset-0 flex items-center justify-center"
                     style="z-index: 50; padding: 1rem"
                     @keydown.escape.window="confirm = false">

                    <div class="card-panel w-full max-w-sm px-6 py-6">
                        <h2 class="text-lg font-bold mb-3" style="color: var(--color-ink)">
                            {% if game.status.value == 'open' %}
                                {{ 'games.toggle.confirm_close_title'|trans }}
                            {% else %}
                                {{ 'games.toggle.confirm_open_title'|trans }}
                            {% endif %}
                        </h2>
                        <p class="text-sm leading-relaxed mb-6" style="color: var(--color-muted)">
                            {% if game.status.value == 'open' %}
                                {{ 'games.toggle.confirm_close_body'|trans }}
                            {% else %}
                                {{ 'games.toggle.confirm_open_body'|trans }}
                            {% endif %}
                        </p>
                        <div class="flex gap-3">
                            <button @click="confirm = false"
                                    class="btn btn-secondary flex-1"
                                    style="min-height:2.5rem;font-size:0.875rem">
                                {{ 'games.toggle.confirm_cancel'|trans }}
                            </button>
                            <form method="POST"
                                  action="{{ path('app_game_toggle_status', {'_locale': app.request.locale, 'token': game.token}) }}"
                                  class="flex-1">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('game_toggle_' ~ game.token) }}">
                                <button type="submit"
                                        class="btn btn-primary w-full"
                                        style="min-height:2.5rem;font-size:0.875rem">
                                    {{ 'games.toggle.confirm_yes'|trans }}
                                </button>
                            </form>
                        </div>
                    </div>

                </div>

            </div>

        </div>

    </div>

    {# ══════════════════════════════════════════════════════════ #}
    {# ── Onglets ─────────────────────────────────────────────── #}
    {# ══════════════════════════════════════════════════════════ #}

    {% set firstTab = 'overview' %}
    <div x-data="{ tab: '{{ firstTab }}' }">

        {# Nav onglets — underline style + scroll mobile #}
        {% set tabs = [['overview', 'games.show.tab_overview'|trans]] %}
        {% if game.isGuessGender() %}{% set tabs = tabs|merge([['gender',  'games.show.tab_gender'|trans]]) %}{% endif %}
        {% if game.isGuessName() %}  {% set tabs = tabs|merge([['name',    'games.show.tab_name'|trans]])   %}{% endif %}
        {% if game.isGuessDate() %}  {% set tabs = tabs|merge([['date',    'games.show.tab_date'|trans]])   %}{% endif %}
        {% if game.isGuessWeight() %}{% set tabs = tabs|merge([['weight',  'games.show.tab_weight'|trans]])  %}{% endif %}
        {% if game.isGuessHeight() %}{% set tabs = tabs|merge([['height',  'games.show.tab_height'|trans]])  %}{% endif %}
        {% set tabs = tabs|merge([['players', 'games.show.tab_players'|trans]]) %}

        <div class="relative mb-6">
            {# Dégradé indicateur — visible uniquement sur mobile #}
            <div class="absolute right-0 top-0 bottom-0.5 w-10 pointer-events-none sm:hidden"
                 style="background: linear-gradient(to right, rgba(255,255,255,0), #fff); z-index: 1"></div>

            <div class="flex overflow-x-auto"
                 x-ref="tabbar"
                 x-init="$watch('tab', () => {
                     $nextTick(() => {
                         const el = $refs.tabbar.querySelector('[data-active=\'1\']');
                         if (el) el.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
                     });
                 })"
                 style="border-bottom: 2px solid var(--color-line); scrollbar-width: none;">

                {% for tabItem in tabs %}
                <button @click="tab = '{{ tabItem[0] }}'"
                        :data-active="tab === '{{ tabItem[0] }}' ? '1' : '0'"
                        class="px-4 sm:px-5 py-3.5 text-sm font-semibold shrink-0 transition-colors -mb-0.5"
                        :style="tab === '{{ tabItem[0] }}'
                            ? 'color:var(--color-brand);border-bottom:2px solid var(--color-brand)'
                            : 'color:var(--color-muted);border-bottom:2px solid transparent'">
                    {{ tabItem[1] }}
                </button>
                {% endfor %}

            </div>
        </div>

        {# ── Onglet Synthèse ──────────────────────────────────── #}
        <div x-show="tab === 'overview'"
             x-transition:enter="transition ease-out duration-150"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100">

            {% if stats.total == 0 %}
            <div class="card text-center py-12">
                <p class="text-4xl font-bold mb-1" style="color: var(--color-brand)">0</p>
                <p class="text-sm mb-6" style="color: var(--color-muted)">{{ 'games.show.no_data'|trans }}</p>
                <a href="{{ path('app_game_share', {'_locale': app.request.locale, 'token': game.token}) }}"
                   class="btn btn-primary inline-flex items-center gap-2">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                    </svg>
                    {{ 'games.show.share_btn'|trans }}
                </a>
            </div>

            {% else %}

            {# Stat joueurs + mini-résumés par catégorie #}
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">

                {# Joueurs #}
                <div class="col-span-2 sm:col-span-1 card text-center py-6">
                    <p class="text-4xl font-bold" style="color: var(--color-brand)">{{ stats.total }}</p>
                    <p class="text-xs font-semibold uppercase tracking-wider mt-1" style="color: var(--color-muted)">
                        {{ locale == 'fr' ? 'joueurs' : (locale == 'es' ? 'jugadores' : (locale == 'pt' ? 'jogadores' : (locale == 'de' ? 'Spieler' : (locale == 'it' ? 'giocatori' : 'players')))) }}
                    </p>
                </div>

                {% if stats.gender is defined %}
                <div class="card flex flex-col items-center justify-center px-4 py-4 cursor-pointer text-center"
                     @click="tab = 'gender'">
                    <p class="text-xs font-bold uppercase tracking-wider mb-3" style="color: var(--color-muted)">
                        {{ 'games.show.tab_gender'|trans }}
                    </p>
                    <div class="flex items-center justify-center w-full gap-0">
                        <div class="flex-1 flex flex-col items-center">
                            <span class="text-xl font-bold" style="color:var(--color-brand)">{{ stats.gender.boy_pct }}%</span>
                            <span class="text-xs mt-0.5" style="color:var(--color-muted)">{{ 'games.show.gender_boy'|trans }}</span>
                        </div>
                        <div class="shrink-0 w-px h-8 self-center" style="background-color:var(--color-line)"></div>
                        <div class="flex-1 flex flex-col items-center">
                            <span class="text-xl font-bold" style="color:var(--color-accent)">{{ stats.gender.girl_pct }}%</span>
                            <span class="text-xs mt-0.5" style="color:var(--color-muted)">{{ 'games.show.gender_girl'|trans }}</span>
                        </div>
                    </div>
                </div>
                {% endif %}

                {% if stats.date is defined %}
                <div class="card flex flex-col items-center justify-center px-4 py-4 cursor-pointer text-center"
                     @click="tab = 'date'">
                    <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color: var(--color-muted)">
                        {{ 'games.show.tab_date'|trans }}
                    </p>
                    <p class="text-xl font-bold" style="color: var(--color-ink)">
                        {{ stats.date.avg_date|date(dateFormat) }}
                    </p>
                    <p class="text-xs mt-0.5" style="color: var(--color-muted)">
                        {{ 'games.show.date_avg'|trans }}
                    </p>
                </div>
                {% endif %}

                {% if stats.name is defined %}
                <div class="card flex flex-col items-center justify-center px-4 py-4 cursor-pointer text-center"
                     @click="tab = 'name'">
                    <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color: var(--color-muted)">
                        {{ 'games.show.tab_name'|trans }}
                    </p>
                    {% if stats.name.top_count > 1 %}
                        <p class="text-xl font-bold" style="color: var(--color-ink)">{{ stats.name.top }}</p>
                        <p class="text-xs mt-0.5" style="color: var(--color-brand)">× {{ stats.name.top_count }} — {{ 'games.show.name_top_label'|trans }}</p>
                    {% else %}
                        <p class="text-xl font-bold" style="color: var(--color-ink)">{{ stats.name.unique_count }}</p>
                        <p class="text-xs mt-0.5" style="color: var(--color-muted)">{{ 'games.show.name_unique_count'|trans({'%count%': stats.name.unique_count}) }}</p>
                    {% endif %}
                </div>
                {% endif %}

                {% if stats.weight is defined %}
                <div class="card flex flex-col items-center justify-center px-4 py-4 cursor-pointer text-center"
                     @click="tab = 'weight'">
                    <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color: var(--color-muted)">
                        {{ 'games.show.tab_weight'|trans }}
                    </p>
                    <p class="text-xl font-bold" style="color: var(--color-ink)">
                        {{ (stats.weight.avg / 1000)|round(1) }} kg
                    </p>
                    <p class="text-xs mt-0.5" style="color: var(--color-muted)">
                        {{ 'games.show.weight_avg'|trans }}
                    </p>
                </div>
                {% endif %}

                {% if stats.height is defined %}
                <div class="card flex flex-col items-center justify-center px-4 py-4 cursor-pointer text-center"
                     @click="tab = 'height'">
                    <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color: var(--color-muted)">
                        {{ 'games.show.tab_height'|trans }}
                    </p>
                    <p class="text-xl font-bold" style="color: var(--color-ink)">
                        {{ (stats.height.avg / 10)|round(1) }} cm
                    </p>
                    <p class="text-xs mt-0.5" style="color: var(--color-muted)">
                        {{ 'games.show.height_avg'|trans }}
                    </p>
                </div>
                {% endif %}

            </div>
            {% endif %}

            {# ── Palmarès post-reveal ──────────────────────── #}
            {% if game.status.value == 'revealed' and stats.total > 0 %}
            <div class="card mb-4 px-5 py-5">
                <div class="flex items-center justify-between mb-4">
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--color-brand)">
                        {{ locale == 'fr' ? 'Palmarès' : (locale == 'es' or locale == 'pt' ? 'Resultados' : (locale == 'de' ? 'Ergebnisse' : (locale == 'it' ? 'Risultati' : 'Results'))) }}
                    </p>
                    <a href="{{ url('app_game_reveal_public', {'_locale': app.request.locale, 'slug': game.slug, 'token': game.token}) }}"
                       class="text-xs font-semibold hover:underline"
                       style="color:var(--color-brand)">
                        {{ locale == 'fr' ? 'Voir la page publique →' : (locale == 'es' ? 'Ver la página pública →' : (locale == 'pt' ? 'Ver a página pública →' : (locale == 'de' ? 'Öffentliche Seite →' : (locale == 'it' ? 'Vedi pagina pubblica →' : 'See public page →')))) }}
                    </a>
                </div>
                {% if game.isGuessGender() and game.answerGender %}
                <div class="flex items-center justify-between py-2.5" style="border-bottom:1px solid var(--color-line)">
                    <span class="text-xs font-semibold uppercase tracking-wider" style="color:var(--color-muted)">{{ 'games.show.tab_gender'|trans }}</span>
                    <div class="flex items-center gap-3">
                        <span class="text-sm font-bold" style="color:var(--color-ink)">
                            {{ game.answerGender.value == 'boy' ? 'games.show.gender_boy'|trans : 'games.show.gender_girl'|trans }}
                        </span>
                        {% if stats.gender.winner_names is defined and stats.gender.winner_names|length > 0 %}
                        <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style="background:rgba(196,113,74,0.12);color:var(--color-brand)">
                            {{ stats.gender.winner_names[0] }}{% if stats.gender.winner_names|length > 1 %} +{{ stats.gender.winner_names|length - 1 }}{% endif %}
                        </span>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
                {% if game.isGuessName() and game.answerName %}
                <div class="flex items-center justify-between py-2.5" style="border-bottom:1px solid var(--color-line)">
                    <span class="text-xs font-semibold uppercase tracking-wider" style="color:var(--color-muted)">{{ 'games.show.tab_name'|trans }}</span>
                    <div class="flex items-center gap-3">
                        <span class="text-sm font-bold" style="color:var(--color-ink)">{{ game.answerName }}</span>
                        {% if stats.name.winner_names is defined and stats.name.winner_names|length > 0 %}
                        <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style="background:rgba(196,113,74,0.12);color:var(--color-brand)">
                            {{ stats.name.winner_names[0] }}{% if stats.name.winner_names|length > 1 %} +{{ stats.name.winner_names|length - 1 }}{% endif %}
                        </span>
                        {% else %}
                        <span class="text-xs italic" style="color:var(--color-muted)">{{ locale == 'fr' ? 'Personne' : (locale == 'es' ? 'Nadie' : (locale == 'pt' ? 'Ninguém' : (locale == 'de' ? 'Niemand' : (locale == 'it' ? 'Nessuno' : 'No one')))) }}</span>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
                {% if game.isGuessDate() and game.answerDate and stats.date.sorted_by_diff is defined %}
                <div class="flex items-center justify-between py-2.5" style="border-bottom:1px solid var(--color-line)">
                    <span class="text-xs font-semibold uppercase tracking-wider" style="color:var(--color-muted)">{{ 'games.show.tab_date'|trans }}</span>
                    <div class="flex items-center gap-3">
                        <span class="text-sm font-bold" style="color:var(--color-ink)">{{ game.answerDate|date(dateFormat) }}</span>
                        <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style="background:rgba(196,113,74,0.12);color:var(--color-brand)">
                            {{ stats.date.sorted_by_diff[0].guess.playerName }}
                        </span>
                    </div>
                </div>
                {% endif %}
                {% if game.isGuessWeight() and game.answerWeight and stats.weight.sorted_by_diff is defined %}
                <div class="flex items-center justify-between py-2.5" style="border-bottom:1px solid var(--color-line)">
                    <span class="text-xs font-semibold uppercase tracking-wider" style="color:var(--color-muted)">{{ 'games.show.tab_weight'|trans }}</span>
                    <div class="flex items-center gap-3">
                        <span class="text-sm font-bold" style="color:var(--color-ink)">{{ (game.answerWeight / 1000)|number_format(3, '.', '') }} kg</span>
                        <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style="background:rgba(196,113,74,0.12);color:var(--color-brand)">
                            {{ stats.weight.sorted_by_diff[0].guess.playerName }}
                        </span>
                    </div>
                </div>
                {% endif %}
                {% if game.isGuessHeight() and game.answerHeight and stats.height.sorted_by_diff is defined %}
                <div class="flex items-center justify-between py-2.5">
                    <span class="text-xs font-semibold uppercase tracking-wider" style="color:var(--color-muted)">{{ 'games.show.tab_height'|trans }}</span>
                    <div class="flex items-center gap-3">
                        <span class="text-sm font-bold" style="color:var(--color-ink)">{{ (game.answerHeight / 10)|number_format(1, '.', '') }} cm</span>
                        <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style="background:rgba(196,113,74,0.12);color:var(--color-brand)">
                            {{ stats.height.sorted_by_diff[0].guess.playerName }}
                        </span>
                    </div>
                </div>
                {% endif %}
            </div>
            {% endif %}

        </div>

        {# ── Onglet Sexe ──────────────────────────────────────── #}
        {% if game.isGuessGender() %}
        <div x-show="tab === 'gender'"
             x-transition:enter="transition ease-out duration-150"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100">

            {% if not stats.gender is defined or stats.gender.total == 0 %}
            <div class="card text-center py-10 text-sm" style="color: var(--color-muted)">
                {{ 'games.show.no_data'|trans }}
            </div>
            {% else %}

            {# Barre duel #}
            <div class="card mb-4 px-6 py-6">
                <div class="flex items-end justify-between mb-4">
                    <div>
                        <p class="text-3xl font-bold" style="color:var(--color-brand)">{{ stats.gender.boy_pct }}%</p>
                        <p class="text-xs font-bold uppercase tracking-wider mt-1" style="color:var(--color-brand)">
                            {{ 'games.show.gender_boy'|trans }}
                            <span class="font-normal normal-case tracking-normal ml-1" style="color:var(--color-muted)">
                                ({{ stats.gender.boy }})
                            </span>
                        </p>
                    </div>
                    <div class="text-right">
                        <p class="text-3xl font-bold" style="color:var(--color-accent)">{{ stats.gender.girl_pct }}%</p>
                        <p class="text-xs font-bold uppercase tracking-wider mt-1" style="color:var(--color-accent)">
                            {{ 'games.show.gender_girl'|trans }}
                            <span class="font-normal normal-case tracking-normal ml-1" style="color:var(--color-muted)">
                                ({{ stats.gender.girl }})
                            </span>
                        </p>
                    </div>
                </div>
                <div class="flex h-4 rounded-full overflow-hidden">
                    {% if stats.gender.boy_pct > 0 %}
                    <div class="h-full" style="width:{{ stats.gender.boy_pct }}%;background-color:var(--color-brand)"></div>
                    {% endif %}
                    {% if stats.gender.girl_pct > 0 %}
                    <div class="h-full" style="width:{{ stats.gender.girl_pct }}%;background-color:var(--color-accent)"></div>
                    {% endif %}
                </div>
            </div>

            {# Deux camps #}
            {% set isBoyWinner  = game.status.value == 'revealed' and game.answerGender and game.answerGender.value == 'boy' %}
            {% set isGirlWinner = game.status.value == 'revealed' and game.answerGender and game.answerGender.value == 'girl' %}
            <div class="card-panel">
                {% if game.status.value == 'revealed' and game.answerGender and stats.gender.correct_count is defined %}
                <div class="px-5 py-3" style="border-bottom:1px solid var(--color-line);background:rgba(196,113,74,0.06)">
                    <p class="text-xs font-semibold" style="color:var(--color-brand)">
                        {{ locale == 'fr'
                            ? stats.gender.correct_count ~ ' joueur' ~ (stats.gender.correct_count > 1 ? 's' : '') ~ ' avaient bon (' ~ stats.gender.correct_pct ~ '%)'
                            : (locale == 'es'
                                ? stats.gender.correct_count ~ ' jugador' ~ (stats.gender.correct_count > 1 ? 'es' : '') ~ ' acertaron (' ~ stats.gender.correct_pct ~ '%)'
                                : (locale == 'pt'
                                    ? stats.gender.correct_count ~ ' jogador' ~ (stats.gender.correct_count > 1 ? 'es' : '') ~ ' acertaram (' ~ stats.gender.correct_pct ~ '%)'
                                    : (locale == 'de'
                                        ? stats.gender.correct_count ~ ' Spieler ' ~ (stats.gender.correct_count > 1 ? 'haben' : 'hat') ~ ' richtig getippt (' ~ stats.gender.correct_pct ~ '%)'
                                        : (locale == 'it'
                                            ? stats.gender.correct_count ~ ' giocator' ~ (stats.gender.correct_count > 1 ? 'i' : 'e') ~ ' hanno indovinato (' ~ stats.gender.correct_pct ~ '%)'
                                            : stats.gender.correct_count ~ ' player' ~ (stats.gender.correct_count > 1 ? 's' : '') ~ ' got it right (' ~ stats.gender.correct_pct ~ '%)')))) }}
                    </p>
                </div>
                {% endif %}
                <div style="display:grid;grid-template-columns:1fr 1fr">
                    <div class="px-5 py-4" style="border-right: 1px solid var(--color-line);{{ isBoyWinner ? '' : (isGirlWinner ? 'opacity:0.45' : '') }}">
                        <p class="text-xs font-bold uppercase tracking-wider mb-3"
                           style="color:{{ isBoyWinner ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                            {{ 'games.show.gender_boy'|trans }}
                            {% if isBoyWinner %} ✓{% endif %}
                        </p>
                        {% if stats.gender.boy == 0 %}
                            <p class="text-sm italic" style="color:var(--color-muted)">—</p>
                        {% else %}
                            {% for g in guesses %}
                            {% if g.guessGender and g.guessGender.value == 'boy' %}
                            <p class="text-sm py-1" style="color:var(--color-ink)">{{ g.playerName }}</p>
                            {% endif %}
                            {% endfor %}
                        {% endif %}
                    </div>
                    <div class="px-5 py-4" style="{{ isGirlWinner ? '' : (isBoyWinner ? 'opacity:0.45' : '') }}">
                        <p class="text-xs font-bold uppercase tracking-wider mb-3"
                           style="color:{{ isGirlWinner ? 'var(--color-accent)' : 'var(--color-muted)' }}">
                            {{ 'games.show.gender_girl'|trans }}
                            {% if isGirlWinner %} ✓{% endif %}
                        </p>
                        {% if stats.gender.girl == 0 %}
                            <p class="text-sm italic" style="color:var(--color-muted)">—</p>
                        {% else %}
                            {% for g in guesses %}
                            {% if g.guessGender and g.guessGender.value == 'girl' %}
                            <p class="text-sm py-1" style="color:var(--color-ink)">{{ g.playerName }}</p>
                            {% endif %}
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>

            {% endif %}
        </div>
        {% endif %}

        {# ── Onglet Prénom ────────────────────────────────────── #}
        {% if game.isGuessName() %}
        <div x-show="tab === 'name'"
             x-transition:enter="transition ease-out duration-150"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100">

            {% if game.nameMode is not null and game.nameMode.value == 'hints' %}

            {# ── Mode indices ── #}
            {% set answerNorm = game.answerName ? game.answerName|lower|trim : null %}

            {# Stat box révélation #}
            {% if game.status.value == 'revealed' and game.answerName %}
            {% set hintsWinners = [] %}
            {% for g in guesses %}{% if g.guessName is not null and g.guessName|lower|trim == answerNorm %}{% set hintsWinners = hintsWinners|merge([g.playerName]) %}{% endif %}{% endfor %}
            <div class="rounded-xl px-5 py-4 mb-4 flex items-center justify-between"
                 style="background:rgba(196,113,74,0.10)">
                <div>
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--color-brand)">
                        {{ locale == 'fr' ? 'Réponse' : (locale == 'es' ? 'Respuesta' : (locale == 'pt' ? 'Resposta' : (locale == 'de' ? 'Antwort' : (locale == 'it' ? 'Risposta' : 'Answer')))) }}
                    </p>
                    <p class="text-2xl font-bold mt-0.5" style="color:var(--color-ink)">{{ game.answerName }}</p>
                </div>
                <div class="text-right">
                    <p class="text-2xl font-bold" style="color:var(--color-brand)">{{ hintsWinners|length }}</p>
                    <p class="text-xs mt-0.5" style="color:var(--color-muted)">
                        {{ locale == 'fr' ? (hintsWinners|length > 1 ? 'ont trouvé' : 'a trouvé') : (locale == 'es' ? (hintsWinners|length > 1 ? 'acertaron' : 'acertó') : (locale == 'pt' ? (hintsWinners|length > 1 ? 'acertaram' : 'acertou') : (locale == 'de' ? (hintsWinners|length > 1 ? 'hatten recht' : 'hatte recht') : (locale == 'it' ? (hintsWinners|length > 1 ? 'hanno indovinato' : 'ha indovinato') : (hintsWinners|length > 1 ? 'found it' : 'found it'))))) }}
                    </p>
                </div>
            </div>
            {% endif %}

            {% if guesses|length == 0 %}
            <div class="card text-center py-10 text-sm" style="color:var(--color-muted)">
                {{ 'games.show.no_data'|trans }}
            </div>
            {% else %}

            <div class="card-panel" x-data="{ open: null }">

                {# Header #}
                <div class="px-5 py-3 flex items-center justify-between"
                     style="border-bottom:1px solid var(--color-line)">
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--color-muted)">
                        {{ locale == 'fr' ? 'Essais' : (locale == 'es' ? 'Intentos' : (locale == 'pt' ? 'Tentativas' : (locale == 'de' ? 'Versuche' : (locale == 'it' ? 'Tentativi' : 'Attempts')))) }}
                    </p>
                    {% if game.status.value == 'revealed' and game.answerName %}
                    <p class="text-xs font-semibold" style="color:var(--color-brand)">
                        {{ locale == 'fr' ? 'Réponse :' : (locale == 'es' ? 'Respuesta:' : (locale == 'pt' ? 'Resposta:' : (locale == 'de' ? 'Antwort:' : (locale == 'it' ? 'Risposta:' : 'Answer:')))) }}
                        <span class="font-bold" style="color:var(--color-ink)">{{ game.answerName }}</span>
                    </p>
                    {% endif %}
                </div>

                {# Accordéon par joueur #}
                {% for g in guesses %}
                {% if g.nameAttempt1 is not null %}
                {% set isWinner = answerNorm and g.guessName is not null and g.guessName|lower|trim == answerNorm and game.status.value == 'revealed' %}
                {% set nbEssais = g.nameHintsUsed %}
                <div style="{{ not loop.last ? 'border-bottom:1px solid var(--color-line)' : '' }}">

                    {# Row cliquable #}
                    <button @click="open = open === {{ loop.index }} ? null : {{ loop.index }}"
                            class="w-full flex items-center justify-between px-5 py-4 text-left transition-colors hover:bg-[#F8F3EE]"
                            style="{{ isWinner ? 'background:rgba(196,113,74,0.07)' : '' }}">
                        <span class="text-sm font-semibold" style="color:var(--color-ink)">
                            {{ g.playerName }}{% if isWinner %} ✓{% endif %}
                        </span>
                        <div class="flex items-center gap-2 shrink-0">
                            <span class="px-2.5 py-1 rounded-full text-xs font-bold"
                                  style="background:{{ isWinner ? 'rgba(196,113,74,0.15)' : 'var(--color-cream)' }};color:{{ isWinner ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                                {{ nbEssais }}{{ locale == 'fr' ? (nbEssais > 1 ? ' essais' : ' essai') : (locale == 'es' ? (nbEssais > 1 ? ' intentos' : ' intento') : (locale == 'pt' ? (nbEssais > 1 ? ' tentativas' : ' tentativa') : (locale == 'de' ? (nbEssais > 1 ? ' Versuche' : ' Versuch') : (locale == 'it' ? (nbEssais > 1 ? ' tentativi' : ' tentativo') : (nbEssais > 1 ? ' tries' : ' try'))))) }}
                            </span>
                            <svg class="w-4 h-4 shrink-0 transition-transform duration-200"
                                 :style="open === {{ loop.index }} ? 'transform:rotate(180deg)' : ''"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <polyline points="6 9 12 15 18 9"/>
                            </svg>
                        </div>
                    </button>

                    {# Détail tentatives #}
                    <div x-show="open === {{ loop.index }}"
                         x-transition:enter="transition ease-out duration-150"
                         x-transition:enter-start="opacity-0"
                         x-transition:enter-end="opacity-100"
                         class="px-5 pb-4 pt-2"
                         style="border-top:1px solid var(--color-line)">
                        {% set attempts = [g.nameAttempt1, g.nameAttempt2, g.nameAttempt3] %}
                        {% for attempt in attempts %}
                        {% if attempt is not null %}
                        {% set isCorrect = answerNorm and attempt|lower|trim == answerNorm %}
                        <div class="flex items-center gap-3 py-2">
                            <span class="text-xs font-bold shrink-0"
                                  style="width:4.5rem;color:var(--color-muted)">
                                {{ locale == 'fr' ? 'Essai' : (locale == 'es' ? 'Intento' : (locale == 'pt' ? 'Tentativa' : (locale == 'de' ? 'Versuch' : (locale == 'it' ? 'Tentativo' : 'Try')))) }} {{ loop.index }}
                            </span>
                            <span class="text-sm font-semibold"
                                  style="color:{{ isCorrect ? 'var(--color-brand)' : 'var(--color-ink)' }}">
                                {{ attempt }}{% if isCorrect %} ✓{% endif %}
                            </span>
                        </div>
                        {% endif %}
                        {% endfor %}
                    </div>

                </div>
                {% endif %}
                {% endfor %}

            </div>
            {% endif %}

            {% else %}

            {# Mode libre #}
            {% if not stats.name is defined or stats.name.freq is empty %}
            <div class="card text-center py-10 text-sm" style="color: var(--color-muted)">
                {{ 'games.show.no_data'|trans }}
            </div>
            {% else %}

            {# Prénoms suggérés plusieurs fois #}
            {% if stats.name.freq|first > 1 %}
            <div class="card-panel mb-4">
                <div class="px-5 py-4" style="border-bottom: 1px solid var(--color-line)">
                    <p class="text-xs font-bold uppercase tracking-wider" style="color: var(--color-muted)">
                        {{ 'games.show.name_popular'|trans }}
                    </p>
                </div>
                {% for name, count in stats.name.freq %}
                {% if count > 1 %}
                <div class="flex items-center justify-between px-5 py-4"
                     style="border-bottom: 1px solid var(--color-line)">
                    <span class="text-base font-bold" style="color: var(--color-ink)">{{ name }}</span>
                    <span class="px-3 py-1 rounded-full text-sm font-bold"
                          style="background-color: rgba(196,113,74,0.15); color: var(--color-brand)">
                        × {{ count }}
                    </span>
                </div>
                {% endif %}
                {% endfor %}
            </div>
            {% endif %}

            {# Toutes les réponses #}
            {% set nameAnswerNorm = game.answerName ? game.answerName|lower|trim : null %}
            <div class="card-panel">
                <div class="px-5 py-4 flex items-center justify-between" style="border-bottom: 1px solid var(--color-line)">
                    <p class="text-xs font-bold uppercase tracking-wider" style="color: var(--color-muted)">
                        {{ 'games.show.name_all'|trans }}
                    </p>
                    {% if game.status.value == 'revealed' and game.answerName %}
                    <p class="text-xs font-semibold" style="color:var(--color-brand)">
                        {{ locale == 'fr' ? 'Réponse :' : (locale == 'es' ? 'Respuesta:' : (locale == 'pt' ? 'Resposta:' : (locale == 'de' ? 'Antwort:' : (locale == 'it' ? 'Risposta:' : 'Answer:')))) }}
                        <span class="font-bold" style="color:var(--color-ink)">{{ game.answerName }}</span>
                    </p>
                    {% endif %}
                </div>
                {% for g in guesses %}
                {% if g.guessName %}
                {% set isNameWinner = nameAnswerNorm and g.guessName|lower|trim == nameAnswerNorm %}
                <div class="flex items-center justify-between px-5 py-3.5 text-sm"
                     style="border-bottom:1px solid var(--color-line);{{ isNameWinner ? 'background:rgba(196,113,74,0.07)' : '' }}">
                    <span style="color:{{ isNameWinner ? 'var(--color-ink)' : 'var(--color-muted)' }};font-weight:{{ isNameWinner ? '600' : 'normal' }}">
                        {{ g.playerName }}{% if isNameWinner %} ✓{% endif %}
                    </span>
                    <span class="font-semibold" style="color:{{ isNameWinner ? 'var(--color-brand)' : 'var(--color-ink)' }}">{{ g.guessName }}</span>
                </div>
                {% endif %}
                {% endfor %}
            </div>

            {% endif %}
            {% endif %}

        </div>
        {% endif %}

        {# ── Onglet Date ──────────────────────────────────────── #}
        {% if game.isGuessDate() %}
        <div x-show="tab === 'date'"
             x-transition:enter="transition ease-out duration-150"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100">

            {% if not stats.date is defined %}
            <div class="card text-center py-10 text-sm" style="color: var(--color-muted)">
                {{ 'games.show.no_data'|trans }}
            </div>
            {% else %}

            {# Stat boxes #}
            {% if stats.date.closest is defined %}
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
            {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
            {% endif %}
                <div class="rounded-xl p-5 text-center"
                     style="background-color:rgba(196,113,74,0.08)">
                    <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-muted)">
                        {{ 'games.show.date_earliest'|trans }}
                    </p>
                    <p class="text-xl font-bold" style="color:var(--color-ink)">
                        {{ stats.date.earliest.guessDate|date(dateFormat) }}
                    </p>
                    <p class="text-xs mt-1" style="color:var(--color-muted)">{{ stats.date.earliest.playerName }}</p>
                </div>
                <div class="rounded-xl p-5 text-center"
                     style="background-color:rgba(196,113,74,0.08)">
                    <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-muted)">
                        {{ 'games.show.date_latest'|trans }}
                    </p>
                    <p class="text-xl font-bold" style="color:var(--color-ink)">
                        {{ stats.date.latest.guessDate|date(dateFormat) }}
                    </p>
                    <p class="text-xs mt-1" style="color:var(--color-muted)">{{ stats.date.latest.playerName }}</p>
                </div>
                {% if stats.date.closest is defined %}
                <div class="rounded-xl p-5 text-center"
                     style="background-color:rgba(196,113,74,0.12)">
                    <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-brand)">
                        {{ 'games.show.date_closest'|trans }}
                    </p>
                    <p class="text-xl font-bold" style="color:var(--color-brand)">
                        {{ stats.date.closest.guessDate|date(dateFormat) }}
                    </p>
                    <p class="text-xs mt-1" style="color:var(--color-muted)">{{ stats.date.closest.playerName }}</p>
                </div>
                {% endif %}
            </div>

            {# Liste triée (par écart si révélé, par valeur sinon) #}
            {% if game.status.value == 'revealed' and game.answerDate and stats.date.sorted_by_diff is defined %}
            <div class="card-panel">
                <div class="px-5 py-3 flex items-center justify-between" style="border-bottom:1px solid var(--color-line)">
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--color-muted)">{{ locale == 'fr' ? 'Classement' : (locale == 'es' ? 'Clasificación' : (locale == 'pt' ? 'Classificação' : (locale == 'de' ? 'Rangliste' : (locale == 'it' ? 'Classifica' : 'Ranking')))) }}</p>
                    <p class="text-xs font-semibold" style="color:var(--color-brand)">
                        {{ locale == 'fr' ? 'Réponse :' : (locale == 'es' ? 'Respuesta:' : (locale == 'pt' ? 'Resposta:' : (locale == 'de' ? 'Antwort:' : (locale == 'it' ? 'Risposta:' : 'Answer:')))) }}
                        <span class="font-bold" style="color:var(--color-ink)">{{ game.answerDate|date(dateFormat) }}</span>
                    </p>
                </div>
                {% for item in stats.date.sorted_by_diff %}
                {% set diffDays = (item.diff / 86400)|round %}
                {% set isFirst = loop.first %}
                <div class="flex justify-between items-center px-5 py-3 text-sm"
                     style="border-bottom:1px solid var(--color-line);{{ isFirst ? 'background:rgba(196,113,74,0.07)' : '' }}">
                    <div class="flex items-center gap-2">
                        <span class="text-xs font-bold w-5 text-right shrink-0" style="color:var(--color-muted)">{{ loop.index }}</span>
                        <span style="color:{{ isFirst ? 'var(--color-ink)' : 'var(--color-ink)' }};font-weight:{{ isFirst ? '700' : 'normal' }}">
                            {{ item.guess.playerName }}{% if isFirst %} ✓{% endif %}
                        </span>
                    </div>
                    <div class="text-right">
                        <span class="font-semibold" style="color:var(--color-ink)">{{ item.guess.guessDate|date(dateFormat) }}</span>
                        <span class="text-xs ml-2" style="color:{{ diffDays == 0 ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                            {% if diffDays == 0 %}{{ locale == 'fr' ? 'Exact !' : (locale == 'es' ? '¡Exacto!' : (locale == 'pt' ? 'Exato!' : (locale == 'de' ? 'Genau!' : (locale == 'it' ? 'Esatto!' : 'Exact!')))) }}
                            {% elseif diffDays == 1 %}{{ locale == 'fr' ? '1 jour' : (locale == 'es' ? '1 día' : (locale == 'pt' ? '1 dia' : (locale == 'de' ? '1 Tag' : (locale == 'it' ? '1 giorno' : '1 day')))) }}
                            {% else %}{{ diffDays }}{{ locale == 'fr' ? ' j' : (locale == 'de' ? ' T' : (locale == 'it' ? ' g' : ' d')) }}
                            {% endif %}
                        </span>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="card px-5 py-2">
                {% for g in stats.date.sorted %}
                <div class="flex justify-between items-center py-2.5 text-sm"
                     style="border-bottom: 1px solid var(--color-line)">
                    <span style="color: var(--color-ink)">{{ g.playerName }}</span>
                    <span class="font-semibold" style="color: var(--color-ink)">{{ g.guessDate|date(dateFormat) }}</span>
                </div>
                {% endfor %}
            </div>
            {% endif %}

            {% endif %}
        </div>
        {% endif %}

        {# ── Onglet Poids ─────────────────────────────────────── #}
        {% if game.isGuessWeight() %}
        <div x-show="tab === 'weight'"
             x-transition:enter="transition ease-out duration-150"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100">

            {% if not stats.weight is defined %}
            <div class="card text-center py-10 text-sm" style="color: var(--color-muted)">
                {{ 'games.show.no_data'|trans }}
            </div>
            {% else %}

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
                <div class="rounded-xl p-5 text-center"
                     style="background-color:rgba(196,113,74,0.12)">
                    <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-brand)">
                        {{ 'games.show.weight_avg'|trans }}
                    </p>
                    <p class="text-2xl font-bold" style="color:var(--color-brand)">
                        {{ (stats.weight.avg / 1000)|round(2) }} kg
                    </p>
                </div>
                <div class="rounded-xl p-5 text-center"
                     style="background-color:rgba(196,113,74,0.08)">
                    <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-muted)">
                        {{ 'games.show.weight_min'|trans }}
                    </p>
                    <p class="text-2xl font-bold" style="color:var(--color-ink)">
                        {{ stats.weight.min / 1000 }} kg
                    </p>
                    <p class="text-xs mt-1" style="color:var(--color-muted)">{{ stats.weight.min_player }}</p>
                </div>
                <div class="rounded-xl p-5 text-center"
                     style="background-color:rgba(196,113,74,0.08)">
                    <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-muted)">
                        {{ 'games.show.weight_max'|trans }}
                    </p>
                    <p class="text-2xl font-bold" style="color:var(--color-ink)">
                        {{ stats.weight.max / 1000 }} kg
                    </p>
                    <p class="text-xs mt-1" style="color:var(--color-muted)">{{ stats.weight.max_player }}</p>
                </div>
            </div>

            {% if game.status.value == 'revealed' and game.answerWeight and stats.weight.sorted_by_diff is defined %}
            <div class="card-panel">
                <div class="px-5 py-3 flex items-center justify-between" style="border-bottom:1px solid var(--color-line)">
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--color-muted)">{{ locale == 'fr' ? 'Classement' : (locale == 'es' ? 'Clasificación' : (locale == 'pt' ? 'Classificação' : (locale == 'de' ? 'Rangliste' : (locale == 'it' ? 'Classifica' : 'Ranking')))) }}</p>
                    <p class="text-xs font-semibold" style="color:var(--color-brand)">
                        {{ locale == 'fr' ? 'Réponse :' : (locale == 'es' ? 'Respuesta:' : (locale == 'pt' ? 'Resposta:' : (locale == 'de' ? 'Antwort:' : (locale == 'it' ? 'Risposta:' : 'Answer:')))) }}
                        <span class="font-bold" style="color:var(--color-ink)">{{ (game.answerWeight / 1000)|number_format(3, '.', '') }} kg</span>
                    </p>
                </div>
                {% for item in stats.weight.sorted_by_diff %}
                {% set isFirst = loop.first %}
                <div class="flex justify-between items-center px-5 py-3 text-sm"
                     style="border-bottom:1px solid var(--color-line);{{ isFirst ? 'background:rgba(196,113,74,0.07)' : '' }}">
                    <div class="flex items-center gap-2">
                        <span class="text-xs font-bold w-5 text-right shrink-0" style="color:var(--color-muted)">{{ loop.index }}</span>
                        <span style="font-weight:{{ isFirst ? '700' : 'normal' }};color:var(--color-ink)">
                            {{ item.guess.playerName }}{% if isFirst %} ✓{% endif %}
                        </span>
                    </div>
                    <div class="text-right">
                        <span class="font-semibold" style="color:var(--color-ink)">{{ (item.guess.guessWeight / 1000)|number_format(3, '.', '') }} kg</span>
                        <span class="text-xs ml-2" style="color:{{ item.diff == 0 ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                            {% if item.diff == 0 %}{{ locale == 'fr' ? 'Exact !' : (locale == 'es' ? '¡Exacto!' : (locale == 'pt' ? 'Exato!' : (locale == 'de' ? 'Genau!' : (locale == 'it' ? 'Esatto!' : 'Exact!')))) }}
                            {% elseif item.diff < 1000 %}{{ item.diff }} g
                            {% else %}{{ (item.diff / 1000)|number_format(2, '.', '') }} kg
                            {% endif %}
                        </span>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="card px-5 py-2">
                {% for g in stats.weight.sorted %}
                <div class="flex justify-between items-center py-2.5 text-sm"
                     style="border-bottom: 1px solid var(--color-line)">
                    <span style="color: var(--color-ink)">{{ g.playerName }}</span>
                    <span class="font-semibold" style="color: var(--color-ink)">
                        {{ g.guessWeight / 1000 }} kg
                        {% if g.guessWeight == stats.weight.min %}
                        <span class="text-xs font-normal ml-1" style="color:var(--color-muted)">← {{ 'games.show.weight_min'|trans|lower }}</span>
                        {% elseif g.guessWeight == stats.weight.max %}
                        <span class="text-xs font-normal ml-1" style="color:var(--color-muted)">← {{ 'games.show.weight_max'|trans|lower }}</span>
                        {% endif %}
                    </span>
                </div>
                {% endfor %}
            </div>
            {% endif %}

            {% endif %}
        </div>
        {% endif %}

        {# ── Onglet Taille ────────────────────────────────────── #}
        {% if game.isGuessHeight() %}
        <div x-show="tab === 'height'"
             x-transition:enter="transition ease-out duration-150"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100">

            {% if not stats.height is defined %}
            <div class="card text-center py-10 text-sm" style="color: var(--color-muted)">
                {{ 'games.show.no_data'|trans }}
            </div>
            {% else %}

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
                <div class="rounded-xl p-5 text-center"
                     style="background-color:rgba(196,113,74,0.12)">
                    <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-brand)">
                        {{ 'games.show.height_avg'|trans }}
                    </p>
                    <p class="text-2xl font-bold" style="color:var(--color-brand)">
                        {{ (stats.height.avg / 10)|round(1) }} cm
                    </p>
                </div>
                <div class="rounded-xl p-5 text-center"
                     style="background-color:rgba(196,113,74,0.08)">
                    <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-muted)">
                        {{ 'games.show.height_min'|trans }}
                    </p>
                    <p class="text-2xl font-bold" style="color:var(--color-ink)">
                        {{ stats.height.min / 10 }} cm
                    </p>
                    <p class="text-xs mt-1" style="color:var(--color-muted)">{{ stats.height.min_player }}</p>
                </div>
                <div class="rounded-xl p-5 text-center"
                     style="background-color:rgba(196,113,74,0.08)">
                    <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-muted)">
                        {{ 'games.show.height_max'|trans }}
                    </p>
                    <p class="text-2xl font-bold" style="color:var(--color-ink)">
                        {{ stats.height.max / 10 }} cm
                    </p>
                    <p class="text-xs mt-1" style="color:var(--color-muted)">{{ stats.height.max_player }}</p>
                </div>
            </div>

            {% if game.status.value == 'revealed' and game.answerHeight and stats.height.sorted_by_diff is defined %}
            <div class="card-panel">
                <div class="px-5 py-3 flex items-center justify-between" style="border-bottom:1px solid var(--color-line)">
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--color-muted)">{{ locale == 'fr' ? 'Classement' : (locale == 'es' ? 'Clasificación' : (locale == 'pt' ? 'Classificação' : (locale == 'de' ? 'Rangliste' : (locale == 'it' ? 'Classifica' : 'Ranking')))) }}</p>
                    <p class="text-xs font-semibold" style="color:var(--color-brand)">
                        {{ locale == 'fr' ? 'Réponse :' : (locale == 'es' ? 'Respuesta:' : (locale == 'pt' ? 'Resposta:' : (locale == 'de' ? 'Antwort:' : (locale == 'it' ? 'Risposta:' : 'Answer:')))) }}
                        <span class="font-bold" style="color:var(--color-ink)">{{ (game.answerHeight / 10)|number_format(1, '.', '') }} cm</span>
                    </p>
                </div>
                {% for item in stats.height.sorted_by_diff %}
                {% set isFirst = loop.first %}
                <div class="flex justify-between items-center px-5 py-3 text-sm"
                     style="border-bottom:1px solid var(--color-line);{{ isFirst ? 'background:rgba(196,113,74,0.07)' : '' }}">
                    <div class="flex items-center gap-2">
                        <span class="text-xs font-bold w-5 text-right shrink-0" style="color:var(--color-muted)">{{ loop.index }}</span>
                        <span style="font-weight:{{ isFirst ? '700' : 'normal' }};color:var(--color-ink)">
                            {{ item.guess.playerName }}{% if isFirst %} ✓{% endif %}
                        </span>
                    </div>
                    <div class="text-right">
                        <span class="font-semibold" style="color:var(--color-ink)">{{ (item.guess.guessHeight / 10)|number_format(1, '.', '') }} cm</span>
                        <span class="text-xs ml-2" style="color:{{ item.diff == 0 ? 'var(--color-brand)' : 'var(--color-muted)' }}">
                            {% if item.diff == 0 %}{{ locale == 'fr' ? 'Exact !' : (locale == 'es' ? '¡Exacto!' : (locale == 'pt' ? 'Exato!' : (locale == 'de' ? 'Genau!' : (locale == 'it' ? 'Esatto!' : 'Exact!')))) }}
                            {% elseif item.diff < 10 %}{{ item.diff }} mm
                            {% else %}{{ (item.diff / 10)|number_format(1, '.', '') }} cm
                            {% endif %}
                        </span>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="card px-5 py-2">
                {% for g in stats.height.sorted %}
                <div class="flex justify-between items-center py-2.5 text-sm"
                     style="border-bottom: 1px solid var(--color-line)">
                    <span style="color: var(--color-ink)">{{ g.playerName }}</span>
                    <span class="font-semibold" style="color: var(--color-ink)">
                        {{ g.guessHeight / 10 }} cm
                        {% if g.guessHeight == stats.height.min %}
                        <span class="text-xs font-normal ml-1" style="color:var(--color-muted)">← {{ 'games.show.height_min'|trans|lower }}</span>
                        {% elseif g.guessHeight == stats.height.max %}
                        <span class="text-xs font-normal ml-1" style="color:var(--color-muted)">← {{ 'games.show.height_max'|trans|lower }}</span>
                        {% endif %}
                    </span>
                </div>
                {% endfor %}
            </div>
            {% endif %}

            {% endif %}
        </div>
        {% endif %}

        {# ── Onglet Participants ──────────────────────────────── #}
        <div x-show="tab === 'players'"
             x-transition:enter="transition ease-out duration-150"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100">

            {% if stats.total == 0 %}
            <div class="card text-center py-10 text-sm" style="color: var(--color-muted)">
                {{ 'games.show.no_data'|trans }}
            </div>
            {% else %}

            {# Quand révélé : guessesRanked (trié par score), sinon guesses brut #}
            {% set useRanked = game.status.value == 'revealed' and guessesRanked %}
            {% set maxScore  = useRanked ? guessesRanked.max : 0 %}

            <div class="card-panel" x-data="{ open: null }">
                {% set entries = useRanked ? guessesRanked.items : guesses %}
                {% for entry in entries %}
                {% set g     = useRanked ? entry.guess : entry %}
                {% set score = useRanked ? entry.score : null %}
                <div style="{{ not loop.last ? 'border-bottom: 1px solid var(--color-line)' : '' }}">

                    <button @click="open = open === {{ loop.index }} ? null : {{ loop.index }}"
                            class="w-full flex items-center justify-between px-5 py-4 text-left transition-colors hover:bg-[#F8F3EE]">
                        <div class="flex items-center gap-3">
                            {% if score is not null and maxScore > 0 %}
                            <span class="shrink-0 w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold"
                                  style="background:{{ score == maxScore ? 'var(--color-brand)' : (score > 0 ? 'rgba(196,113,74,0.18)' : 'var(--color-cream)') }};color:{{ score == maxScore ? '#fff' : (score > 0 ? 'var(--color-brand)' : 'var(--color-muted)') }}">
                                {{ score }}
                            </span>
                            {% endif %}
                            <div class="flex flex-col">
                                <span class="text-sm font-semibold" style="color: var(--color-ink)">{{ g.playerName }}</span>
                                <span class="text-xs mt-0.5" style="color: var(--color-muted)">
                                    {{ g.createdAt|date(dateFormat) }} · {{ g.createdAt|date('H:i') }}
                                </span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            {% if score is not null and maxScore > 0 %}
                            <span class="text-xs" style="color:var(--color-muted)">{{ score }}/{{ maxScore }}</span>
                            {% endif %}
                            <svg class="w-4 h-4 shrink-0 transition-transform duration-200"
                                 :style="open === {{ loop.index }} ? 'transform:rotate(180deg)' : ''"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <polyline points="6 9 12 15 18 9"/>
                            </svg>
                        </div>
                    </button>

                    <div x-show="open === {{ loop.index }}"
                         x-transition:enter="transition ease-out duration-150"
                         x-transition:enter-start="opacity-0"
                         x-transition:enter-end="opacity-100"
                         class="px-5 pb-4"
                         style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem 1.5rem">
                        {% if game.isGuessGender() and g.guessGender %}
                        <div>
                            <p class="text-xs mb-0.5" style="color: var(--color-muted)">{{ 'games.show.tab_gender'|trans }}</p>
                            <p class="text-sm font-semibold"
                               style="color: {{ g.guessGender.value == 'boy' ? 'var(--color-brand)' : 'var(--color-accent)' }}">
                                {{ g.guessGender.value == 'boy' ? 'games.show.gender_boy'|trans : 'games.show.gender_girl'|trans }}
                                {% if game.status.value == 'revealed' and game.answerGender and g.guessGender.value == game.answerGender.value %} ✓{% endif %}
                            </p>
                        </div>
                        {% endif %}
                        {% if game.isGuessName() and g.guessName %}
                        <div>
                            <p class="text-xs mb-0.5" style="color: var(--color-muted)">{{ 'games.show.tab_name'|trans }}</p>
                            <p class="text-sm font-semibold" style="color: var(--color-ink)">
                                {{ g.guessName }}
                                {% if game.status.value == 'revealed' and game.answerName and g.guessName|lower|trim == game.answerName|lower|trim %} ✓{% endif %}
                            </p>
                        </div>
                        {% endif %}
                        {% if game.isGuessDate() and g.guessDate %}
                        <div>
                            <p class="text-xs mb-0.5" style="color: var(--color-muted)">{{ 'games.show.tab_date'|trans }}</p>
                            <p class="text-sm font-semibold" style="color: var(--color-ink)">{{ g.guessDate|date(dateFormat) }}</p>
                        </div>
                        {% endif %}
                        {% if game.isGuessWeight() and g.guessWeight %}
                        <div>
                            <p class="text-xs mb-0.5" style="color: var(--color-muted)">{{ 'games.show.tab_weight'|trans }}</p>
                            <p class="text-sm font-semibold" style="color: var(--color-ink)">{{ (g.guessWeight / 1000)|round(2) }} kg</p>
                        </div>
                        {% endif %}
                        {% if game.isGuessHeight() and g.guessHeight %}
                        <div>
                            <p class="text-xs mb-0.5" style="color: var(--color-muted)">{{ 'games.show.tab_height'|trans }}</p>
                            <p class="text-sm font-semibold" style="color: var(--color-ink)">{{ (g.guessHeight / 10)|round(1) }} cm</p>
                        </div>
                        {% endif %}
                    </div>

                </div>
                {% endfor %}
            </div>
            {% endif %}

        </div>

    </div>{# /x-data #}

</div>
{% endblock %}
