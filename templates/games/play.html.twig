{% extends 'base.html.twig' %}

{% set _invite_title = 'play.identify.welcome_title'|trans({'%name%': game.user.firstName}) %}
{% set _invite_desc  = 'play.identify.welcome_desc'|trans({'%name%': game.user.firstName}) %}

{% block title %}{{ _invite_title }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}
{% block meta_description %}{{ _invite_desc }}{% endblock %}
{% block og_title %}{{ _invite_title }}{% endblock %}
{% block og_description %}{{ _invite_desc }}{% endblock %}

{% block og_image %}
{% set _base = app.request.schemeAndHttpHost %}
{% set _img_url = game.image ? (_base ~ '/' ~ game.image) : (_base ~ asset('images/logo-mybabyguessr.png')) %}
<meta property="og:image" content="{{ _img_url }}">
{% if game.image %}
<meta property="og:image:alt" content="{{ game.displayTitle }}">
{% else %}
<meta property="og:image:width"  content="1024">
<meta property="og:image:height" content="1024">
<meta property="og:image:alt"    content="MyBabyGuessr">
{% endif %}
{% endblock %}

{% block twitter_card %}{{ game.image ? 'summary_large_image' : 'summary' }}{% endblock %}
{% block twitter_image %}{% set _b = app.request.schemeAndHttpHost %}{{ game.image ? (_b ~ '/' ~ game.image) : (_b ~ asset('images/logo-mybabyguessr.png')) }}{% endblock %}

{% block stylesheets %}
<style>
.deco-play { position:absolute; pointer-events:none; z-index:2; }
.deco-play-papillon { top:20px; left:20px; width:51px; opacity:0.76; }
.deco-play-soleil   { top:6px; right:10px; width:86px; opacity:0.70; }
.deco-play-lion     { bottom:-10px; right:10px; width:72px; opacity:0.88; }
@media (min-width:640px) {
    .deco-play-papillon { top:24px; left:calc(50% - 258px); width:63px; }
    .deco-play-soleil   { top:8px; left:calc(50% + 192px); width:98px; }
    .deco-play-lion     { bottom:-10px; left:calc(50% + 218px); width:100px; }
}
</style>
{% endblock %}

{% block body %}
<section class="flex items-center justify-center min-h-[calc(100vh-10rem)] px-4 py-6 sm:py-12"
         style="position:relative;overflow:hidden">

    <img src="{{ asset('images/illustration/papillon3.png') }}" alt="" aria-hidden="true" class="deco-play deco-play-papillon">
    <img src="{{ asset('images/illustration/soleil.png') }}"    alt="" aria-hidden="true" class="deco-play deco-play-soleil">
    <img src="{{ asset('images/illustration/lion.png') }}"      alt="" aria-hidden="true" class="deco-play deco-play-lion">

<div class="card w-full max-w-md" style="position:relative;z-index:1">

    {# ── Logo ─────────────────────────────────────────────────── #}
    <div class="flex justify-center mb-6">
        <img src="{{ asset('images/logo-mybabyguessr.png') }}"
             alt="MyBabyGuessr"
             width="1024" height="1024"
             fetchpriority="high"
             class="h-16 w-auto">
    </div>

    {# ── Accueil ──────────────────────────────────────────────── #}
    <div class="text-center mb-8">
        <h1 class="text-2xl sm:text-3xl font-bold mb-2" style="color: var(--color-ink)">
            {{ game.displayTitle }}
        </h1>
        <p class="text-base font-semibold mb-3" style="color: var(--color-brand)">
            {{ 'play.identify.welcome_title'|trans({'%name%': game.user.firstName}) }}
        </p>
        <p class="text-sm leading-relaxed" style="color: var(--color-muted)">
            {{ 'play.identify.welcome_desc'|trans({'%name%': game.user.firstName}) }}
        </p>
    </div>

    {# ── Formulaire ───────────────────────────────────────────── #}
    <form method="post" novalidate>
        <input type="hidden" name="_token" value="{{ csrf_token('play_identify') }}">
        {% if nameExists %}
        <input type="hidden" name="_skip_name_check" value="1">
        {% endif %}

        {# Prénom / surnom #}
        <div class="mb-5">
            <label for="player_name" class="form-label">
                {{ 'play.identify.name_label'|trans }}
                <span aria-hidden="true" class="text-red-500 ml-0.5">*</span>
            </label>
            <input type="text"
                   id="player_name"
                   name="player_name"
                   class="form-input"
                   value="{{ formData.player_name|e('html_attr') }}"
                   placeholder="{{ 'play.identify.name_placeholder'|trans }}"
                   maxlength="100"
                   autocomplete="nickname"
                   autofocus
                   required
                   aria-describedby="error-player-name"
                   {% if errors.name is defined %}aria-invalid="true" style="border-color: #ef4444;"{% endif %}>
            {% if errors.name is defined %}
            <p id="error-player-name" class="mt-1.5 flex items-start gap-1.5 text-sm text-red-600" role="alert">
                <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>{{ 'play.identify.name_error'|trans }}</span>
            </p>
            {% elseif nameExists %}
            <p class="mt-2 text-sm px-3 py-2 rounded-lg leading-relaxed" role="alert"
               style="background-color: rgba(196,113,74,0.10); color: var(--color-brand)">
                {{ 'play.identify.name_duplicate'|trans }}
            </p>
            {% endif %}
        </div>

        {# Email optionnel #}
        <div class="mb-7">
            <label for="player_email" class="form-label">
                {{ 'play.identify.email_label'|trans }}
                <span class="text-xs font-normal ml-1" style="color: var(--color-muted)">
                    ({{ app.request.locale == 'fr' ? 'facultatif' : (app.request.locale == 'es' or app.request.locale == 'pt' ? 'opcional' : (app.request.locale == 'it' ? 'facoltativo' : 'optional')) }})
                </span>
            </label>
            <input type="email"
                   id="player_email"
                   name="player_email"
                   class="form-input"
                   value="{{ formData.player_email|e('html_attr') }}"
                   placeholder="{{ 'play.identify.email_placeholder'|trans }}"
                   maxlength="255"
                   autocomplete="email"
                   aria-describedby="error-player-email"
                   {% if errors.email is defined %}aria-invalid="true" style="border-color: #ef4444;"{% endif %}>
            {% if errors.email is defined %}
            <p class="mt-1.5 flex items-start gap-1.5 text-sm text-red-600" role="alert">
                <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>{{ 'play.identify.email_error'|trans }}</span>
            </p>
            {% else %}
            <p class="mt-1 text-sm leading-relaxed" style="color: var(--color-muted)">
                {{ 'play.identify.email_hint'|trans }}
            </p>
            {% endif %}
        </div>

        <button type="submit" class="btn btn-primary w-full">
            {{ 'play.identify.submit'|trans }}
        </button>

    </form>

</div>
</section>
{% endblock %}
