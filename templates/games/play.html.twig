{% extends 'base.html.twig' %}

{% set _invite_title = app.request.locale == 'fr'
    ? game.user.firstName ~ ' vous invite à jouer !'
    : game.user.firstName ~ ' invites you to play!' %}
{% set _invite_desc = app.request.locale == 'fr'
    ? game.displayTitle ~ ' — Participez et faites vos pronostics sur l\'arrivée du bébé !'
    : game.displayTitle ~ ' — Join in and make your predictions about the baby\'s arrival!' %}

{% block title %}{{ _invite_title }}{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}
{% block meta_description %}{{ _invite_desc }}{% endblock %}
{% block og_title %}{{ _invite_title }} — MyBabyGuessr{% endblock %}
{% block og_description %}{{ _invite_desc }}{% endblock %}

{% block og_image %}
{% set _img_url = game.image ? absolute_url(asset(game.image)) : absolute_url(asset('images/logo-mybabyguessr.png')) %}
<meta property="og:image" content="{{ _img_url }}">
{% if game.image %}
<meta property="og:image:alt" content="{{ game.displayTitle }}">
{% else %}
<meta property="og:image:width"  content="1024">
<meta property="og:image:height" content="1024">
<meta property="og:image:alt"    content="MyBabyGuessr">
{% endif %}
{% endblock %}

{% block twitter_card %}{{ game.image ? 'summary_large_image' : 'summary' }}{% endblock %}
{% block twitter_image %}{{ game.image ? absolute_url(asset(game.image)) : absolute_url(asset('images/logo-mybabyguessr.png')) }}{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 sm:px-6 py-12 text-center">

    {% if game.image %}
    <div class="mx-auto mb-8 rounded-2xl overflow-hidden"
         style="max-width: 24rem; height: 14rem;">
        <img src="{{ asset(game.image) }}"
             alt="{{ game.displayTitle }}"
             style="width: 100%; height: 100%; object-fit: cover; display: block;">
    </div>
    {% endif %}

    <h1 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--color-ink)">
        {{ game.displayTitle }}
    </h1>

    <p class="text-base leading-relaxed" style="color: var(--color-muted)">
        {{ 'play.coming_soon'|trans }}
    </p>

</div>
{% endblock %}
