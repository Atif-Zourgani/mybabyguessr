{% extends 'base.html.twig' %}

{% block title %}{{ 'register.title'|trans }} — MyBabyGuessr{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block stylesheets %}
<style>
.deco-reg { position:absolute; pointer-events:none; z-index:2; }
.deco-reg-papillon { top:20px; left:24px; width:54px; opacity:0.78; }
.deco-reg-etoile   { top:16px; right:24px; width:45px; opacity:0.72; }
.deco-reg-singe    { bottom:0; right:12px; width:65px; opacity:0.88; }
@media (min-width:640px) {
    .deco-reg-papillon { top:24px; left:calc(50% - 252px); width:66px; }
    .deco-reg-etoile   { top:18px; left:calc(50% + 200px); width:57px; }
    .deco-reg-singe    { bottom:0; left:calc(50% + 208px); width:95px; }
}
</style>
{% endblock %}

{% block body %}
<section class="flex items-center justify-center min-h-[calc(100vh-10rem)] px-4 py-6 sm:py-12"
         style="position:relative;overflow:hidden">

    <img src="{{ asset('images/illustration/papillon3.png') }}" alt="" aria-hidden="true" class="deco-reg deco-reg-papillon">
    <img src="{{ asset('images/illustration/etoile.png') }}"   alt="" aria-hidden="true" class="deco-reg deco-reg-etoile">
    <img src="{{ asset('images/illustration/singe.png') }}"    alt="" aria-hidden="true" class="deco-reg deco-reg-singe">

    <div class="card w-full max-w-md" style="position:relative;z-index:1">

        {# Logo #}
        <div class="flex justify-center mb-6">
            <img src="{{ asset('images/logo-mybabyguessr.png') }}"
                 alt="MyBabyGuessr"
                 width="1024" height="1024"
                 fetchpriority="high"
                 class="h-16 sm:h-28 w-auto">
        </div>

        <h1 class="text-2xl text-center mb-8">{{ 'register.title'|trans }}</h1>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm) }}

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {{ form_row(registrationForm.firstName, {label: 'register.first_name'|trans}) }}
                {{ form_row(registrationForm.lastName,  {label: 'register.last_name'|trans}) }}
            </div>

            {{ form_row(registrationForm.email,       {label: 'register.email'|trans}) }}
            {{ form_row(registrationForm.plainPassword, {label: 'register.password'|trans}) }}
            {% set terms_link = '<a href="' ~ path('app_terms', {'_locale': app.request.locale}) ~ '" class="underline hover:opacity-80" target="_blank" rel="noopener">' ~ 'register.terms_label'|trans ~ '</a>' %}
            {% set privacy_link = '<a href="' ~ path('app_privacy', {'_locale': app.request.locale}) ~ '" class="underline hover:opacity-80" target="_blank" rel="noopener">' ~ 'register.privacy_label'|trans ~ '</a>' %}
            {{ form_row(registrationForm.agreeTerms, {
                label: 'register.agree_terms'|trans({'%cgu%': terms_link, '%privacy%': privacy_link}),
                label_html: true
            }) }}

            <button type="submit" class="btn btn-primary w-full mt-2">
                {{ 'register.submit'|trans }}
            </button>

        {{ form_end(registrationForm) }}

        <p class="text-center text-sm text-muted mt-6">
            {{ 'register.already_account'|trans }}
            <a href="{{ path('app_login', {'_locale': app.request.locale}) }}">
                {{ 'login.title'|trans }}
            </a>
        </p>

    </div>
</section>
{% endblock %}
