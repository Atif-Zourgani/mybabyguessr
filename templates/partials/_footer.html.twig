<footer class="mt-auto border-t border-line" role="contentinfo"
        style="background:var(--color-cream);padding:2.5rem 1rem 2rem">

    <div class="max-w-2xl mx-auto flex flex-col items-center gap-5 text-center">

        {# Logo #}
        <a href="{{ path('app_home', {'_locale': app.request.locale}) }}"
           aria-label="MyBabyGuessr"
           style="text-decoration:none;display:inline-block">
            <img src="{{ asset('images/logo-mybabyguessr.png') }}"
                 alt=""
                 width="612" height="408"
                 loading="lazy"
                 style="height:3rem;width:auto">
        </a>

        {# Copyright #}
        <p style="font-size:0.8125rem;color:var(--color-muted);margin:0">
            © {{ "now"|date("Y") }} MyBabyGuessr &nbsp;·&nbsp; {{ 'home.hero.subtitle'|trans }}
        </p>

        {# Liens légaux #}
        <nav aria-label="{{ 'footer.legal_nav_label'|trans }}"
             style="display:flex;flex-wrap:wrap;justify-content:center;gap:0.375rem 1rem;font-size:0.75rem">
            <a href="{{ path('app_privacy',  {'_locale': app.request.locale}) }}"
               class="hover:underline" style="color:var(--color-muted)">{{ 'footer.privacy'|trans }}</a>
            <span style="color:var(--color-line)" aria-hidden="true">·</span>
            <a href="{{ path('app_terms',    {'_locale': app.request.locale}) }}"
               class="hover:underline" style="color:var(--color-muted)">{{ 'footer.terms'|trans }}</a>
            <span style="color:var(--color-line)" aria-hidden="true">·</span>
            <a href="{{ path('app_mentions', {'_locale': app.request.locale}) }}"
               class="hover:underline" style="color:var(--color-muted)">{{ 'footer.mentions'|trans }}</a>
            <span style="color:var(--color-line)" aria-hidden="true">·</span>
            <a href="mailto:contact@mybabyguessr.com"
               class="hover:underline" style="color:var(--color-muted)">{{ 'footer.contact'|trans }}</a>
            <span style="color:var(--color-line)" aria-hidden="true">·</span>
            <button onclick="mbgCookies.manage()"
                    style="background:none;border:none;cursor:pointer;font-size:inherit;font-family:inherit;padding:0;color:var(--color-muted)"
                    class="hover:underline">
                {{ 'footer.manage_cookies'|trans }}
            </button>
        </nav>

        {# Made by #}
        <p style="font-size:0.75rem;color:var(--color-muted);margin:0">
            Made by <a href="https://www.linkedin.com/in/atif-micka%C3%ABl/"
                       target="_blank" rel="noopener noreferrer"
                       aria-label="Atif Zourgani — LinkedIn (nouvel onglet)"
                       class="hover:underline font-semibold"
                       style="color:var(--color-brand)">Atif Zourgani</a>
        </p>

    </div>
</footer>
