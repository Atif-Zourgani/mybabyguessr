<header class="bg-cream border-b border-line" role="banner">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between gap-4">

        <a href="{{ path('app_home', {'_locale': app.request.locale}) }}"
           aria-label="MyBabyGuessr — {{ app.request.locale == 'fr' ? 'Accueil' : 'Home' }}"
           class="shrink-0"
           style="text-decoration:none">
            <img src="{{ asset('images/logo-mybabyguessr-wide.png') }}"
                 alt="MyBabyGuessr"
                 width="612" height="408"
                 class="h-20 md:h-32 w-auto">
        </a>

        <div class="flex items-center gap-3">

            {% if app.user %}
                {% if is_granted('ROLE_ADMIN') %}
                    {% set _on_admin = app.request.attributes.get('_route') starts with 'app_admin' %}
                    <a href="{{ _on_admin
                            ? path('app_dashboard', {'_locale': app.request.locale})
                            : path('app_admin_index', {'_locale': app.request.locale}) }}"
                       class="flex items-center gap-1.5 text-xs font-bold px-2.5 py-1 rounded-full transition-colors hover:opacity-80"
                       style="background-color:rgba(196,113,74,0.12);color:var(--color-brand);text-decoration:none">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                        </svg>
                        {{ _on_admin ? 'Mes jeux' : 'Admin' }}
                    </a>
                {% endif %}

                {# ── Menu utilisateur ── #}
                <div x-data="{ open: false }"
                     @click.away="open = false"
                     @keydown.escape="open = false"
                     class="relative">
                    <button @click="open = !open"
                            :aria-expanded="open"
                            type="button"
                            class="flex items-center gap-2 rounded-lg px-2.5 py-1.5 transition-colors"
                            style="color:var(--color-ink);border:1px solid var(--color-line);background:var(--color-cream)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="8" r="4"/>
                            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                        </svg>
                        <span class="hidden sm:inline text-sm font-bold">{{ app.user.firstName }}</span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                             :style="open ? 'transform:rotate(180deg)' : ''"
                             style="transition:transform 0.15s ease">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </button>

                    <div x-show="open"
                         x-cloak
                         x-transition:enter="transition ease-out duration-150"
                         x-transition:enter-start="opacity-0 translate-y-1"
                         x-transition:enter-end="opacity-100 translate-y-0"
                         x-transition:leave="transition ease-in duration-100"
                         x-transition:leave-start="opacity-100 translate-y-0"
                         x-transition:leave-end="opacity-0 translate-y-1"
                         class="absolute right-0 mt-1 rounded-lg overflow-hidden"
                         style="top:100%;min-width:180px;background:var(--color-cream);border:1px solid var(--color-line);box-shadow:0 4px 20px rgba(0,0,0,0.10);z-index:50">

                        <a href="{{ path('app_dashboard', {'_locale': app.request.locale}) }}"
                           class="flex items-center gap-2.5 px-4 py-3 text-sm font-semibold transition-colors hover:bg-white"
                           style="text-decoration:none;color:var(--color-ink)">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                                <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                            </svg>
                            {{ app.request.locale == 'fr' ? 'Mes jeux' : 'My games' }}
                        </a>

                        <a href="{{ path('app_profile', {'_locale': app.request.locale}) }}"
                           class="flex items-center gap-2.5 px-4 py-3 text-sm font-semibold transition-colors hover:bg-white"
                           style="text-decoration:none;color:var(--color-ink)">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="8" r="4"/>
                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                            </svg>
                            {{ 'profile.nav'|trans }}
                        </a>

                        <div style="border-top:1px solid var(--color-line)"></div>

                        <a href="{{ path('app_logout', {'_locale': app.request.locale}) }}"
                           class="flex items-center gap-2.5 px-4 py-3 text-sm font-semibold transition-colors hover:bg-white"
                           style="text-decoration:none;color:var(--color-muted)">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                <polyline points="16 17 21 12 16 7"/>
                                <line x1="21" y1="12" x2="9" y2="12"/>
                            </svg>
                            {{ 'login.logout'|trans }}
                        </a>
                    </div>
                </div>
            {% endif %}

            {% if app.request.attributes.has('_route') %}
                {% set _route  = app.request.attributes.get('_route') %}
                {% set _params = app.request.attributes.get('_route_params') %}
                {% set _langs = [
                    {'code': 'fr', 'label': 'Français',   'flag': 'fr'},
                    {'code': 'en', 'label': 'English',    'flag': 'gb'},
                    {'code': 'es', 'label': 'Español',    'flag': 'es'},
                    {'code': 'pt', 'label': 'Português',  'flag': 'pt'},
                    {'code': 'de', 'label': 'Deutsch',    'flag': 'de'},
                    {'code': 'it', 'label': 'Italiano',   'flag': 'it'}
                ] %}
                <nav aria-label="{{ 'nav.lang_' ~ app.request.locale|default('fr')|trans }}"
                     x-data="{ open: false }"
                     @click.away="open = false"
                     @keydown.escape="open = false"
                     class="relative">

                    {% set _currentFlag = '' %}
                    {% for lang in _langs %}{% if lang.code == app.request.locale %}{% set _currentFlag = lang.flag %}{% endif %}{% endfor %}
                    <button @click="open = !open"
                            :aria-expanded="open"
                            type="button"
                            class="flex items-center gap-1.5 text-sm font-bold rounded-lg px-2.5 py-1.5 transition-colors"
                            style="color:var(--color-ink);border:1px solid var(--color-line);background:var(--color-cream)">
                        <span class="fi fi-{{ _currentFlag }}" style="width:20px;height:15px;border-radius:2px" aria-hidden="true"></span>
                        <span>{{ app.request.locale|upper }}</span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true"
                             :style="open ? 'transform:rotate(180deg)' : ''"
                             style="transition:transform 0.15s ease">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </button>

                    <div x-show="open"
                         x-cloak
                         x-transition:enter="transition ease-out duration-150"
                         x-transition:enter-start="opacity-0 translate-y-1"
                         x-transition:enter-end="opacity-100 translate-y-0"
                         x-transition:leave="transition ease-in duration-100"
                         x-transition:leave-start="opacity-100 translate-y-0"
                         x-transition:leave-end="opacity-0 translate-y-1"
                         class="absolute right-0 mt-1 rounded-lg overflow-hidden"
                         style="top:100%;min-width:148px;background:var(--color-cream);border:1px solid var(--color-line);box-shadow:0 4px 20px rgba(0,0,0,0.10);z-index:50">
                        {% for lang in _langs %}
                        <a href="{{ url(_route, _params|merge({'_locale': lang.code})) }}"
                           hreflang="{{ lang.code }}"
                           {% if app.request.locale == lang.code %}aria-current="true"{% endif %}
                           class="flex items-center gap-2 px-3 py-2.5 text-sm font-bold transition-colors"
                           style="text-decoration:none;color:var(--color-ink);{% if app.request.locale == lang.code %}background:rgba(196,113,74,0.10);{% endif %}">
                            <span class="fi fi-{{ lang.flag }}" style="width:20px;height:15px;border-radius:2px;flex-shrink:0" aria-hidden="true"></span>
                            {{ lang.label }}
                            {% if app.request.locale == lang.code %}
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                 stroke="var(--color-brand)" stroke-width="3"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                                 class="ml-auto">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            {% endif %}
                        </a>
                        {% endfor %}
                    </div>

                </nav>
            {% endif %}

        </div>
    </div>
</header>
